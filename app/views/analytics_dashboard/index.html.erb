<% content_for :head do %>
<style>
  .an-page { background: #FAFAF7; min-height: 100vh; }
  .an-header { border-bottom: 1.5px solid #E8E4DC; background: #fff; padding: 1.25rem 0; margin-bottom: 2rem; }
  .an-title { font-size: 1.4rem; font-weight: 700; color: #2C2A25; }
  .an-subtitle { font-size: 0.85rem; color: #9B9588; margin-top: 2px; }

  /* Period tabs */
  .period-tabs { display: flex; gap: 0.35rem; }
  .period-tab {
    padding: 0.3rem 0.85rem; border-radius: 20px; font-size: 0.82rem; font-weight: 500;
    border: 1.5px solid #C8C4BC; color: #4A4640; text-decoration: none;
    transition: all 0.15s;
  }
  .period-tab:hover  { border-color: #2C2A25; color: #2C2A25; }
  .period-tab.active { background: #2C2A25; border-color: #2C2A25; color: #fff; }

  /* KPI cards */
  .kpi-card {
    background: #fff; border: 1.5px solid #E8E4DC; border-radius: 12px;
    padding: 1.25rem 1.5rem; position: relative; overflow: hidden;
  }
  .kpi-label { font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #9B9588; margin-bottom: 0.5rem; }
  .kpi-value { font-size: 2rem; font-weight: 700; color: #2C2A25; line-height: 1; }
  .kpi-sub   { font-size: 0.8rem; color: #9B9588; margin-top: 0.35rem; }
  .kpi-accent { position: absolute; top: 0; left: 0; width: 4px; height: 100%; border-radius: 12px 0 0 12px; }

  /* Section headers */
  .an-section { margin-bottom: 2rem; }
  .an-section-title {
    font-size: 0.95rem; font-weight: 700; color: #2C2A25;
    margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem;
  }

  /* Bar chart */
  .bar-row { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.55rem; }
  .bar-label { font-size: 0.8rem; color: #4A4640; width: 180px; flex-shrink: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .bar-track { flex: 1; height: 8px; background: #F0EDE8; border-radius: 4px; overflow: hidden; }
  .bar-fill  { height: 100%; border-radius: 4px; background: #2563EB; transition: width 0.4s ease; }
  .bar-fill.green  { background: #2D9B5F; }
  .bar-fill.orange { background: #D97706; }
  .bar-count { font-size: 0.8rem; color: #9B9588; width: 44px; text-align: right; flex-shrink: 0; }

  /* Sparkline */
  .sparkline { display: flex; align-items: flex-end; gap: 3px; height: 48px; }
  .spark-bar { flex: 1; background: #2563EB; border-radius: 2px 2px 0 0; min-height: 2px; opacity: 0.8; }

  /* Table overrides for this page */
  .an-table { width: 100%; border-collapse: collapse; }
  .an-table thead th {
    font-size: 0.72rem; font-weight: 700; color: #9B9588; text-transform: uppercase;
    letter-spacing: 0.05em; border-bottom: 1.5px solid #E8E4DC; padding: 0.5rem 0.75rem;
  }
  .an-table tbody td {
    font-size: 0.85rem; color: #2C2A25; padding: 0.6rem 0.75rem;
    border-bottom: 1px solid #F0EDE8; vertical-align: middle;
  }
  .an-table tbody tr:last-child td { border-bottom: none; }
  .an-table tbody tr:hover td { background: #FAFAF7; }
  .an-table .mono { font-family: ui-monospace, monospace; font-size: 0.8rem; color: #4A4640; }

  /* Event type pill */
  .ev-pill {
    display: inline-block; padding: 0.15em 0.65em; border-radius: 20px;
    font-size: 0.75rem; font-weight: 600; background: #EDE9E0; color: #4A4640;
  }
  .ev-pill.page_view    { background: #DBEAFE; color: #1D4ED8; }
  .ev-pill.time_on_page { background: #D1FAE5; color: #065F46; }
  .ev-pill.js_error     { background: #FEE2E2; color: #991B1B; }
  .ev-pill.form_submit  { background: #FEF9C3; color: #92400E; }
  .ev-pill.click        { background: #EDE9FE; color: #5B21B6; }
  .ev-pill.server_error { background: #FEE2E2; color: #991B1B; }
</style>
<% end %>

<div class="an-page">
  <%# Header %>
  <div class="an-header">
    <div class="container" style="max-width: 1200px;">
      <div class="d-flex justify-content-between align-items-center">
        <div>
          <div class="an-title">Analytics</div>
          <div class="an-subtitle">
            <%= @days %> derniers jours
            <% if @total_events %>&middot; <%= @total_events %> événements<% end %>
            &middot; Mis à jour <%= l(Time.current, format: :short) %>
          </div>
        </div>
        <div class="period-tabs">
          <%= link_to "7j",  analytics_dashboard_path(days: 7),  class: "period-tab #{@days == 7  ? 'active' : ''}" %>
          <%= link_to "30j", analytics_dashboard_path(days: 30), class: "period-tab #{@days == 30 ? 'active' : ''}" %>
          <%= link_to "90j", analytics_dashboard_path(days: 90), class: "period-tab #{@days == 90 ? 'active' : ''}" %>
        </div>
      </div>
    </div>
  </div>

  <div class="container pb-5" style="max-width: 1200px;">

    <%# ── Tab nav ─────────────────────────────────────────────── %>
    <div style="display: flex; gap: 0.25rem; border-bottom: 1.5px solid #E8E4DC; margin-bottom: 2rem;">
      <%= link_to analytics_dashboard_path(days: @days), style: "padding: 0.6rem 1.1rem; font-size: 0.88rem; font-weight: 600; text-decoration: none; border-bottom: 2.5px solid #{@tab == 'overview' ? '#2563EB' : 'transparent'}; color: #{@tab == 'overview' ? '#2563EB' : '#9B9588'}; margin-bottom: -1.5px;" do %>
        Vue d'ensemble
      <% end %>
      <%= link_to analytics_dashboard_path(tab: "users"), style: "padding: 0.6rem 1.1rem; font-size: 0.88rem; font-weight: 600; text-decoration: none; border-bottom: 2.5px solid #{@tab == 'users' ? '#2563EB' : 'transparent'}; color: #{@tab == 'users' ? '#2563EB' : '#9B9588'}; margin-bottom: -1.5px;" do %>
        Utilisateurs
      <% end %>
    </div>

    <% if @tab == "overview" %>
    <%# ── KPI row ──────────────────────────────────────────────── %>
    <div class="row g-3 mb-4">
      <div class="col-6 col-lg">
        <div class="kpi-card">
          <div class="kpi-accent" style="background: #2563EB;"></div>
          <div class="kpi-label">Événements</div>
          <div class="kpi-value"><%= number_with_delimiter(@total_events) %></div>
          <div class="kpi-sub"><%= @days %>j glissants</div>
        </div>
      </div>
      <div class="col-6 col-lg">
        <div class="kpi-card">
          <div class="kpi-accent" style="background: #7C3AED;"></div>
          <div class="kpi-label">Sessions</div>
          <div class="kpi-value"><%= number_with_delimiter(@total_sessions) %></div>
          <div class="kpi-sub">Visites uniques</div>
        </div>
      </div>
      <div class="col-6 col-lg">
        <div class="kpi-card">
          <div class="kpi-accent" style="background: #059669;"></div>
          <div class="kpi-label">Utilisateurs</div>
          <div class="kpi-value"><%= number_with_delimiter(@unique_users) %></div>
          <div class="kpi-sub">Connectés</div>
        </div>
      </div>
      <div class="col-6 col-lg">
        <div class="kpi-card">
          <div class="kpi-accent" style="background: #D97706;"></div>
          <div class="kpi-label">Conversion</div>
          <div class="kpi-value"><%= @conversion_rate %>%</div>
          <div class="kpi-sub">Sessions converties</div>
        </div>
      </div>
      <div class="col-6 col-lg">
        <div class="kpi-card">
          <div class="kpi-accent" style="background: #DB2777;"></div>
          <div class="kpi-label">Durée moy.</div>
          <div class="kpi-value">
            <% mins = (@avg_duration / 60).to_i; secs = (@avg_duration % 60).to_i %>
            <% if mins > 0 %><%= "#{mins}m#{secs}s" %><% else %><%= "#{secs}s" %><% end %>
          </div>
          <div class="kpi-sub">Par session</div>
        </div>
      </div>
    </div>

    <% end %><%# /overview KPI row %>

    <% if @tab == "users" %>
      <%# ── All users tab ───────────────────────────────────────── %>
      <div class="od-card">
        <div style="overflow-x: auto;">
          <table style="width: 100%; border-collapse: collapse;">
            <thead>
              <tr>
                <th style="font-size: 0.72rem; font-weight: 700; color: #9B9588; text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 1.5px solid #E8E4DC; padding: 0.75rem 1rem; text-align: left;">Utilisateur</th>
                <th style="font-size: 0.72rem; font-weight: 700; color: #9B9588; text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 1.5px solid #E8E4DC; padding: 0.75rem 1rem; text-align: left;">Email</th>
                <th style="font-size: 0.72rem; font-weight: 700; color: #9B9588; text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 1.5px solid #E8E4DC; padding: 0.75rem 1rem; text-align: left;">Première visite</th>
                <th style="font-size: 0.72rem; font-weight: 700; color: #9B9588; text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 1.5px solid #E8E4DC; padding: 0.75rem 1rem; text-align: left;">Dernière visite</th>
                <th style="font-size: 0.72rem; font-weight: 700; color: #9B9588; text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 1.5px solid #E8E4DC; padding: 0.75rem 1rem; text-align: left;">Sessions</th>
                <th style="font-size: 0.72rem; font-weight: 700; color: #9B9588; text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 1.5px solid #E8E4DC; padding: 0.75rem 1rem; text-align: left;">Événements</th>
                <th style="font-size: 0.72rem; font-weight: 700; color: #9B9588; text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 1.5px solid #E8E4DC; padding: 0.75rem 1rem; text-align: left;">Temps total</th>
                <th style="font-size: 0.72rem; font-weight: 700; color: #9B9588; text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 1.5px solid #E8E4DC; padding: 0.75rem 1rem; text-align: left;">Dernière page</th>
              </tr>
            </thead>
            <tbody>
              <% if @all_users.any? %>
                <% @all_users.each do |row| %>
                  <tr style="cursor: pointer;" onclick="window.location='<%= analytics_user_detail_path(row[:user].id) %>'">
                    <td style="padding: 0.75rem 1rem; border-bottom: 1px solid #F0EDE8;">
                      <div style="display: flex; align-items: center; gap: 0.6rem;">
                        <span style="width: 32px; height: 32px; border-radius: 50%; background: #2C2A25; color: #fff; font-size: 0.78rem; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                          <%= (row[:user].full_name.presence || row[:user].email).first.upcase %>
                        </span>
                        <%= link_to(row[:user].full_name.presence || "Utilisateur ##{row[:user].id}", analytics_user_detail_path(row[:user].id), style: "font-weight: 600; color: #2563EB; text-decoration: none; font-size: 0.88rem;") %>
                      </div>
                    </td>
                    <td style="padding: 0.75rem 1rem; border-bottom: 1px solid #F0EDE8; font-size: 0.83rem; color: #4A4640;"><%= row[:user].email %></td>
                    <td style="padding: 0.75rem 1rem; border-bottom: 1px solid #F0EDE8; font-size: 0.83rem; color: #9B9588; white-space: nowrap;"><%= row[:first_seen] ? l(row[:first_seen], format: :short) : "—" %></td>
                    <td style="padding: 0.75rem 1rem; border-bottom: 1px solid #F0EDE8; font-size: 0.83rem; color: #9B9588; white-space: nowrap;">
                      <% if row[:last_seen] %>
                        <% diff = Time.current - row[:last_seen] %>
                        <span title="<%= l(row[:last_seen], format: :long) %>">
                          <% if diff < 3600 %>il y a <%= (diff / 60).to_i %>min
                          <% elsif diff < 86400 %>il y a <%= (diff / 3600).to_i %>h
                          <% else %><%= l(row[:last_seen], format: :short) %>
                          <% end %>
                        </span>
                      <% else %>—<% end %>
                    </td>
                    <td style="padding: 0.75rem 1rem; border-bottom: 1px solid #F0EDE8; font-size: 0.83rem; color: #2C2A25;"><%= row[:session_count] %></td>
                    <td style="padding: 0.75rem 1rem; border-bottom: 1px solid #F0EDE8; font-size: 0.83rem; color: #2C2A25;"><%= number_with_delimiter(row[:event_count]) %></td>
                    <td style="padding: 0.75rem 1rem; border-bottom: 1px solid #F0EDE8; font-size: 0.83rem; color: #2C2A25;">
                      <% s = row[:total_time_s].to_i %>
                      <% if s >= 3600 %><%= "#{s/3600}h#{(s%3600)/60}m" %>
                      <% elsif s >= 60 %><%= "#{s/60}m#{s%60}s" %>
                      <% else %><%= "#{s}s" %>
                      <% end %>
                    </td>
                    <td style="padding: 0.75rem 1rem; border-bottom: 1px solid #F0EDE8; font-family: ui-monospace, monospace; font-size: 0.78rem; color: #4A4640;"><%= row[:last_page].presence || "—" %></td>
                  </tr>
                <% end %>
              <% else %>
                <tr>
                  <td colspan="8" style="padding: 3rem; text-align: center; color: #9B9588; font-size: 0.88rem;">
                    Aucun utilisateur connecté enregistré pour le moment.
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% end %><%# /users tab %>

    <% if @tab == "overview" %>
    <%# ── Utilisateurs actifs (live, rafraîchi toutes les 10s) ── %>
    <div class="od-card p-4 mb-4">
      <div class="d-flex align-items-center gap-2 mb-3">
        <span style="width: 9px; height: 9px; border-radius: 50%; background: #059669; display: inline-block; box-shadow: 0 0 0 3px rgba(5,150,105,0.2); animation: pulse 2s infinite;"></span>
        <div class="an-section-title mb-0">Actifs maintenant</div>
        <span style="font-size: 0.8rem; color: #9B9588;">· live, rafraîchi toutes les 10s</span>
      </div>
      <div data-controller="analytics-live"
           data-analytics-live-url-value="<%= analytics_active_users_path %>">
        <%= render "active_users" %>
      </div>
    </div>
    <style>
      @keyframes pulse {
        0%, 100% { box-shadow: 0 0 0 3px rgba(5,150,105,0.2); }
        50%       { box-shadow: 0 0 0 6px rgba(5,150,105,0.0); }
      }
    </style>

    <%# ── Sparkline + Top pages (2-col) ──────────────────────── %>
    <div class="row g-3 mb-4">

      <%# Activity sparkline %>
      <div class="col-lg-4">
        <div class="od-card p-4 h-100">
          <div class="an-section-title">Activité quotidienne</div>
          <% if @daily_events.any? %>
            <% max_val = @daily_events.values.max.to_f %>
            <div class="sparkline mb-2">
              <% @daily_events.each do |_date, count| %>
                <div class="spark-bar" style="height: <%= [ (count / max_val * 100).round, 4 ].max %>%;"></div>
              <% end %>
            </div>
            <div class="d-flex justify-content-between" style="font-size: 0.72rem; color: #9B9588;">
              <span><%= @daily_events.keys.first %></span>
              <span><%= @daily_events.keys.last %></span>
            </div>
          <% else %>
            <div class="text-center py-4" style="color: #9B9588; font-size: 0.85rem;">Aucune donnée</div>
          <% end %>
        </div>
      </div>

      <%# Top pages bar chart %>
      <div class="col-lg-8">
        <div class="od-card p-4 h-100">
          <div class="an-section-title">Top pages vues</div>
          <% if @top_pages.any? %>
            <% max_pv = @top_pages.values.max.to_f %>
            <% @top_pages.each do |path, count| %>
              <div class="bar-row">
                <div class="bar-label" title="<%= path %>"><%= path.presence || "(root)" %></div>
                <div class="bar-track">
                  <div class="bar-fill" style="width: <%= (count / max_pv * 100).round %>%;"></div>
                </div>
                <div class="bar-count"><%= number_with_delimiter(count) %></div>
              </div>
            <% end %>
          <% else %>
            <div class="text-center py-4" style="color: #9B9588; font-size: 0.85rem;">Aucune page vue enregistrée</div>
          <% end %>
        </div>
      </div>
    </div>

    <%# ── Utilisateurs récents ────────────────────────────────── %>
    <div class="od-card mb-4">
      <div class="p-4 pb-0">
        <div class="an-section-title">Utilisateurs connectés — <%= @days %>j</div>
      </div>
      <div style="overflow-x: auto;">
        <table class="an-table">
          <thead>
            <tr>
              <th>Utilisateur</th>
              <th>Email</th>
              <th>Événements</th>
              <th>Temps passé</th>
              <th>Dernière page</th>
              <th>Dernière activité</th>
            </tr>
          </thead>
          <tbody>
            <% if @recent_user_activity.any? %>
              <% @recent_user_activity.each do |row| %>
                <tr>
                  <td>
                    <%= link_to analytics_user_detail_path(row[:user].id), style: "display: flex; align-items: center; gap: 0.6rem; text-decoration: none;" do %>
                      <span style="width: 30px; height: 30px; border-radius: 50%; background: #2C2A25; color: #fff; font-size: 0.75rem; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                        <%= (row[:user].full_name.presence || row[:user].email).first.upcase %>
                      </span>
                      <span style="font-weight: 600; color: #2563EB;">
                        <%= row[:user].full_name.presence || "Utilisateur ##{row[:user].id}" %>
                      </span>
                    <% end %>
                  </td>
                  <td class="mono"><%= row[:user].email %></td>
                  <td><%= number_with_delimiter(row[:event_count]) %></td>
                  <td>
                    <% secs = row[:time_spent_s].to_i %>
                    <% if secs >= 3600 %>
                      <%= "#{secs / 3600}h #{(secs % 3600) / 60}m" %>
                    <% elsif secs >= 60 %>
                      <%= "#{secs / 60}m #{secs % 60}s" %>
                    <% else %>
                      <%= "#{secs}s" %>
                    <% end %>
                  </td>
                  <td class="mono"><%= row[:last_page].presence || "—" %></td>
                  <td style="white-space: nowrap;">
                    <% if row[:last_seen] %>
                      <span title="<%= l(row[:last_seen], format: :long) %>">
                        <% diff = Time.current - row[:last_seen] %>
                        <% if diff < 60 %>
                          Il y a <%= diff.to_i %>s
                        <% elsif diff < 3600 %>
                          Il y a <%= (diff / 60).to_i %>min
                        <% else %>
                          <%= l(row[:last_seen], format: :short) %>
                        <% end %>
                      </span>
                    <% else %>
                      —
                    <% end %>
                  </td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="6" class="text-center py-4" style="color: #9B9588;">
                  Aucun utilisateur connecté sur cette période.
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <%# ── Event types + Drop-off pages (2-col) ───────────────── %>
    <div class="row g-3 mb-4">

      <%# Event type breakdown %>
      <div class="col-lg-6">
        <div class="od-card p-4 h-100">
          <div class="an-section-title">Types d'événements</div>
          <% if @event_summary.any? %>
            <% max_ev = @event_summary.values.max.to_f %>
            <% @event_summary.each do |type, count| %>
              <div class="bar-row">
                <div class="bar-label"><%= type %></div>
                <div class="bar-track">
                  <div class="bar-fill green" style="width: <%= (count / max_ev * 100).round %>%;"></div>
                </div>
                <div class="bar-count"><%= number_with_delimiter(count) %></div>
              </div>
            <% end %>
          <% else %>
            <div class="text-center py-4" style="color: #9B9588; font-size: 0.85rem;">Aucun événement</div>
          <% end %>
        </div>
      </div>

      <%# Drop-off pages %>
      <div class="col-lg-6">
        <div class="od-card p-4 h-100">
          <div class="an-section-title">Pages d'abandon</div>
          <% if @drop_off_pages.any? %>
            <% max_do = @drop_off_pages.values.max.to_f %>
            <% @drop_off_pages.each do |path, count| %>
              <div class="bar-row">
                <div class="bar-label" title="<%= path %>"><%= path.presence || "(root)" %></div>
                <div class="bar-track">
                  <div class="bar-fill orange" style="width: <%= (count / max_do * 100).round %>%;"></div>
                </div>
                <div class="bar-count"><%= number_with_delimiter(count) %></div>
              </div>
            <% end %>
          <% else %>
            <div class="text-center py-4" style="color: #9B9588; font-size: 0.85rem;">Aucun abandon enregistré</div>
          <% end %>
        </div>
      </div>
    </div>

    <%# ── Avg load times ──────────────────────────────────────── %>
    <% if @avg_load_times.any? %>
      <div class="od-card p-4 mb-4">
        <div class="an-section-title">Temps de chargement moyen par page</div>
        <% max_lt = @avg_load_times.values.max.to_f %>
        <% @avg_load_times.each do |path, ms| %>
          <div class="bar-row">
            <div class="bar-label" title="<%= path %>"><%= path.presence || "(root)" %></div>
            <div class="bar-track">
              <% pct = [ (ms / max_lt * 100).round, 2 ].max %>
              <div class="bar-fill" style="width: <%= pct %>%; background: <%= ms > 3000 ? '#EF4444' : ms > 1500 ? '#F59E0B' : '#10B981' %>;"></div>
            </div>
            <div class="bar-count"><%= ms %>ms</div>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# ── Funnels ──────────────────────────────────────────────── %>
    <% @funnel_reports.each do |report| %>
      <div class="od-card p-4 mb-4">
        <div class="d-flex justify-content-between align-items-start mb-3">
          <div>
            <div class="an-section-title mb-0"><%= report[:funnel_name].humanize %></div>
            <div style="font-size: 0.8rem; color: #9B9588; margin-top: 2px;">
              <%= report[:total_started] %> démarrages &middot;
              <strong style="color: <%= report[:overall_conversion] >= 30 ? '#059669' : report[:overall_conversion] >= 10 ? '#D97706' : '#DC2626' %>;">
                <%= report[:overall_conversion] %>% conversion globale
              </strong>
            </div>
          </div>
          <span class="ev-pill" style="background: #EDE9E0; color: #4A4640; font-size: 0.78rem;">
            <%= @days %>j
          </span>
        </div>

        <% if report[:total_started] > 0 %>
          <div class="d-flex align-items-stretch gap-0" style="overflow-x: auto; padding-bottom: 0.5rem;">
            <% report[:steps].each_with_index do |step, idx| %>
              <%# Arrow connector between steps %>
              <% if idx > 0 %>
                <div style="display: flex; align-items: center; flex-shrink: 0; padding: 0 4px; color: #C8C4BC; font-size: 1.1rem;">›</div>
              <% end %>

              <% bar_color = step[:rate] >= 60 ? '#059669' : step[:rate] >= 30 ? '#D97706' : '#DC2626' %>
              <div style="min-width: 110px; flex: 1; text-align: center;">
                <%# Funnel bar — height proportional to rate %>
                <div style="height: 80px; display: flex; flex-direction: column; justify-content: flex-end; align-items: center; margin-bottom: 0.5rem;">
                  <div style="
                    width: 60%;
                    height: <%= [ step[:rate].round, 4 ].max %>%;
                    background: <%= bar_color %>;
                    border-radius: 4px 4px 0 0;
                    opacity: 0.85;
                    min-height: 4px;
                    transition: height 0.3s ease;
                  "></div>
                </div>
                <div style="font-size: 0.75rem; font-weight: 700; color: #2C2A25; line-height: 1.2;">
                  <%= step[:entered] %>
                </div>
                <div style="font-size: 0.7rem; color: #9B9588; margin-top: 2px; line-height: 1.2;">
                  <%= step[:label] %>
                </div>
                <div style="font-size: 0.72rem; font-weight: 600; color: <%= bar_color %>; margin-top: 3px;">
                  <%= step[:rate] %>%
                </div>
                <% if idx > 0 && step[:drop_rate] > 0 %>
                  <div style="font-size: 0.68rem; color: #DC2626; margin-top: 1px;">
                    −<%= step[:drop_rate] %>%
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-3" style="color: #9B9588; font-size: 0.85rem;">
            Aucune donnée de funnel pour cette période.
          </div>
        <% end %>
      </div>
    <% end %>

    <%# ── Errors ───────────────────────────────────────────────── %>
    <% if @recent_errors.any? %>
      <div class="od-card mb-4" style="border-color: #FCA5A5;">
        <div class="p-4 pb-0 d-flex align-items-center gap-2">
          <span style="width: 10px; height: 10px; border-radius: 50%; background: #EF4444; flex-shrink: 0;"></span>
          <div class="an-section-title mb-0" style="color: #991B1B;">Erreurs récentes</div>
          <span class="ms-auto" style="font-size: 0.8rem; color: #9B9588;"><%= @recent_errors.size %> erreur<%= @recent_errors.size > 1 ? 's' : '' %> sur <%= @days %>j</span>
        </div>
        <div style="overflow-x: auto;">
          <table class="an-table">
            <thead>
              <tr>
                <th>Type</th>
                <th>Exception</th>
                <th>Page / Action</th>
                <th>User</th>
                <th>Date</th>
              </tr>
            </thead>
            <tbody>
              <% @recent_errors.each do |ev| %>
                <tr>
                  <td>
                    <span class="ev-pill" style="background: #FEE2E2; color: #991B1B;">
                      <%= ev.event_type %>
                    </span>
                  </td>
                  <td style="max-width: 320px;">
                    <div style="font-size: 0.78rem; font-weight: 600; color: #7F1D1D; font-family: ui-monospace, monospace; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="<%= ev.properties['exception_class'] %>">
                      <%= ev.properties["exception_class"] %>
                    </div>
                    <div style="font-size: 0.75rem; color: #4A4640; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 320px;" title="<%= ev.properties['exception_message'] %>">
                      <%= ev.properties["exception_message"]&.truncate(120) %>
                    </div>
                  </td>
                  <td class="mono">
                    <div><%= ev.page_path.presence || "—" %></div>
                    <% if ev.properties["controller"].present? %>
                      <div style="font-size: 0.72rem; color: #9B9588;"><%= ev.properties["controller"] %></div>
                    <% end %>
                  </td>
                  <td class="mono"><%= ev.user_id.presence || "anon" %></td>
                  <td style="white-space: nowrap;"><%= l(ev.created_at, format: :short) %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% end %>

    <%# ── Recent events table ─────────────────────────────────── %>
    <div class="od-card mb-4">
      <div class="p-4 pb-0">
        <div class="an-section-title">Événements récents</div>
      </div>
      <div style="overflow-x: auto;">
        <table class="an-table">
          <thead>
            <tr>
              <th>Type</th>
              <th>Page</th>
              <th>Session</th>
              <th>User</th>
              <th>Durée (chargement)</th>
              <th>Date</th>
            </tr>
          </thead>
          <tbody>
            <% if @recent_events.any? %>
              <% @recent_events.each do |ev| %>
                <tr>
                  <td><span class="ev-pill <%= ev.event_type %>"><%= ev.event_type %></span></td>
                  <td class="mono"><%= ev.page_path.presence || "—" %></td>
                  <td class="mono"><%= ev.session_id&.first(8) %>…</td>
                  <td class="mono"><%= ev.user_id.presence || "anon" %></td>
                  <td><%= ev.page_load_time_ms ? "#{ev.page_load_time_ms}ms" : "—" %></td>
                  <td style="white-space: nowrap;"><%= l(ev.created_at, format: :short) %></td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="6" class="text-center py-4" style="color: #9B9588;">
                  Aucun événement enregistré pour le moment.
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

  <% end %><%# /overview tab %>

  </div><%# /container %>
</div><%# /an-page %>
