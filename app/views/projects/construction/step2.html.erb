<% content_for :head do %>
<meta name="turbo-cache-control" content="no-cache">
<style>
  .renovation-card {
    display: flex;
    align-items: center;
    gap: 1.15rem;
    border: 1.5px solid #2C2A25;
    border-radius: 12px;
    background: #EDEAE4;
    padding: 1.25rem 1.5rem;
    margin-bottom: 0.75rem;
    min-height: 80px;
  }
  .renovation-card .reno-icon { font-size: 1.7rem; width: 2.2rem; text-align: center; flex-shrink: 0; }

  .room-picker {
    border: 1px solid #C8C4BC;
    border-radius: 10px;
    padding: 1.25rem;
    background: #FFFFFF;
    margin-top: 0.75rem;
  }

  .room-group {
    border: 1px solid #C8C4BC;
    border-radius: 8px;
    background: #fff;
    margin-bottom: 0.5rem;
    overflow: hidden;
  }
  .room-group-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.65rem 1rem;
  }
  .room-checkbox-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    font-size: 0.95rem;
    color: #2C2A25;
    font-weight: 500;
    flex: 1;
  }
  .room-count-control {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .room-count-control .btn-count {
    width: 26px; height: 26px;
    border: 1px solid #C8C4BC;
    border-radius: 6px;
    background: #fff;
    color: #2C2A25;
    font-size: 1rem;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
    padding: 0;
  }
  .room-count-control .btn-count:hover { background: #F0EDE8; border-color: #2C2A25; }
  .room-count-control .count-display {
    font-size: 0.9rem;
    font-weight: 600;
    color: #2C2A25;
    min-width: 20px;
    text-align: center;
  }

  .room-instances {
    border-top: 1px solid #C8C4BC;
  }
  .room-instance {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 1rem 0.5rem 2.75rem;
    border-top: 1px solid #F0EDE8;
  }
  .room-instance:first-child { border-top: none; }
  .room-instance-name {
    font-size: 0.88rem;
    color: #2C2A25;
    font-weight: 500;
    min-width: 100px;
  }
  .room-instance-surface {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-left: auto;
  }
  .room-instance-surface input {
    width: 80px;
    border: 1px solid #C8C4BC;
    border-radius: 6px;
    padding: 0.25rem 0.5rem;
    font-size: 0.85rem;
    color: #2C2A25;
    background: #fff;
  }
  .room-instance-surface input:focus {
    border-color: #2C2A25;
    outline: none;
    box-shadow: 0 0 0 2px rgba(44,42,37,0.1);
  }
  .room-instance-surface span {
    font-size: 0.8rem;
    color: #4A4640;
  }

  .field-error {
    font-size: 0.8rem;
    color: #C25E4A;
    margin-top: 0.25rem;
  }

  .generate-btn {
    background: #2663EB;
    color: #fff;
    border: 1.5px solid #2663EB;
    border-radius: 50px;
    font-size: 1.05rem;
    font-weight: 600;
    padding: 0.85rem 2.2rem;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: background 0.2s, border-color 0.2s, transform 0.2s, box-shadow 0.2s;
  }
  .generate-btn:hover:not(:disabled) { background: #1B4FC2; border-color: #1B4FC2; transform: translateY(-2px); box-shadow: 0 4px 14px rgba(37,99,235,0.30); }
  .generate-btn:disabled { opacity: 0.5; cursor: not-allowed; }

  /* ── Generation loader overlay ───────────────────────────────────────────── */
  #construction-loader {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: #fff;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2rem;
  }
  .loader-house { width: 120px; height: 120px; }
  .house-outline {
    fill: none; stroke: #2563eb; stroke-width: 3;
    stroke-linecap: round; stroke-linejoin: round;
    stroke-dasharray: 320; stroke-dashoffset: 320;
    animation: draw-house 1.4s ease forwards;
  }
  .house-door { fill: none; stroke: #2563eb; stroke-width: 2.5; stroke-linecap: round; opacity: 0; animation: fade-in 0.4s ease 1.2s forwards; }
  .house-window { fill: none; stroke: #2563eb; stroke-width: 2; stroke-linecap: round; opacity: 0; animation: fade-in 0.4s ease 1.4s forwards; }
  .house-window-2 { animation-delay: 1.55s; }
  .house-chimney { fill: none; stroke: #2563eb; stroke-width: 2.5; stroke-linecap: round; opacity: 0; animation: fade-in 0.4s ease 1.0s forwards; }
  .smoke-puff { fill: #93c5fd; opacity: 0; animation: puff 1.8s ease-in-out 1.8s infinite; }
  .smoke-puff-2 { animation-delay: 2.4s; }
  .smoke-puff-3 { animation-delay: 3.0s; }
  .ground-line { stroke: #DBEAFE; stroke-width: 2; stroke-linecap: round; stroke-dasharray: 4 4; }
  @keyframes draw-house { to { stroke-dashoffset: 0; } }
  @keyframes fade-in    { to { opacity: 1; } }
  @keyframes puff {
    0%   { opacity: 0; transform: translateY(0) scale(0.6); }
    40%  { opacity: 0.7; transform: translateY(-6px) scale(1); }
    100% { opacity: 0; transform: translateY(-14px) scale(1.3); }
  }
  .loader-dots { display: flex; gap: 6px; }
  .loader-dots span { width: 8px; height: 8px; border-radius: 50%; background: #2563eb; animation: bounce-dot 1.2s ease-in-out infinite; }
  .loader-dots span:nth-child(2) { animation-delay: 0.2s; }
  .loader-dots span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes bounce-dot { 0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; } 40% { transform: scale(1.0); opacity: 1; } }
  .loader-text { font-size: 1rem; font-weight: 600; color: #2C2A25; letter-spacing: -0.2px; }
  .loader-subtext { font-size: 0.85rem; color: #9B9588; margin-top: 0.25rem; text-align: center; }
</style>
<% end %>

<%
  selected_rooms_data = (@selected_rooms.is_a?(Array) && @selected_rooms.first.is_a?(Hash)) ? @selected_rooms : []
  selected_bases  = selected_rooms_data.map { |r| r["base"] || r["name"] }.uniq
  selected_counts = selected_rooms_data.group_by { |r| r["base"] || r["name"] }
%>

<div class="container py-4" style="max-width: 620px;">
  <%= render "projects/wizard/stepper", current_step: 2, project_type: @project_type %>

  <%= form_with url: construction_step2_path, method: :post,
      data: { controller: "construction-rooms", action: "change->construction-rooms#validate",
              "construction-rooms-total-surface-value": @project.total_surface_sqm.to_f } do |f| %>

    <input type="hidden" name="renovation_type" value="par_piece">

    <%# Static header card — always "active", not interactive %>
    <div class="renovation-card">
      <div class="reno-icon">🏠</div>
      <div>
        <div style="font-weight: 600; font-size: 0.95rem;">Décrivez votre future construction neuve</div>
      </div>
    </div>

    <%# Room picker — always open, no label %>
    <div class="room-picker">
      <% if @errors&.include?(:rooms) %>
        <div class="field-error">Veuillez sélectionner au moins une pièce</div>
      <% end %>
      <% if @errors&.include?(:surface_total) %>
        <div class="field-error">La somme des surfaces des pièces dépasse la surface totale du bien (<%= @project.total_surface_sqm %> m²)</div>
      <% end %>

      <% Projects::WizardController::PRESET_ROOMS.each do |room| %>
        <%
          is_checked      = selected_bases.include?(room)
          room_instances  = selected_counts[room] || []
          count           = [ room_instances.size, 1 ].max
        %>
        <div class="room-group" data-construction-rooms-target="roomGroup" data-room="<%= room %>">
          <div class="room-group-header">
            <label class="room-checkbox-label">
              <input type="checkbox"
                     data-construction-rooms-target="roomCheckbox"
                     data-room="<%= room %>"
                     <%= "checked" if is_checked %>
                     data-action="change->construction-rooms#toggleRoom">
              <%= room %>
            </label>

            <div class="room-count-control" <%= "hidden" unless is_checked %>
                 data-construction-rooms-target="countControl" data-room="<%= room %>">
              <button type="button" class="btn-count"
                      data-action="click->construction-rooms#decrement"
                      data-room="<%= room %>">−</button>
              <span class="count-display"
                    data-construction-rooms-target="countDisplay" data-room="<%= room %>"><%= count %></span>
              <button type="button" class="btn-count"
                      data-action="click->construction-rooms#increment"
                      data-room="<%= room %>">+</button>
            </div>
          </div>

          <div class="room-instances" <%= "hidden" unless is_checked %>
               data-construction-rooms-target="roomInstances" data-room="<%= room %>">
            <% if is_checked %>
              <% room_instances.each_with_index do |inst, i| %>
                <div class="room-instance" data-room-index>
                  <div class="room-instance-name"><%= count > 1 ? "#{room} #{i + 1}" : room %></div>
                  <input type="hidden" class="room-field-name" name="rooms[][name]" value="<%= count > 1 ? "#{room} #{i + 1}" : room %>">
                  <input type="hidden" class="room-field-base" name="rooms[][base]" value="<%= room %>">
                  <input type="hidden" class="room-field-surface" name="rooms[][surface]" value="<%= inst["surface"] %>">
                  <div class="room-instance-surface">
                    <input type="number" placeholder="—" min="0" step="any"
                           data-action="input->construction-rooms#syncSurface"
                           value="<%= inst["surface"] %>">
                    <span>m²</span>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>

      <div class="field-error" hidden data-construction-rooms-target="surfaceError"></div>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-4 flex-wrap gap-3">
      <%= link_to wizard_step1_path, class: "btn btn-ghost-od" do %>
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M10 12L6 8l4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Retour
      <% end %>

      <div class="d-flex gap-2 align-items-center flex-wrap">
        <button type="submit" name="commit" value="suivant"
                class="btn btn-dark-od"
                data-construction-rooms-target="submit"
                disabled>
          Suivant
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>

        <button type="button" id="generate-btn" class="generate-btn"
                data-construction-rooms-target="submit"
                disabled>
          Générer l'estimation ✨
        </button>
      </div>
    </div>
  <% end %>
</div>

<%# ── Fullscreen generation loader ─────────────────────────────────────── %>
<div id="construction-loader">
  <svg class="loader-house" viewBox="0 0 100 95" xmlns="http://www.w3.org/2000/svg">
    <line class="ground-line" x1="10" y1="85" x2="90" y2="85" />
    <polyline class="house-chimney" points="68,42 68,28 78,28 78,42" />
    <path class="house-outline" d="M15,85 L15,50 L50,18 L85,50 L85,85 Z" />
    <path class="house-door" d="M42,85 L42,65 Q42,62 45,62 L55,62 Q58,62 58,65 L58,85" />
    <rect class="house-window" x="22" y="55" width="16" height="14" rx="2" />
    <line class="house-window" x1="30" y1="55" x2="30" y2="69" />
    <line class="house-window" x1="22" y1="62" x2="38" y2="62" />
    <rect class="house-window house-window-2" x="62" y="55" width="16" height="14" rx="2" />
    <line class="house-window house-window-2" x1="70" y1="55" x2="70" y2="69" />
    <line class="house-window house-window-2" x1="62" y1="62" x2="78" y2="62" />
    <circle class="smoke-puff" cx="73" cy="23" r="3.5" />
    <circle class="smoke-puff smoke-puff-2" cx="76" cy="17" r="2.5" />
    <circle class="smoke-puff smoke-puff-3" cx="71" cy="12" r="2" />
  </svg>

  <div style="text-align: center;">
    <div class="loader-text">Génération de l'estimation…</div>
    <div class="loader-subtext">Calcul des postes et des tarifs en cours</div>
  </div>

  <div class="loader-dots">
    <span></span><span></span><span></span>
  </div>
</div>

<script>
  (function() {
    var generateBtn = document.getElementById("generate-btn")
    var form = generateBtn.closest("form")

    generateBtn.addEventListener("click", function() {
      if (generateBtn.disabled) return
      document.getElementById("construction-loader").style.display = "flex"
      setTimeout(function() {
        var input = document.createElement("input")
        input.type  = "hidden"
        input.name  = "commit"
        input.value = "generate"
        form.appendChild(input)
        form.submit()
      }, 3000)
    })
  })()
</script>
