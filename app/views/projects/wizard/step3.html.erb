<% content_for :title, "Catégories de travaux — Estimation OpenDevis" %>

<% content_for :head do %>
<meta name="turbo-cache-control" content="no-cache">
<style>
  .s3 { font-family: 'Plus Jakarta Sans', sans-serif; }

  .s3 .category-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    border: 1.5px solid #DDD9D1;
    border-radius: 12px;
    background: #fff;
    padding: 1.2rem 0.8rem;
    cursor: pointer;
    text-align: center;
    font-size: 0.88rem;
    color: #2C2A25;
    transition: border-color 0.15s, background 0.15s;
    height: 100%;
    min-height: 110px;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .s3 .category-card:has(input:checked) {
    border-color: #2563eb;
    background: #EFF4FF;
    font-weight: 700;
    color: #1C1A16;
  }
  .s3 .category-card:not(:has(input:checked)):hover {
    border-color: #2563eb;
    background: #FAFCFF;
  }
  .s3 .category-card input[type="checkbox"] { display: none; }
  .s3 .category-card .cat-icon { font-size: 1.6rem; line-height: 1; }
  .s3 .category-card .dpe-badge {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    background: #E8F5E9;
    color: #2E7D32;
    border-radius: 10px;
    padding: 0.1em 0.5em;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    line-height: 1.4;
  }
  .s3 .category-card .dpe-badge svg { flex-shrink: 0; }

  .s3 .group-title {
    font-size: 0.68rem;
    font-weight: 700;
    color: #9B9588;
    text-transform: uppercase;
    letter-spacing: 0.13em;
    margin-bottom: 0.6rem;
    margin-top: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .s3 .group-title::after {
    content: '';
    display: block;
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, #DDD9D1, transparent);
  }
  .s3 .group-title:first-of-type { margin-top: 0; }

  .s3 .room-tab {
    display: inline-block;
    padding: 0.45rem 1rem;
    border: 1.5px solid #DDD9D1;
    border-radius: 20px;
    background: #fff;
    color: #4A4640;
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .s3 .room-tab:hover { border-color: #2563eb; color: #2563eb; }
  .s3 .room-tab.active {
    border-color: #2563eb;
    background: #2563eb;
    color: #fff;
    font-weight: 600;
  }
  .s3 .room-tab .badge-count {
    display: inline-block;
    background: rgba(255,255,255,0.3);
    border-radius: 10px;
    padding: 0 0.4em;
    font-size: 0.75rem;
    margin-left: 0.3em;
  }

  .s3 .room-categories-panel { display: none; }
  .s3 .room-categories-panel.active { display: block; }

  .s3 .select-all-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: #4A4640;
    cursor: pointer;
    margin-bottom: 0.75rem;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .s3 .select-all-toggle input[type="checkbox"] {
    width: 16px;
    height: 16px;
    accent-color: #2563eb;
    cursor: pointer;
  }

  .s3 .custom-needs-section {
    border: 1.5px solid #E8E4DC;
    border-radius: 12px;
    padding: 1.25rem;
    background: #fff;
    margin-top: 1.5rem;
  }
</style>
<% end %>

<%
  # Determine if we show per-room tabs or a single category grid
  is_par_piece = @renovation_type == "par_piece"
  rooms_data = is_par_piece ? @selected_rooms : []

  # For non-par_piece: selected categories is a flat array
  # For par_piece: we use room_categories from session or compute defaults
  room_categories = session[:wizard_room_categories] || {}

  # Categories that improve DPE (energy performance)
  dpe_slugs = %w[isolation fenetres ventilation_chauffage]
%>

<div class="container py-4 s3" style="max-width: 720px;">
  <%= render "stepper", current_step: 3, project_type: @project_type %>

  <h2 class="mb-1" style="font-family: 'DM Serif Display', serif; font-size: 1.9rem; color: #1C1A16;">Travaux souhaités</h2>
  <p class="mb-4" style="color: #4A4640;">Sélectionnez les catégories de travaux à inclure dans l'estimation.</p>

  <% if @renovation_type.in?(%w[construction extension]) %>
    <%# Free-text fallback for construction %>
    <%= form_with url: wizard_step3_path, method: :post, data: { turbo: false } do |f| %>
      <div class="custom-needs-section">
        <p style="color: #4A4640; font-size: 0.9rem;">
          Décrivez vos besoins spécifiques. Nos conseillers affineront l'estimation.
        </p>
        <textarea name="custom_needs" class="form-control" rows="4"
                  placeholder="Ex: Extension de 20m² avec création d'une cuisine ouverte..."
                  style="border-color: #DDD9D1; border-radius: 10px;"><%= session[:wizard_custom_needs] %></textarea>

        <%# Include all categories by default %>
        <% @category_groups.each do |group| %>
          <% group[:slugs].each do |slug| %>
            <input type="hidden" name="categories[]" value="<%= slug %>">
          <% end %>
        <% end %>
      </div>
      <div class="d-flex justify-content-between mt-4">
        <%= link_to wizard_step1_path, class: "btn btn-ghost-od" do %>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M10 12L6 8l4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Retour
        <% end %>
        <button type="submit" class="btn btn-dark-od">
          Suivant
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>
    <% end %>

  <% elsif is_par_piece %>
    <%# Per-room category selection with tabs %>
    <%= form_with url: wizard_step3_path, method: :post, data: { controller: "room-tabs", turbo: false } do |f| %>
      <div class="d-flex gap-2 flex-wrap mb-3">
        <% rooms_data.each_with_index do |room, idx| %>
          <% room_name = room["name"] %>
          <button type="button" class="room-tab <%= 'active' if idx == 0 %>"
                  data-action="click->room-tabs#switch"
                  data-room-tabs-target="tab"
                  data-room="<%= room_name %>">
            <%= room_name %>
          </button>
        <% end %>
      </div>

      <%# Category panels per room — filtered by ROOM_ALLOWED_CATEGORIES using base name %>
      <% rooms_data.each_with_index do |room, idx| %>
        <% room_name = room["name"] %>
        <% room_base = room["base"] || room_name %>
        <% saved_cats = room_categories[room_name] || room_categories[room_base] || [] %>
        <% allowed = @room_allowed_categories[room_base] || @category_groups.flat_map { |g| g[:slugs] } %>
        <div class="room-categories-panel <%= 'active' if idx == 0 %>"
             data-room-tabs-target="panel" data-room="<%= room_name %>"
             data-controller="select-all">
          <label class="select-all-toggle">
            <input type="checkbox" data-select-all-target="toggle" data-action="change->select-all#toggleAll">
            Tout sélectionner
          </label>
          <% @category_groups.each do |group| %>
            <% filtered_slugs = group[:slugs].select { |s| allowed.include?(s) } %>
            <% next if filtered_slugs.empty? %>
            <div class="group-title"><%= group[:name] %></div>
            <div class="row g-2">
              <% filtered_slugs.each do |slug| %>
                <% cat = @category_labels[slug] %>
                <div class="col-4 col-md-3">
                  <label class="category-card w-100">
                    <input type="checkbox" name="room_categories[<%= room_name %>][]" value="<%= slug %>"
                           data-select-all-target="item" data-action="change->select-all#updateToggle"
                           <%= "checked" if saved_cats.include?(slug) %>>
                    <div class="cat-icon"><%= cat[:icon] %></div>
                    <div><%= cat[:label] %></div>
                    <% if dpe_slugs.include?(slug) %>
                      <span class="dpe-badge"><svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 16 16" fill="#2E7D32"><path d="M5.52.359A.5.5 0 0 1 6 0h4a.5.5 0 0 1 .474.658L8.694 6H12.5a.5.5 0 0 1 .395.807l-7 9a.5.5 0 0 1-.873-.454L6.823 9.5H3.5a.5.5 0 0 1-.48-.641l2.5-8.5z"/></svg> DPE</span>
                    <% end %>
                  </label>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>

      <%# Also store flat list of all unique categories for generation %>
      <%# This hidden field will be populated by JS or we compute server-side %>

      <%# Custom needs %>
      <div class="custom-needs-section">
        <div class="field-label" style="font-size: 0.85rem; font-weight: 600; color: #2C2A25; margin-bottom: 0.3rem; font-family: 'Plus Jakarta Sans', sans-serif;">Autres / Besoins spécifiques</div>
        <textarea name="custom_needs" class="form-control" rows="3"
                  placeholder="J'aimerais également..."
                  style="border-color: #DDD9D1; border-radius: 10px;"><%= session[:wizard_custom_needs] %></textarea>
      </div>

      <div class="d-flex justify-content-between mt-4">
        <%= link_to wizard_step2_path, class: "btn btn-ghost-od" do %>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M10 12L6 8l4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Retour
        <% end %>
        <button type="submit" class="btn btn-dark-od">
          Suivant
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>
    <% end %>

  <% else %>
    <%# Standard category grid (renovation_complete / energetique) %>
    <%= form_with url: wizard_step3_path, method: :post, data: { controller: "select-all", turbo: false } do |f| %>
      <label class="select-all-toggle">
        <input type="checkbox" data-select-all-target="toggle" data-action="change->select-all#toggleAll">
        Tout sélectionner
      </label>
      <% @category_groups.each do |group| %>
        <% next if group[:slugs].empty? %>
        <div class="group-title"><%= group[:name] %></div>
        <div class="row g-2">
          <% group[:slugs].each do |slug| %>
            <% cat = @category_labels[slug] %>
            <div class="col-4 col-md-3">
              <label class="category-card w-100">
                <input type="checkbox" name="categories[]" value="<%= slug %>"
                       data-select-all-target="item" data-action="change->select-all#updateToggle"
                       <%= "checked" if @selected_categories.include?(slug) %>>
                <div class="cat-icon"><%= cat[:icon] %></div>
                <div><%= cat[:label] %></div>
                <% if dpe_slugs.include?(slug) %>
                  <span class="dpe-badge"><svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 16 16" fill="#2E7D32"><path d="M5.52.359A.5.5 0 0 1 6 0h4a.5.5 0 0 1 .474.658L8.694 6H12.5a.5.5 0 0 1 .395.807l-7 9a.5.5 0 0 1-.873-.454L6.823 9.5H3.5a.5.5 0 0 1-.48-.641l2.5-8.5z"/></svg> DPE</span>
                <% end %>
              </label>
            </div>
          <% end %>
        </div>
      <% end %>

      <%# Custom needs %>
      <div class="custom-needs-section">
        <div class="field-label" style="font-size: 0.85rem; font-weight: 600; color: #2C2A25; margin-bottom: 0.3rem; font-family: 'Plus Jakarta Sans', sans-serif;">Autres / Besoins spécifiques</div>
        <textarea name="custom_needs" class="form-control" rows="3"
                  placeholder="J'aimerais également..."
                  style="border-color: #DDD9D1; border-radius: 10px;"><%= session[:wizard_custom_needs] %></textarea>
      </div>

      <div class="d-flex justify-content-between mt-4">
        <%= link_to wizard_step2_path, class: "btn btn-ghost-od" do %>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M10 12L6 8l4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Retour
        <% end %>
        <button type="submit" class="btn btn-dark-od">
          Suivant
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>
    <% end %>
  <% end %>
</div>
