<% content_for :title, "Type de rénovation — Estimation OpenDevis" %>

<% content_for :head do %>
<meta name="turbo-cache-control" content="no-cache">
<style>
  .s2 { font-family: 'Plus Jakarta Sans', sans-serif; }

  .s2 .renovation-card {
    position: relative;
    display: flex;
    align-items: center;
    gap: 1.15rem;
    border: 1.5px solid #E8E4DC;
    border-radius: 12px;
    background: #fff;
    padding: 1.25rem 1.5rem;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
    margin-bottom: 0.75rem;
    min-height: 80px;
    overflow: hidden;
  }
  .s2 .renovation-card::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: #2563eb;
    border-radius: 12px 12px 0 0;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.22s ease;
  }
  .s2 .renovation-card:hover { border-color: #DDD9D1; }
  .s2 .renovation-card:has(input:checked) {
    border-color: #2563eb;
    background: #EFF4FF;
  }
  .s2 .renovation-card:has(input:checked)::after {
    transform: scaleX(1);
  }
  .s2 .renovation-card input[type="radio"] { display: none; }

  .s2 .reno-icon-box {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: #F5F2EC;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.2s;
  }
  .s2 .renovation-card:has(input:checked) .reno-icon-box { background: #DBEAFE; }

  .s2 .reno-title { font-weight: 600; font-size: 0.95rem; color: #1C1A16; font-family: 'Plus Jakarta Sans', sans-serif; }
  .s2 .reno-desc { font-size: 0.85rem; color: #4A4640; font-family: 'Plus Jakarta Sans', sans-serif; }

  .s2 .room-picker {
    border: 1.5px solid #E8E4DC;
    border-radius: 12px;
    padding: 1.25rem;
    background: #FFFFFF;
    margin-top: 0.75rem;
  }

  .s2 .room-group {
    border: 1.5px solid #E8E4DC;
    border-radius: 10px;
    background: #fff;
    margin-bottom: 0.5rem;
    overflow: hidden;
  }
  .s2 .room-group-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.65rem 1rem;
  }
  .s2 .room-checkbox-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    font-size: 0.95rem;
    color: #2C2A25;
    font-weight: 500;
    flex: 1;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .s2 .room-count-control {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .s2 .room-count-control .btn-count {
    width: 28px; height: 28px;
    border: 1.5px solid #DDD9D1;
    border-radius: 7px;
    background: #fff;
    color: #2C2A25;
    font-size: 1rem;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
    padding: 0;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .s2 .room-count-control .btn-count:hover { background: #EFF4FF; border-color: #2563eb; color: #2563eb; }
  .s2 .room-count-control .count-display {
    font-size: 0.9rem;
    font-weight: 700;
    color: #2C2A25;
    min-width: 20px;
    text-align: center;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }

  .s2 .room-instances {
    border-top: 1px solid #F0EDE8;
  }
  .s2 .room-instance {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 1rem 0.5rem 2.75rem;
    border-top: 1px solid #F0EDE8;
  }
  .s2 .room-instance:first-child { border-top: none; }
  .s2 .room-instance-name {
    font-size: 0.88rem;
    color: #2C2A25;
    font-weight: 500;
    min-width: 100px;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .s2 .room-instance-surface {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-left: auto;
  }
  .s2 .room-instance-surface input {
    width: 80px;
    border: 1.5px solid #DDD9D1;
    border-radius: 8px;
    padding: 0.25rem 0.5rem;
    font-size: 0.85rem;
    color: #2C2A25;
    background: #fff;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .s2 .room-instance-surface input:focus {
    border-color: #2563eb;
    outline: none;
    box-shadow: 0 0 0 3px rgba(37,99,235,0.1);
  }
  .s2 .room-instance-surface span {
    font-size: 0.8rem;
    color: #4A4640;
  }

  .s2 .field-error {
    font-size: 0.8rem;
    color: #C25E4A;
    margin-top: 0.25rem;
  }
</style>
<% end %>

<%
  # Parse stored room data: session[:wizard_rooms] is now an array of hashes
  # [{ "name" => "Chambre 1", "base" => "Chambre", "surface" => "12" }, ...]
  selected_rooms_data = (@selected_rooms.is_a?(Array) && @selected_rooms.first.is_a?(Hash)) ? @selected_rooms : []

  # Group by base name to rebuild counts
  selected_bases = selected_rooms_data.map { |r| r["base"] || r["name"] }.uniq
  selected_counts = selected_rooms_data.group_by { |r| r["base"] || r["name"] }
%>

<div class="container py-4 s2" style="max-width: 620px;">
  <%= render "stepper", current_step: 2, project_type: @project_type %>

  <h2 class="mb-1" style="font-family: 'DM Serif Display', serif; font-size: 1.9rem; color: #1C1A16;">Type de rénovation</h2>
  <p class="mb-4" style="color: #4A4640; font-family: 'Plus Jakarta Sans', sans-serif;">Sélectionnez le type de travaux envisagés.</p>

  <%= form_with url: wizard_step2_path, method: :post,
      data: { controller: "renovation-type", action: "change->renovation-type#validate",
              "renovation-type-total-surface-value": @project.total_surface_sqm.to_f } do |f| %>
    <%
      renovation_types = []
      renovation_types << ["renovation_complete", "complete", "Rénovation complète", "Estimation rapide"] unless @project_type == "construction"
      renovation_types << ["par_piece", "piece", "Rénovation par pièce", "Estimation plus détaillée ou pour des pièces spécifiques"]
    %>
    <% renovation_types.each do |value, icon_type, label, desc| %>
      <label class="renovation-card">
        <input type="radio" name="renovation_type" value="<%= value %>"
               <%= "checked" if @renovation_type == value %>
               data-action="change->renovation-type#toggleRoomPicker">
        <div class="reno-icon-box">
          <% if icon_type == "complete" %>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
            </svg>
          <% else %>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
              <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
          <% end %>
        </div>
        <div>
          <div class="reno-title"><%= label %></div>
          <div class="reno-desc"><%= desc %></div>
        </div>
      </label>
    <% end %>

    <%# Room picker — visible for "par_piece" %>
    <div data-renovation-type-target="roomPicker"
         class="room-picker" <%= @renovation_type == "par_piece" ? "" : "hidden" %>>
      <div class="small fw-semibold mb-2" style="color: #4A4640; font-family: 'Plus Jakarta Sans', sans-serif;">
        Quelles pièces rénover ? <span style="color: #C25E4A;">*</span>
      </div>

      <% Projects::WizardController::PRESET_ROOMS.each do |room| %>
        <%
          is_checked = selected_bases.include?(room)
          room_instances = selected_counts[room] || []
          count = [room_instances.size, 1].max
        %>
        <div class="room-group" data-renovation-type-target="roomGroup" data-room="<%= room %>">
          <div class="room-group-header">
            <label class="room-checkbox-label">
              <input type="checkbox"
                     data-renovation-type-target="roomCheckbox"
                     data-room="<%= room %>"
                     <%= "checked" if is_checked %>
                     data-action="change->renovation-type#toggleRoom">
              <%= room %>
            </label>

            <div class="room-count-control" <%= "hidden" unless is_checked %>
                 data-renovation-type-target="countControl" data-room="<%= room %>">
              <button type="button" class="btn-count"
                      data-action="click->renovation-type#decrement"
                      data-room="<%= room %>">−</button>
              <span class="count-display"
                    data-renovation-type-target="countDisplay" data-room="<%= room %>"><%= count %></span>
              <button type="button" class="btn-count"
                      data-action="click->renovation-type#increment"
                      data-room="<%= room %>">+</button>
            </div>
          </div>

          <div class="room-instances" <%= "hidden" unless is_checked %>
               data-renovation-type-target="roomInstances" data-room="<%= room %>">
            <% if is_checked %>
              <% room_instances.each_with_index do |inst, i| %>
                <div class="room-instance" data-room-index>
                  <div class="room-instance-name"><%= count > 1 ? "#{room} #{i + 1}" : room %></div>
                  <input type="hidden" class="room-field-name" name="rooms[][name]" value="<%= count > 1 ? "#{room} #{i + 1}" : room %>">
                  <input type="hidden" class="room-field-base" name="rooms[][base]" value="<%= room %>">
                  <input type="hidden" class="room-field-surface" name="rooms[][surface]" value="<%= inst["surface"] %>">
                  <div class="room-instance-surface">
                    <input type="number" placeholder="—" min="0" step="0.01"
                           data-action="input->renovation-type#syncSurface"
                           value="<%= inst["surface"] %>">
                    <span>m²</span>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>

      <% if @errors&.include?(:rooms) %>
        <div class="field-error">Veuillez sélectionner au moins une pièce</div>
      <% end %>
      <% if @errors&.include?(:surface_total) %>
        <div class="field-error">La somme des surfaces des pièces dépasse la surface totale du bien (<%= @project.total_surface_sqm %> m²)</div>
      <% end %>
      <div class="field-error" hidden data-renovation-type-target="surfaceError"></div>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-4">
      <%= link_to wizard_step1_path, class: "btn btn-ghost-od" do %>
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M10 12L6 8l4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Retour
      <% end %>
      <button type="submit" class="btn btn-dark-od"
              data-renovation-type-target="submit"
              <%= "disabled" unless @renovation_type.present? %>>
        Suivant
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
  <% end %>
</div>
