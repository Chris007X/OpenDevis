<% content_for :title, "Nouvelle estimation — OpenDevis" %>
<% content_for :description, "Commencez votre estimation de travaux en quelques clics." %>

<% content_for :head do %>
<style>
  .choose-scope { font-family: 'Plus Jakarta Sans', sans-serif; }

  .choose-eyebrow {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: #9B9588;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }
  .choose-eyebrow::after {
    content: '';
    display: block;
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, #DDD9D1, transparent);
  }

  .choose-card {
    position: relative;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    width: 100%;
    border: 1.5px solid #E8E4DC;
    border-radius: 14px;
    background: #fff;
    padding: 1.5rem 1.75rem;
    cursor: pointer;
    transition: border-color 0.2s, transform 0.18s, box-shadow 0.18s;
    text-align: left;
    overflow: hidden;
  }
  .choose-card::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: #2563eb;
    border-radius: 14px 14px 0 0;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.22s ease;
  }
  .choose-card:hover {
    border-color: #DDD9D1;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(44,42,37,0.10);
  }
  .choose-card:hover::after {
    transform: scaleX(1);
  }

  .choose-icon-box {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: #F5F2EC;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.2s;
  }
  .choose-card:hover .choose-icon-box {
    background: #EFF4FF;
  }

  .choose-title {
    font-size: 1rem;
    font-weight: 700;
    color: #1C1A16;
    margin-bottom: 0.2rem;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .choose-desc {
    font-size: 0.86rem;
    color: #4A4640;
    line-height: 1.45;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }

  .choose-back-link {
    color: #9B9588;
    font-size: 0.85rem;
    text-decoration: none;
    font-family: 'Plus Jakarta Sans', sans-serif;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    transition: color 0.15s;
  }
  .choose-back-link:hover { color: #2C2A25; }
</style>
<% end %>

<div class="container py-5 choose-scope" style="max-width: 560px;">
  <div class="text-center mb-5">
    <h2 style="font-family: 'DM Serif Display', serif; font-size: 2rem; color: #1C1A16; margin-bottom: 0.5rem;">
      Nouveau <em>projet</em>
    </h2>
    <p style="color: #4A4640; font-size: 0.95rem;">Quel type de projet souhaitez-vous estimer ?</p>
  </div>

  <div class="choose-eyebrow">Type de projet</div>

  <div class="d-flex flex-column gap-3">
    <%# Rénovation %>
    <%= form_with url: wizard_save_choose_path, method: :post, html: { class: "w-100" } do %>
      <input type="hidden" name="project_type" value="renovation">
      <button type="submit" class="choose-card">
        <div class="choose-icon-box">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
          </svg>
        </div>
        <div>
          <div class="choose-title">Rénovation</div>
          <div class="choose-desc">Rénovation partielle, complète ou énergétique</div>
        </div>
      </button>
    <% end %>

    <%# Construction neuve %>
    <%= form_with url: wizard_save_choose_path, method: :post, html: { class: "w-100" } do %>
      <input type="hidden" name="project_type" value="construction">
      <button type="submit" class="choose-card">
        <div class="choose-icon-box">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
        </div>
        <div>
          <div class="choose-title">Construction neuve</div>
          <div class="choose-desc">Maison, véranda…</div>
        </div>
      </button>
    <% end %>
  </div>

  <div class="text-center mt-5">
    <%= link_to projects_path, class: "choose-back-link" do %>
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M10 12L6 8l4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Retour aux projets
    <% end %>
  </div>
</div>
