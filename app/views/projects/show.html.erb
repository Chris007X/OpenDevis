<% content_for :title, "#{@project.name} — OpenDevis" %>
<% content_for :description, "Détail du projet #{@project.name} : pièces, postes de travaux et estimation budgétaire." %>

<% content_for :head do %>
<style>
  .proj-show { font-family: 'Plus Jakarta Sans', sans-serif; }

  /* ── Summary cards ─────────────────────────────────────── */
  .proj-show .summary-card {
    border: 1.5px solid #2563eb;
    border-radius: 14px;
    padding: 1.375rem 1.5rem;
    background: #2563eb;
    color: #fff;
    height: 100%;
  }
  .proj-show .summary-card-light {
    border: 1.5px solid #E8E4DC;
    border-radius: 14px;
    padding: 1.375rem 1.5rem;
    background: #fff;
    height: 100%;
  }
  .proj-show .summary-label {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.75;
    margin-bottom: 0.4rem;
  }
  .proj-show .summary-amount {
    font-family: 'DM Serif Display', serif;
    font-size: 2rem;
    font-weight: 400;
    letter-spacing: -0.04em;
    line-height: 1.1;
  }
  .proj-show .summary-amount-light {
    font-family: 'DM Serif Display', serif;
    font-size: 2rem;
    font-weight: 400;
    letter-spacing: -0.04em;
    color: #4A4640;
    line-height: 1.1;
  }

  /* ── Standing toggle ───────────────────────────────────── */
  .proj-show .standing-toggle-btn {
    flex: 1;
    border: 1.5px solid #DDD9D1;
    border-radius: 8px;
    background: transparent;
    padding: 0.45rem 0.5rem;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.84rem;
    font-weight: 600;
    color: #4A4640;
    text-decoration: none;
    text-align: center;
    transition: border-color 0.12s, background 0.12s, color 0.12s;
  }
  .proj-show .standing-toggle-btn.active { border-color: #2563eb; background: #2563eb; color: #fff; }
  .proj-show .standing-toggle-btn:hover:not(.active) { border-color: #4A4640; color: #2C2A25; }

  .proj-show .standing-postes-count {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.78rem;
    color: #9B9588;
    margin-top: 0.5rem;
  }

  /* ── Category cards ────────────────────────────────────── */
  .proj-show .cat-card {
    border: 1.5px solid #E8E4DC;
    border-radius: 14px;
    background: #fff;
    padding: 1.25rem;
    text-align: center;
    transition: border-color 0.15s, transform 0.15s, box-shadow 0.15s;
    height: 100%;
  }
  .proj-show .cat-card:hover {
    border-color: #2C2A25;
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(44,42,37,0.1);
  }
  .proj-show .cat-icon  { font-size: 2rem; margin-bottom: 0.45rem; line-height: 1; }
  .proj-show .cat-name  { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 0.88rem; font-weight: 700; color: #2C2A25; margin-bottom: 0.25rem; }
  .proj-show .cat-count { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 0.75rem; color: #9B9588; margin-bottom: 0.5rem; }
  .proj-show .cat-total { font-family: 'DM Serif Display', serif; font-size: 1.1rem; font-weight: 400; color: #1C1A16; }

  /* ── Room rows ─────────────────────────────────────────── */
  .proj-show .room-row {
    border: 1.5px solid #E8E4DC;
    border-radius: 12px;
    background: #fff;
    padding: 1rem 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.5rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s;
  }
  .proj-show .room-row:hover { border-color: #2C2A25; color: inherit; }

  .proj-show .room-name {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 700;
    color: #1C1A16;
    margin-bottom: 0.15rem;
  }
  .proj-show .room-meta {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.82rem;
    color: #9B9588;
  }

  /* ── Section eyebrow ───────────────────────────────────── */
  .proj-show .section-eyebrow {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: #9B9588;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }
  .proj-show .section-eyebrow::after {
    content: '';
    display: block;
    height: 1px;
    flex: 1;
    background: linear-gradient(to right, #DDD9D1, transparent);
  }

  /* ── Bidding CTA ───────────────────────────────────────── */
  .proj-show .bidding-cta {
    border: 1.5px solid #E8E4DC;
    border-left: 4px solid #2563eb;
    border-radius: 14px;
    background: #F8FAFF;
    padding: 1.375rem 1.5rem;
    margin-bottom: 1.75rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }
  .proj-show .bidding-cta-title {
    font-family: 'DM Serif Display', serif;
    font-size: 1.05rem;
    font-weight: 400;
    color: #1C1A16;
    margin-bottom: 4px;
  }
  .proj-show .bidding-cta-desc {
    font-family: 'Plus Jakarta Sans', sans-serif;
    color: #4A4640;
    font-size: 0.88rem;
  }
  .proj-show .btn-bidding-cta {
    background: #2563eb;
    color: #fff;
    border-radius: 50px;
    padding: 10px 22px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.15s;
  }
  .proj-show .btn-bidding-cta:hover { background: #1B4FC2; color: #fff; }

  .proj-show .bidding-existing {
    border: 1.5px solid #E8E4DC;
    border-radius: 14px;
    background: #fff;
    padding: 1.25rem 1.5rem;
    margin-bottom: 1.75rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }

  /* ── Modals ────────────────────────────────────────────── */
  .proj-show-modal .modal-content {
    border: 1.5px solid #E8E4DC;
    border-radius: 16px;
    box-shadow: 0 8px 32px rgba(44,42,37,0.12);
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .proj-show-modal .modal-title-text {
    font-weight: 700;
    color: #2C2A25;
    font-size: 1rem;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .proj-show-modal .modal-sub-text {
    color: #4A4640;
    font-size: 0.85rem;
    margin-top: 2px;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .proj-show-modal .modal-body-text {
    color: #4A4640;
    font-size: 0.88rem;
    margin: 0 0 1.25rem;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .proj-show-modal .btn-modal-cancel {
    border: 1px solid #DDD9D1;
    background: #fff;
    color: #4A4640;
    border-radius: 50px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.88rem;
    font-weight: 500;
    padding: 0.45rem 1.15rem;
    cursor: pointer;
    transition: border-color 0.12s;
  }
  .proj-show-modal .btn-modal-cancel:hover { border-color: #2C2A25; }
  .proj-show-modal .btn-modal-danger {
    background: #842029;
    color: #fff;
    border: none;
    border-radius: 50px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.88rem;
    font-weight: 600;
    padding: 0.45rem 1.15rem;
    cursor: pointer;
    transition: background 0.12s;
  }
  .proj-show-modal .btn-modal-danger:hover { background: #6d1a22; }
  .proj-show-modal .btn-modal-dark {
    background: #2C2A25;
    color: #fff;
    border: none;
    border-radius: 50px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.88rem;
    font-weight: 600;
    padding: 0.45rem 1.15rem;
    cursor: pointer;
    transition: background 0.12s;
  }
  .proj-show-modal .btn-modal-dark:hover { background: #1C1A16; }

  /* ── Back link ─────────────────────────────────────────── */
  .proj-show .back-link {
    font-family: 'Plus Jakarta Sans', sans-serif;
    color: #9B9588;
    font-size: 0.85rem;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    transition: color 0.12s;
  }
  .proj-show .back-link:hover { color: #2C2A25; }

  /* ── Page title ────────────────────────────────────────── */
  .proj-show .project-h1 {
    font-family: 'DM Serif Display', serif;
    font-size: 1.8rem;
    font-weight: 400;
    letter-spacing: -0.025em;
    color: #1C1A16;
    margin: 0;
    line-height: 1.15;
  }

  /* ── Meta line ─────────────────────────────────────────── */
  .proj-show .project-meta {
    font-family: 'Plus Jakarta Sans', sans-serif;
    color: #9B9588;
    font-size: 0.875rem;
    margin-top: 4px;
  }

  /* ── Status badges ─────────────────────────────────────── */
  .proj-show .badge-brouillon { background-color: #EDE9E0; color: #4A4640; font-family: 'Plus Jakarta Sans', sans-serif; letter-spacing: 0.02em; }
  .proj-show .badge-en-cours  { background-color: #D4EDDA; color: #2D6A4F; font-family: 'Plus Jakarta Sans', sans-serif; letter-spacing: 0.02em; }
  .proj-show .badge-termine   { background-color: #D0E8F5; color: #1A5C80; font-family: 'Plus Jakarta Sans', sans-serif; letter-spacing: 0.02em; }
  .proj-show .badge-refuse    { background-color: #F8D7DA; color: #842029; font-family: 'Plus Jakarta Sans', sans-serif; letter-spacing: 0.02em; }
</style>
<% end %>

<%
category_icons = {
  "maconnerie"  => "🏗️",
  "plomberie"   => "🔧",
  "electricite" => "⚡",
  "menuiserie"  => "🚪",
  "peinture"    => "🖌️",
  "carrelage"   => "◻️",
  "isolation"   => "🧱",
  "chauffage"   => "🌡️"
}
status_label, status_class = case @project.status
  when "in_progress"     then ["Projet en cours",  "badge-en-cours"]
  when "quote_requested" then ["Devis demandé",    "badge-brouillon"]
  when "quote_received"  then ["Devis reçu",       "badge-termine"]
  when "archived"        then ["Archivé",           "badge-refuse"]
  else                        ["Projet en cours",  "badge-en-cours"]
  end
%>

<div class="proj-show" data-controller="delete-confirm archive-confirm">
<div class="container py-4" style="max-width: 1100px;">

  <%# ── Header ─────────────────────────────────────────────────────────── %>
  <div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-2">
    <div>
      <%= link_to projects_path, class: "back-link" do %>
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M10 12L6 8L10 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Mes projets
      <% end %>
      <div class="d-flex align-items-center gap-2 mt-1 flex-wrap">
        <h1 class="project-h1">
          <%= @project.location_zip.presence || "Projet sans localisation" %>
        </h1>
        <span class="badge <%= status_class %> fw-normal"
              style="font-size: 0.8rem; padding: 0.35em 0.8em; border-radius: 20px;">
          <%= status_label %>
        </span>
      </div>
      <div class="project-meta">
        <% meta = [] %>
        <% meta << "#{@project.total_surface_sqm&.to_i} m²" if @project.total_surface_sqm.present? %>
        <% meta << "#{@project.room_count} pièces" if @project.room_count.present? %>
        <% meta << "DPE #{@project.energy_rating}" if @project.energy_rating.present? %>
        <%= meta.join(" · ") %>
      </div>
    </div>
    <div class="d-flex gap-2 align-items-center" style="font-family: 'Plus Jakarta Sans', sans-serif;">
      <%= link_to "Exporter PDF", project_path(@project, standing: @standing, format: :pdf),
            class: "btn btn-ghost-od btn-sm" %>
      <%= link_to "Modifier", wizard_edit_path(@project), class: "btn btn-ghost-od btn-sm" %>
      <% if @project.archived? %>
        <%= button_to "Désarchiver", unarchive_project_path(@project), method: :patch,
              class: "btn btn-ghost-od btn-sm" %>
      <% else %>
        <button type="button" class="btn btn-ghost-od btn-sm"
                data-action="click->archive-confirm#show"
                data-archive-path="<%= archive_project_path(@project) %>"
                data-archive-name="<%= @project.location_zip.presence || @project.name.presence || 'Sans localisation' %>">
          Archiver
        </button>
      <% end %>
      <button type="button" class="btn btn-ghost-od btn-sm"
              style="color: #842029; border-color: #F8D7DA;"
              data-action="click->delete-confirm#show"
              data-delete-path="<%= project_path(@project) %>"
              data-delete-name="<%= @project.location_zip.presence || @project.name.presence || 'Sans localisation' %>">
        Supprimer
      </button>
    </div>
  </div>

  <%# ── Summary bar + categories (Turbo Frame) ─────────────────────────── %>
  <%= turbo_frame_tag "project_summary" do %>

    <%# Summary bar %>
    <div class="row g-3 mb-5">
      <div class="col-md-4">
        <div class="summary-card-light">
          <div class="summary-label" style="color: #4A4640;">Total HT</div>
          <div class="summary-amount-light">
            <%= number_to_currency(@total_ht, unit: "€", format: "%n %u",
                  separator: ",", delimiter: "\u202F") %>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="summary-card">
          <div class="summary-label">Total TTC</div>
          <div class="summary-amount">
            <%= number_to_currency(@total_ttc, unit: "€", format: "%n %u",
                  separator: ",", delimiter: "\u202F") %>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="summary-card-light">
          <div class="summary-label" style="color: #4A4640; opacity: 1;">Niveau de standing</div>
          <div class="d-flex gap-2">
            <% [[1, "Éco"], [2, "Standard"], [3, "Premium"]].each do |level, label| %>
              <%= link_to label, project_path(@project, standing: level),
                    class: "standing-toggle-btn #{"active" if @standing == level}",
                    data: { turbo_frame: "project_summary" } %>
            <% end %>
          </div>
          <div class="standing-postes-count">
            <%= pluralize(@categories_data.sum { |d| d[:count] }, "poste") %>
          </div>
        </div>
      </div>
    </div>

    <%# Categories %>
    <% if @categories_data.any? %>
      <div class="section-eyebrow">Par catégorie de travaux</div>
      <div class="row g-3 mb-5">
        <% @categories_data.each do |data| %>
          <% cat = data[:category] %>
          <div class="col-6 col-md-4 col-lg-3">
            <div class="cat-card">
              <div class="cat-icon"><%= category_icons[cat&.slug] || "🔨" %></div>
              <div class="cat-name"><%= cat&.name || "Autre" %></div>
              <div class="cat-count"><%= pluralize(data[:count], "poste") %></div>
              <div class="cat-total">
                <%= number_to_currency(data[:total], unit: "€", format: "%n %u",
                      separator: ",", delimiter: "\u202F") %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-4 mb-4" style="border: 1.5px solid #E8E4DC; border-radius: 14px; background: #fff;">
        <div style="font-family: 'Plus Jakarta Sans', sans-serif; color: #4A4640; font-size: 0.9rem;">
          Aucun poste pour le standing
          <strong><%= ["Éco", "Standard", "Premium"][@standing - 1] %></strong>.
          <% if @project.work_items.any? %>
            Essayez un autre niveau.
          <% else %>
            <br><%= link_to "Ajouter des pièces et des postes", new_project_room_path(@project) %>
            pour construire votre estimation.
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>

  <%# ── Artisan bidding CTA ────────────────────────────────────────────── %>
  <% if @project.bidding_round.nil? || @project.bidding_round.status == "draft" %>
    <%
      cta_path = if @project.bidding_round.nil?
        new_project_bidding_round_path(@project, standing: @standing)
      else
        select_artisans_project_bidding_round_path(@project)
      end
    %>
    <div class="bidding-cta">
      <div>
        <div class="bidding-cta-title">Obtenir des devis artisans</div>
        <div class="bidding-cta-desc">
          Envoyez votre estimation à des artisans locaux et comparez leurs propositions.
        </div>
      </div>
      <%= link_to "Demander des devis", cta_path, class: "btn-bidding-cta" %>
    </div>
  <% else %>
    <%
      br = @project.bidding_round
      br_label, br_class = case br.status
        when "sent"        then ["Envoyé",    "badge-en-cours"]
        when "in_progress" then ["En cours",  "badge-en-cours"]
        when "completed"   then ["Terminé",   "badge-termine"]
        else                    ["Brouillon", "badge-brouillon"]
      end
    %>
    <div class="bidding-existing">
      <div>
        <div class="d-flex align-items-center gap-2 mb-1">
          <span style="font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 700; color: #2C2A25;">Devis artisans</span>
          <span class="badge <%= br_class %> fw-normal" style="font-size: 0.75rem; padding: 0.25em 0.7em; border-radius: 20px;">
            <%= br_label %>
          </span>
        </div>
        <div style="font-family: 'Plus Jakarta Sans', sans-serif; color: #4A4640; font-size: 0.85rem;">
          <%= br.responses_received %> / <%= br.total_requests %> réponses reçues
          · Niveau <%= br.standing_label %>
          · Date limite <%= l(br.deadline, format: :short) %>
        </div>
      </div>
      <%= link_to "Voir le suivi", project_bidding_round_path(@project),
            style: "background: transparent; border: 1.5px solid #DDD9D1; color: #2C2A25; border-radius: 50px;
                    padding: 8px 20px; font-family: 'Plus Jakarta Sans', sans-serif; font-size: 0.88rem; font-weight: 600; text-decoration: none;
                    transition: border-color 0.12s;" %>
    </div>
  <% end %>

  <%# ── Rooms section ───────────────────────────────────────────────────── %>
  <div class="section-eyebrow">Par pièce</div>

  <% if @rooms.any? %>
    <% @rooms.each do |room| %>
      <%= link_to room, class: "room-row" do %>
        <div>
          <div class="room-name"><%= room.name %></div>
          <div class="room-meta">
            <% rparts = [] %>
            <% rparts << "#{room.surface_sqm&.to_i} m²" if room.surface_sqm.present? %>
            <% rparts << pluralize(room.work_items.size, "poste") %>
            <%= rparts.join(" · ") %>
          </div>
        </div>
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" style="color: #9B9588; flex-shrink: 0;">
          <path d="M6 4L10 8L6 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      <% end %>
    <% end %>
  <% else %>
    <div class="text-center py-4" style="border: 1.5px solid #E8E4DC; border-radius: 12px;
         background: #fff; font-family: 'Plus Jakarta Sans', sans-serif; color: #4A4640; font-size: 0.9rem;">
      Aucune pièce pour l'instant.
    </div>
  <% end %>

</div>

  <%# Modal de confirmation de suppression %>
  <div class="modal fade proj-show-modal" id="deleteConfirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 420px;">
      <div class="modal-content">
        <div class="modal-body p-4">
          <div class="d-flex align-items-center gap-3 mb-3">
            <div style="width: 40px; height: 40px; border-radius: 10px; background: #F8D7DA; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="#842029" viewBox="0 0 16 16">
                <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z"/>
                <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z"/>
              </svg>
            </div>
            <div>
              <div class="modal-title-text">Supprimer le projet</div>
              <div class="modal-sub-text">
                "<span data-delete-confirm-target="nameDisplay" style="color: #2C2A25; font-weight: 500;"></span>"
              </div>
            </div>
          </div>
          <p class="modal-body-text">
            Cette action est irréversible. Toutes les pièces et les postes associés à ce projet seront définitivement supprimés.
          </p>
          <div class="d-flex gap-2 justify-content-end">
            <button type="button" data-bs-dismiss="modal" class="btn-modal-cancel">
              Annuler
            </button>
            <button type="button" data-action="click->delete-confirm#confirm" class="btn-modal-danger">
              Supprimer définitivement
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%= form_with url: "#", method: :delete,
        data: { delete_confirm_target: "form" },
        style: "display: none;" do |f| %>
    <%= f.submit "Supprimer", style: "display: none;" %>
  <% end %>

  <%# Modal de confirmation d'archivage %>
  <div class="modal fade proj-show-modal" id="archiveConfirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 420px;">
      <div class="modal-content">
        <div class="modal-body p-4">
          <div class="d-flex align-items-center gap-3 mb-3">
            <div style="width: 40px; height: 40px; border-radius: 10px; background: #EDE9E0; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="#4A4640" viewBox="0 0 16 16">
                <path d="M0 2a1 1 0 0 1 1-1h14a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1v7.5a2.5 2.5 0 0 1-2.5 2.5h-9A2.5 2.5 0 0 1 1 12.5V5a1 1 0 0 1-1-1zm2 3v7.5A1.5 1.5 0 0 0 3.5 14h9a1.5 1.5 0 0 0 1.5-1.5V5zm13-3H1v2h14zM5 7.5a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5"/>
              </svg>
            </div>
            <div>
              <div class="modal-title-text">Archiver le projet</div>
              <div class="modal-sub-text">
                "<span data-archive-confirm-target="nameDisplay" style="color: #2C2A25; font-weight: 500;"></span>"
              </div>
            </div>
          </div>
          <p class="modal-body-text">
            Le projet sera déplacé dans les archives. Vous pourrez le désarchiver à tout moment.
          </p>
          <div class="d-flex gap-2 justify-content-end">
            <button type="button" data-bs-dismiss="modal" class="btn-modal-cancel">
              Annuler
            </button>
            <button type="button" data-action="click->archive-confirm#confirm" class="btn-modal-dark">
              Archiver
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%# Formulaire PATCH pour l'archivage %>
  <%= form_with url: "#", method: :patch,
        data: { archive_confirm_target: "form" },
        style: "display: none;" do |f| %>
    <%= f.submit "Archiver", style: "display: none;" %>
  <% end %>

</div>
