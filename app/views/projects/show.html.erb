<% status_fr = { "draft" => "Brouillon", "sent" => "Envoyé", "accepted" => "Accepté", "rejected" => "Refusé" } %>

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <%= link_to "← Mes projets", projects_path, class: "btn btn-outline-secondary btn-sm" %>
    <div class="d-flex gap-2">
      <%= link_to "Modifier", edit_project_path(@project), class: "btn btn-outline-secondary btn-sm" %>
      <%= button_to "Supprimer", @project, method: :delete, data: { turbo_confirm: "Supprimer ce projet ?" }, class: "btn btn-outline-danger btn-sm" %>
    </div>
  </div>

  <div class="card mb-4">
    <div class="card-body">
      <h2 class="card-title"><%= @project.location_zip.presence || "Projet" %></h2>
      <div class="row g-2 text-muted small">
        <div class="col-auto"><strong>Statut :</strong> <%= status_fr[@project.status] || "Brouillon" %></div>
        <div class="col-auto"><strong>Surface :</strong> <%= @project.total_surface_sqm&.then { |s| "#{s} m²" } || "—" %></div>
        <div class="col-auto"><strong>Pièces :</strong> <%= @project.room_count || "—" %></div>
        <div class="col-auto"><strong>Classe énergétique :</strong> <%= @project.energy_rating || "—" %></div>
        <% if @project.property_url.present? %>
          <div class="col-auto"><%= link_to "Lien du bien", @project.property_url, target: "_blank" %></div>
        <% end %>
      </div>
      <% if @project.total_exVAT.present? %>
        <div class="mt-2">
          <strong>Total HT :</strong> <%= number_to_currency(@project.total_exVAT, unit: "€", separator: ",", delimiter: " ") %>
          &nbsp;|&nbsp;
          <strong>Total TTC :</strong> <%= number_to_currency(@project.total_incVAT, unit: "€", separator: ",", delimiter: " ") %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Pièces</h3>
    <%= link_to "Ajouter une pièce", new_project_room_path(@project), class: "btn btn-primary btn-sm" %>
  </div>

  <% if @rooms.any? %>
    <div class="row g-3">
      <% @rooms.each do |room| %>
        <div class="col-md-4">
          <div class="card h-100">
            <div class="card-body">
              <h5 class="card-title"><%= room.name %></h5>
              <p class="card-text text-muted small">
                <%= [room.surface_sqm&.then { |v| "#{v} m²" }, room.perimeter_lm&.then { |v| "périmètre #{v} ml" }, room.wall_height_m&.then { |v| "hauteur #{v} m" }].compact.join(" · ") %>
              </p>
              <p class="card-text small"><%= pluralize(room.work_items.size, "poste", "postes") %></p>
            </div>
            <div class="card-footer d-flex gap-2">
              <%= link_to "Voir", room, class: "btn btn-sm btn-outline-primary" %>
              <%= link_to "Modifier", edit_room_path(room), class: "btn btn-sm btn-outline-secondary" %>
              <%= button_to "Supprimer", room, method: :delete, data: { turbo_confirm: "Supprimer cette pièce ?" }, class: "btn btn-sm btn-outline-danger" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-muted">Aucune pièce. <%= link_to "Ajouter la première pièce", new_project_room_path(@project) %>.</p>
  <% end %>

  <hr class="my-4">

  <div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Documents</h3>
    <%= link_to "Ajouter un document", new_project_document_path(@project), class: "btn btn-primary btn-sm" %>
  </div>

  <% if @documents.any? %>
    <table class="table table-hover align-middle">
      <thead class="table-light">
        <tr>
          <th>Nom du fichier</th>
          <th>Type</th>
          <th>Déposé le</th>
          <th>Lien</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @documents.each do |doc| %>
          <tr>
            <td><%= doc.file_name %></td>
            <td><%= doc.file_type %></td>
            <td><%= doc.uploaded_at&.strftime("%d/%m/%Y") %></td>
            <td><%= link_to "Ouvrir", doc.file_url, target: "_blank" if doc.file_url.present? %></td>
            <td class="text-end">
              <%= button_to "Supprimer", doc, method: :delete, data: { turbo_confirm: "Supprimer ce document ?" }, class: "btn btn-sm btn-outline-danger" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-muted">Aucun document. <%= link_to "Ajouter le premier", new_project_document_path(@project) %>.</p>
  <% end %>
</div>
