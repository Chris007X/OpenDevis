<% status_fr = { "draft" => "Brouillon", "sent" => "Envoyé", "accepted" => "Accepté", "rejected" => "Refusé" } %>

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Mes projets</h1>
    <%= link_to "Nouveau projet", new_project_path, class: "btn btn-primary" %>
  </div>

  <% if @projects.any? %>
    <div class="row g-3">
      <% @projects.each do |project| %>
        <div class="col-md-4">
          <div class="card h-100">
            <div class="card-body">
              <h5 class="card-title"><%= project.location_zip.presence || "Sans localisation" %></h5>
              <p class="card-text text-muted">
                <span class="badge bg-secondary"><%= status_fr[project.status] || "Brouillon" %></span>
                <% if project.total_surface_sqm.present? %>
                  &nbsp;· <%= project.total_surface_sqm %> m²
                <% end %>
              </p>
              <p class="card-text">
                <% if project.total_exVAT.present? %>
                  <strong>Total HT :</strong> <%= number_to_currency(project.total_exVAT, unit: "€", separator: ",", delimiter: " ") %>
                <% end %>
              </p>
            </div>
            <div class="card-footer d-flex gap-2">
              <%= link_to "Voir", project, class: "btn btn-sm btn-outline-primary" %>
              <%= link_to "Modifier", edit_project_path(project), class: "btn btn-sm btn-outline-secondary" %>
              <%= button_to "Supprimer", project, method: :delete, data: { turbo_confirm: "Supprimer ce projet ?" }, class: "btn btn-sm btn-outline-danger" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-5">
      <p class="text-muted">Aucun projet pour l'instant.</p>
      <%= link_to "Créer votre premier projet", new_project_path, class: "btn btn-primary" %>
    </div>
  <% end %>
</div>
