<% content_for :title, "Mes projets — OpenDevis" %>
<% content_for :description, "Gérez et suivez tous vos projets de rénovation au même endroit." %>

<% content_for :head do %>
<style>
  .proj-index { font-family: 'Plus Jakarta Sans', sans-serif; }

  .proj-index body { background-color: #FAFAF7; }

  .proj-index .page-title {
    font-family: 'DM Serif Display', serif;
    font-size: 2rem;
    font-weight: 400;
    letter-spacing: -0.025em;
    color: #1C1A16;
    line-height: 1.15;
  }

  .proj-index .project-count {
    font-family: 'Plus Jakarta Sans', sans-serif;
    color: #9B9588;
    font-size: 0.88rem;
    margin-top: 4px;
    font-weight: 500;
  }

  .proj-index .btn-primary-dark {
    background-color: #2563eb;
    border-color: #2563eb;
    color: #fff;
    border-radius: 50px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 600;
    font-size: 0.9rem;
    padding: 0.5rem 1.35rem;
    transition: background-color 0.15s, border-color 0.15s;
  }
  .proj-index .btn-primary-dark:hover {
    background-color: #1B4FC2;
    border-color: #1B4FC2;
    color: #fff;
  }

  .proj-index .project-card {
    border: 1.5px solid #E8E4DC;
    border-radius: 16px;
    background: #fff;
    text-decoration: none;
    color: inherit;
    display: block;
    transition: border-color 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
    overflow: hidden;
  }
  .proj-index .project-card:hover {
    border-color: #2C2A25;
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(44,42,37,0.1);
    color: inherit;
    text-decoration: none;
  }

  .proj-index .badge-brouillon { background-color: #EDE9E0; color: #4A4640; font-family: 'Plus Jakarta Sans', sans-serif; letter-spacing: 0.02em; }
  .proj-index .badge-en-cours  { background-color: #D4EDDA; color: #2D6A4F; font-family: 'Plus Jakarta Sans', sans-serif; letter-spacing: 0.02em; }
  .proj-index .badge-termine   { background-color: #D0E8F5; color: #1A5C80; font-family: 'Plus Jakarta Sans', sans-serif; letter-spacing: 0.02em; }
  .proj-index .badge-refuse    { background-color: #F8D7DA; color: #842029; font-family: 'Plus Jakarta Sans', sans-serif; letter-spacing: 0.02em; }
  .proj-index .badge-renovation   { background-color: #FFF3E0; color: #E65100; font-family: 'Plus Jakarta Sans', sans-serif; letter-spacing: 0.02em; }
  .proj-index .badge-construction { background-color: #E8E4F8; color: #5B4FC2; font-family: 'Plus Jakarta Sans', sans-serif; letter-spacing: 0.02em; }

  .proj-index .card-name {
    font-family: 'DM Serif Display', serif;
    font-size: 1.1rem;
    font-weight: 400;
    color: #1C1A16;
    letter-spacing: -0.01em;
    margin-bottom: 0.35rem;
  }

  .proj-index .card-total {
    font-family: 'DM Serif Display', serif;
    font-size: 1.35rem;
    font-weight: 400;
    letter-spacing: -0.03em;
    color: #1C1A16;
  }

  .proj-index .card-fourchette-label {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.75rem;
    color: #9B9588;
    font-weight: 500;
    margin-bottom: 0.85rem;
  }

  .proj-index .card-meta {
    font-family: 'Plus Jakarta Sans', sans-serif;
    color: #9B9588;
    font-size: 0.82rem;
    font-weight: 400;
  }

  .proj-index .project-card-wrapper { position: relative; }

  .proj-index .btn-delete-project {
    position: absolute;
    top: 8px;
    right: 8px;
    z-index: 10;
    width: 26px;
    height: 26px;
    border-radius: 6px;
    background: rgba(255,255,255,0.9);
    border: 1px solid #E8E4DC;
    color: #C5BFB5;
    font-size: 1rem;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    transition: color 0.12s, background 0.12s, border-color 0.12s;
    cursor: pointer;
  }
  .proj-index .btn-delete-project:hover {
    color: #842029;
    background: #F8D7DA;
    border-color: #F8D7DA;
  }

  .proj-index .project-card-photo {
    width: 100%;
    height: 130px;
    object-fit: cover;
    border-radius: 15px 15px 0 0;
    display: block;
  }
  .proj-index .project-card-photo-placeholder {
    width: 100%;
    height: 130px;
    border-radius: 15px 15px 0 0;
    background: #F5F2EC;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .proj-index .card-body-inner {
    padding: 1.25rem 1.375rem;
  }

  /* Archives eyebrow */
  .proj-index .section-eyebrow {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: #9B9588;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    white-space: nowrap;
  }
  .proj-index .section-eyebrow::after {
    content: '';
    display: block;
    height: 1px;
    flex: 1;
    background: linear-gradient(to right, #DDD9D1, transparent);
  }

  /* Empty state */
  .proj-index .empty-state-icon { margin-bottom: 1.25rem; }

  .proj-index .empty-state-title {
    font-family: 'DM Serif Display', serif;
    font-size: 1.4rem;
    font-weight: 400;
    color: #1C1A16;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }

  .proj-index .empty-state-desc {
    font-family: 'Plus Jakarta Sans', sans-serif;
    color: #4A4640;
    font-size: 0.9rem;
    max-width: 360px;
    text-align: center;
    margin-bottom: 1.5rem;
  }

  /* Delete modal */
  .proj-index-modal .modal-content {
    border: 1.5px solid #E8E4DC;
    border-radius: 16px;
    box-shadow: 0 8px 32px rgba(44,42,37,0.12);
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .proj-index-modal .modal-title-text {
    font-weight: 700;
    color: #2C2A25;
    font-size: 1rem;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .proj-index-modal .modal-sub-text {
    color: #4A4640;
    font-size: 0.85rem;
    margin-top: 2px;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .proj-index-modal .modal-body-text {
    color: #4A4640;
    font-size: 0.88rem;
    margin: 0 0 1.25rem;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .proj-index-modal .btn-modal-cancel {
    border: 1px solid #DDD9D1;
    background: #fff;
    color: #4A4640;
    border-radius: 50px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.88rem;
    font-weight: 500;
    padding: 0.45rem 1.15rem;
    cursor: pointer;
    transition: border-color 0.12s;
  }
  .proj-index-modal .btn-modal-cancel:hover { border-color: #2C2A25; }
  .proj-index-modal .btn-modal-danger {
    background: #842029;
    color: #fff;
    border: none;
    border-radius: 50px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.88rem;
    font-weight: 600;
    padding: 0.45rem 1.15rem;
    cursor: pointer;
    transition: background 0.12s;
  }
  .proj-index-modal .btn-modal-danger:hover { background: #6d1a22; }
</style>
<% end %>

<div class="proj-index" data-controller="delete-confirm">

  <div class="container py-4" style="max-width: 1100px;">
    <%# Header %>
    <div class="d-flex justify-content-between align-items-start mb-4">
      <div>
        <div class="page-title">Mes projets</div>
        <div class="project-count"><%= pluralize(@projects.size, "projet") %></div>
      </div>
      <%= link_to wizard_choose_path, class: "btn btn-primary-dark" do %>
        + Nouveau projet
      <% end %>
    </div>

    <% if @projects.any? %>
      <div class="row g-3">
        <% @projects.each do |project| %>
          <% status_label, status_class = case project.status
             when "in_progress"     then ["Projet en cours",  "badge-en-cours"]
             when "quote_requested" then ["Devis demandé",    "badge-brouillon"]
             when "quote_received"  then ["Devis reçu",       "badge-termine"]
             when "archived"        then ["Archivé",           "badge-refuse"]
             else                        ["Projet en cours",  "badge-en-cours"]
             end %>
          <div class="col-md-4">
            <div class="project-card-wrapper h-100">
              <button class="btn-delete-project"
                      title="Supprimer ce projet"
                      data-action="click->delete-confirm#show"
                      data-delete-path="<%= project_path(project) %>"
                      data-delete-name="<%= project.location_zip.presence || "Sans localisation" %>">
                &times;
              </button>
              <%= link_to project, class: "project-card h-100" do %>
                <%# Photo banner — image or placeholder %>
                <% if project.photo_url.present? %>
                  <img src="<%= project.photo_url %>"
                       alt="<%= project.name.presence || project.location_zip %>"
                       class="project-card-photo" />
                <% else %>
                  <div class="project-card-photo-placeholder">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="none" viewBox="0 0 48 48">
                      <path d="M24 6L4 22h5v20h12V30h6v12h12V22h5L24 6z" stroke="#C8C4BC" stroke-width="2" stroke-linejoin="round" fill="none"/>
                      <rect x="19" y="30" width="10" height="12" rx="1" stroke="#C8C4BC" stroke-width="2" fill="none"/>
                    </svg>
                  </div>
                <% end %>

                <div class="card-body-inner">
                  <%# Title + badges %>
                  <div class="mb-2">
                    <div class="card-name">
                      <%= project.location_zip.presence || "Sans localisation" %>
                    </div>
                    <span class="badge <%= status_class %> fw-normal" style="font-size: 0.78rem; padding: 0.3em 0.75em; border-radius: 20px;">
                      <%= status_label %>
                    </span>
                    <span class="badge <%= project.project_type == "construction" ? "badge-construction" : "badge-renovation" %> fw-normal" style="font-size: 0.78rem; padding: 0.3em 0.75em; border-radius: 20px;">
                      <%= project.project_type == "construction" ? "Construction" : "Rénovation" %>
                    </span>
                  </div>

                  <%# Price range Éco → Premium %>
                  <% eco_total     = project.total_incVAT_for_standing(1) %>
                  <% premium_total = project.total_incVAT_for_standing(3) %>
                  <div class="card-total mb-1">
                    <% if eco_total > 0 && premium_total > 0 %>
                      <%= number_to_currency(eco_total, unit: "€", format: "%n %u", separator: ",", delimiter: "\u202F", precision: 0) %>
                      <span style="font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 400; font-size: 1rem; color: #9B9588; margin: 0 0.2rem;">—</span>
                      <%= number_to_currency(premium_total, unit: "€", format: "%n %u", separator: ",", delimiter: "\u202F", precision: 0) %>
                    <% else %>
                      — €
                    <% end %>
                  </div>
                  <div class="card-fourchette-label">Fourchette TTC estimée (Éco → Premium)</div>

                  <%# Room count + surface %>
                  <div class="card-meta">
                    <% parts = [] %>
                    <% parts << "#{project.room_count}p" if project.room_count.present? %>
                    <% parts << "#{project.total_surface_sqm&.to_i} m²" if project.total_surface_sqm.present? %>
                    <% unless parts.empty? %>
                      <span><%= parts.join(" · ") %></span>
                      <span class="mx-1">·</span>
                    <% end %>
                    <span>Modifié <%= time_ago_in_words(project.updated_at) %></span>
                  </div>
                </div><%# /card-body-inner %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

    <% else %>
      <%# Empty state %>
      <div class="d-flex flex-column align-items-center justify-content-center py-5 mt-4">
        <div class="empty-state-icon">
          <svg width="64" height="64" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M32 8L6 28h7v28h16V42h6v14h16V28h7L32 8z" stroke="#2563eb" stroke-width="2.5" stroke-linejoin="round"/>
            <rect x="25" y="42" width="14" height="14" rx="1.5" stroke="#2563eb" stroke-width="2" fill="none"/>
            <path d="M22 28h20v14H22z" stroke="#2563eb" stroke-width="2" stroke-linejoin="round" fill="none"/>
          </svg>
        </div>
        <div class="empty-state-title">Aucun projet pour le moment</div>
        <p class="empty-state-desc">
          Créez votre première estimation de travaux en quelques clics.
        </p>
        <%= link_to "+ Nouveau projet", wizard_choose_path, class: "btn btn-primary-dark" %>
      </div>
    <% end %>

    <%# Archives section %>
    <% if @archived_projects.any? %>
      <div class="mt-5 pt-4" style="border-top: 1px solid #E8E4DC;">
        <div class="section-eyebrow mb-3">
          Archives
          <span style="font-size: 0.75rem; font-weight: 600; letter-spacing: 0; text-transform: none; color: #9B9588; margin-left: -0.25rem;">
            (<%= @archived_projects.size %>)
          </span>
        </div>
        <div class="row g-3">
          <% @archived_projects.each do |project| %>
            <div class="col-md-4">
              <div class="project-card-wrapper h-100" style="opacity: 0.65;">
                <button class="btn-delete-project"
                        title="Supprimer ce projet"
                        data-action="click->delete-confirm#show"
                        data-delete-path="<%= project_path(project) %>"
                        data-delete-name="<%= project.location_zip.presence || "Sans localisation" %>">
                  &times;
                </button>
                <%= link_to project, class: "project-card h-100" do %>
                  <% if project.photo_url.present? %>
                    <img src="<%= project.photo_url %>"
                         alt="<%= project.location_zip %>"
                         class="project-card-photo" style="filter: grayscale(40%);" />
                  <% else %>
                    <div class="project-card-photo-placeholder">
                      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="none" viewBox="0 0 48 48">
                        <path d="M24 6L4 22h5v20h12V30h6v12h12V22h5L24 6z" stroke="#C8C4BC" stroke-width="2" stroke-linejoin="round" fill="none"/>
                        <rect x="19" y="30" width="10" height="12" rx="1" stroke="#C8C4BC" stroke-width="2" fill="none"/>
                      </svg>
                    </div>
                  <% end %>
                  <div class="card-body-inner">
                    <div class="mb-2">
                      <div class="card-name">
                        <%= project.location_zip.presence || "Sans localisation" %>
                      </div>
                      <span class="badge badge-refuse fw-normal" style="font-size: 0.78rem; padding: 0.3em 0.75em; border-radius: 20px;">
                        Archivé
                      </span>
                      <span class="badge badge-project-type fw-normal" style="font-size: 0.78rem; padding: 0.3em 0.75em; border-radius: 20px;">
                        <%= project.project_type == "construction" ? "Construction" : "Rénovation" %>
                      </span>
                    </div>
                    <% eco_total     = project.total_incVAT_for_standing(1) %>
                    <% premium_total = project.total_incVAT_for_standing(3) %>
                    <div class="card-total mb-1">
                      <% if eco_total > 0 && premium_total > 0 %>
                        <%= number_to_currency(eco_total, unit: "€", format: "%n %u", separator: ",", delimiter: "\u202F", precision: 0) %>
                        <span style="font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 400; font-size: 1rem; color: #9B9588; margin: 0 0.2rem;">—</span>
                        <%= number_to_currency(premium_total, unit: "€", format: "%n %u", separator: ",", delimiter: "\u202F", precision: 0) %>
                      <% else %>
                        — €
                      <% end %>
                    </div>
                    <div class="card-fourchette-label">Fourchette TTC estimée (Éco → Premium)</div>
                    <div class="card-meta">
                      <% parts = [] %>
                      <% parts << "#{project.room_count}p" if project.room_count.present? %>
                      <% parts << "#{project.total_surface_sqm&.to_i} m²" if project.total_surface_sqm.present? %>
                      <% unless parts.empty? %>
                        <span><%= parts.join(" · ") %></span>
                        <span class="mx-1">·</span>
                      <% end %>
                      <span>Archivé <%= time_ago_in_words(project.updated_at) %></span>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <%# Modal de confirmation de suppression — à l'intérieur du controller Stimulus %>
  <div class="modal fade proj-index-modal" id="deleteConfirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 420px;">
      <div class="modal-content">
        <div class="modal-body p-4">

          <div class="d-flex align-items-center gap-3 mb-3">
            <div style="width: 40px; height: 40px; border-radius: 10px; background: #F8D7DA; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="#842029" viewBox="0 0 16 16">
                <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z"/>
                <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z"/>
              </svg>
            </div>
            <div>
              <div class="modal-title-text">Supprimer le projet</div>
              <div class="modal-sub-text">
                "<span data-delete-confirm-target="nameDisplay" style="color: #2C2A25; font-weight: 500;"></span>"
              </div>
            </div>
          </div>

          <p class="modal-body-text">
            Cette action est irréversible. Toutes les pièces et les postes associés à ce projet seront définitivement supprimés.
          </p>

          <div class="d-flex gap-2 justify-content-end">
            <button type="button"
                    data-bs-dismiss="modal"
                    class="btn-modal-cancel">
              Annuler
            </button>
            <button type="button"
                    data-action="click->delete-confirm#confirm"
                    class="btn-modal-danger">
              Supprimer définitivement
            </button>
          </div>

        </div>
      </div>
    </div>
  </div>

  <%# Formulaire caché utilisé par le controller pour soumettre le DELETE %>
  <%= form_with url: "#", method: :delete,
        data: { delete_confirm_target: "form" },
        style: "display: none;" do |f| %>
    <%= f.submit "Supprimer", style: "display: none;" %>
  <% end %>

</div>
