<% content_for :head do %>
<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap');

  .br-new-scope {
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .br-new-scope .page-heading {
    font-family: 'DM Serif Display', serif;
    font-style: italic;
    font-size: 1.9rem;
    color: #1C1A16;
    margin: 0 0 6px;
    line-height: 1.2;
  }
  .br-new-scope .eyebrow {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: #9B9588;
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
  }
  .br-new-scope .eyebrow::after {
    content: '';
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, #E8E4DC, transparent);
  }
  .br-new-scope .info-card {
    background: #FAFAF7;
    border: 1.5px solid #E8E4DC;
    border-radius: 14px;
    padding: 18px 22px;
  }
  .br-new-scope .bd-cat-card {
    border: 1.5px solid #E8E4DC;
    border-radius: 12px;
    padding: 16px;
    cursor: pointer;
    transition: all 0.15s ease;
    background: #fff;
    position: relative;
    user-select: none;
  }
  .br-new-scope .bd-cat-card:hover { border-color: #DDD9D1; }
  .br-new-scope .bd-cat-card.selected {
    border-color: #2563eb;
    background: #EFF4FF;
  }
  .br-new-scope .bd-cat-checkbox {
    position: absolute;
    top: 12px;
    right: 12px;
    accent-color: #2563eb;
    width: 16px;
    height: 16px;
  }
  .br-new-scope .bd-cat-name {
    font-weight: 600;
    font-size: 0.88rem;
    color: #1C1A16;
    margin-top: 4px;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .br-new-scope .bd-cat-meta {
    font-size: 0.78rem;
    color: #9B9588;
    margin-top: 2px;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .br-new-scope .bd-cat-price {
    font-size: 0.92rem;
    font-weight: 700;
    color: #2C2A25;
    margin-top: 6px;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .br-new-scope .select-all-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.83rem;
    font-weight: 500;
    color: #4A4640;
    cursor: pointer;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .br-new-scope .select-all-toggle input[type="checkbox"] {
    width: 16px;
    height: 16px;
    accent-color: #2563eb;
    cursor: pointer;
  }
  .br-new-scope .deadline-input {
    border: 1.5px solid #DDD9D1;
    border-radius: 10px;
    padding: 9px 14px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.9rem;
    color: #2C2A25;
    background: #fff;
    outline: none;
    transition: border-color 0.12s;
  }
  .br-new-scope .deadline-input:focus { border-color: #2563eb; }
  .br-new-scope .back-link {
    font-size: 0.82rem;
    color: #9B9588;
    text-decoration: none;
  }
  .br-new-scope .back-link:hover { color: #4A4640; }
  .br-new-scope .submit-btn {
    background: #2563eb;
    color: #fff;
    border: none;
    padding: 10px 26px;
    border-radius: 20px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    opacity: 0.4;
    transition: opacity 0.15s, background 0.15s;
  }
  .br-new-scope .submit-btn:not([disabled]) { opacity: 1; }
  .br-new-scope .submit-btn:not([disabled]):hover { background: #1d4ed8; }
  .br-new-scope .empty-state {
    border: 1.5px solid #E8E4DC;
    border-radius: 14px;
    background: #fff;
    padding: 2.5rem;
    text-align: center;
  }
</style>
<% end %>

<div class="container py-4 br-new-scope" style="max-width: 860px;">
  <%= link_to "← Retour au projet", project_path(@project), class: "back-link" %>

  <h2 class="page-heading mt-3">Demander des devis artisans</h2>
  <p class="mb-4" style="color: #9B9588; font-size: 0.88rem;">Sélectionnez les catégories et la date limite pour recevoir des propositions.</p>

  <div class="info-card mb-4">
    <div class="d-flex justify-content-between align-items-center">
      <div>
        <span style="font-weight: 600; color: #1C1A16; font-size: 0.92rem;">Niveau sélectionné : <%= BiddingRound::STANDING_LABELS[@standing_level] %></span>
        <% total_ht = @categories_with_items.sum { |c| c.subtotal_ht.to_f } %>
        <div style="color: #9B9588; font-size: 0.83rem; margin-top: 3px;">
          Estimation initiale : <%= number_to_currency(total_ht, unit: "€", format: "%n %u", precision: 0) %> HT
        </div>
      </div>
    </div>
  </div>

  <%= form_with url: project_bidding_round_path(@project), method: :post,
        data: { controller: "bidding-step1" } do |f| %>
    <input type="hidden" name="bidding_round[standing_level]" value="<%= @standing_level %>">

    <div class="d-flex justify-content-between align-items-center mb-1">
      <div class="eyebrow" style="flex: 1; margin-bottom: 0;">Catégories à envoyer</div>
      <% if @categories_with_items.any? %>
        <label class="select-all-toggle ms-3">
          <input type="checkbox" data-bidding-step1-target="selectAllToggle"
                 data-action="change->bidding-step1#selectAll">
          Tout sélectionner
        </label>
      <% end %>
    </div>
    <p class="mb-3 mt-3" style="color: #9B9588; font-size: 0.85rem;">
      Sélectionnez les catégories pour lesquelles vous souhaitez recevoir des devis artisans.
    </p>

    <% if @categories_with_items.any? %>
      <div class="row g-3 mb-4">
        <% @categories_with_items.each do |category| %>
          <div class="col-md-4">
            <label class="bd-cat-card w-100 d-block" data-bidding-step1-target="catCard">
              <input type="checkbox" name="category_ids[]" value="<%= category.id %>"
                     class="bd-cat-checkbox"
                     data-action="change->bidding-step1#updateButton">
              <div class="bd-cat-name"><%= category.name %></div>
              <div class="bd-cat-meta"><%= category.items_count %> postes</div>
              <div class="bd-cat-price">
                <%= number_to_currency(category.subtotal_ht.to_f, unit: "€", format: "%n %u", precision: 0) %> HT
              </div>
            </label>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="empty-state mb-4">
        <div style="color: #9B9588; font-size: 0.88rem;">
          Aucun poste au niveau <%= BiddingRound::STANDING_LABELS[@standing_level] %> pour ce projet.
          <br><%= link_to "Retour au projet", project_path(@project), style: "color: #2563eb;" %> pour ajouter des postes.
        </div>
      </div>
    <% end %>

    <div class="eyebrow">Date limite de réponse</div>
    <p class="mb-3" style="color: #9B9588; font-size: 0.85rem;">Les artisans auront jusqu'à cette date pour répondre.</p>

    <div class="row g-2 mb-1">
      <div class="col-auto">
        <% default_deadline = 7.days.from_now.strftime("%Y-%m-%dT%H:%M") %>
        <input type="datetime-local"
               name="bidding_round[deadline]"
               value="<%= default_deadline %>"
               min="<%= 24.hours.from_now.strftime("%Y-%m-%dT%H:%M") %>"
               class="deadline-input"
               data-bidding-step1-target="deadline"
               data-action="change->bidding-step1#updateButton">
      </div>
    </div>
    <p class="mb-4" style="color: #9B9588; font-size: 0.78rem;">Recommandé : 7 jours.</p>

    <div class="d-flex justify-content-between align-items-center">
      <%= link_to "← Retour", project_path(@project), class: "back-link" %>
      <button type="submit"
              class="submit-btn"
              data-bidding-step1-target="submitBtn"
              disabled>
        Choisir les artisans →
      </button>
    </div>
  <% end %>
</div>
