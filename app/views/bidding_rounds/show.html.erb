<% content_for :head do %>
<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap');

  .br-scope {
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .br-scope .page-heading {
    font-family: 'DM Serif Display', serif;
    font-style: italic;
    font-size: 1.9rem;
    color: #1C1A16;
    margin: 0 0 4px;
    line-height: 1.2;
  }
  .br-scope .eyebrow {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: #9B9588;
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
  }
  .br-scope .eyebrow::after {
    content: '';
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, #E8E4DC, transparent);
  }
  .br-scope .br-status-badge {
    display: inline-block;
    padding: 0.3em 0.9em;
    border-radius: 20px;
    font-size: 0.78rem;
    font-weight: 600;
    font-family: 'Plus Jakarta Sans', sans-serif;
    letter-spacing: 0.02em;
  }
  .br-scope .br-status-draft      { background: #F0EDE8; color: #4A4640; }
  .br-scope .br-status-sent       { background: #D0E8F5; color: #1A5C80; }
  .br-scope .br-status-in_progress { background: #FFF3CD; color: #856404; }
  .br-scope .br-status-completed  { background: #D4EDDA; color: #2D6A4F; }
  .br-scope .br-status-cancelled  { background: #F8D7DA; color: #842029; }

  .br-scope .req-status-badge {
    font-size: 0.72rem;
    padding: 0.2em 0.65em;
    border-radius: 20px;
    font-weight: 600;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .br-scope .req-pending   { background: #F0EDE8; color: #4A4640; }
  .br-scope .req-sent      { background: #D0E8F5; color: #1A5C80; }
  .br-scope .req-responded { background: #D4EDDA; color: #2D6A4F; }
  .br-scope .req-declined  { background: #F8D7DA; color: #842029; }
  .br-scope .req-expired   { background: #F8D7DA; color: #842029; }
  .br-scope .req-replaced  { background: #F0EDE8; color: #4A4640; }

  .br-scope .cat-group {
    border: 1.5px solid #E8E4DC;
    border-radius: 14px;
    background: #fff;
    margin-bottom: 14px;
    overflow: hidden;
  }
  .br-scope .cat-group-header {
    padding: 13px 20px;
    background: #FAFAF7;
    border-bottom: 1.5px solid #E8E4DC;
    font-weight: 700;
    font-size: 0.88rem;
    color: #1C1A16;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .br-scope .artisan-row {
    padding: 13px 20px;
    border-bottom: 1px solid #F0EDE8;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .br-scope .artisan-row:last-child { border-bottom: none; }
  .br-scope .artisan-avatar-sm {
    width: 34px; height: 34px; border-radius: 50%;
    background: #E8E4DC; color: #4A4640;
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 0.82rem; flex-shrink: 0;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .br-scope .progress-card {
    border: 1.5px solid #E8E4DC;
    border-radius: 14px;
    background: #fff;
    padding: 20px 24px;
    margin-bottom: 24px;
  }
  .br-scope .back-link {
    font-size: 0.82rem;
    color: #9B9588;
    text-decoration: none;
  }
  .br-scope .back-link:hover { color: #4A4640; }
  .br-scope .empty-state {
    border: 1.5px solid #E8E4DC;
    border-radius: 14px;
    background: #fff;
    padding: 3rem;
    text-align: center;
  }
</style>
<% end %>

<%
  status_labels = {
    "draft"       => ["Brouillon",    "br-status-draft"],
    "sent"        => ["Envoyé",       "br-status-sent"],
    "in_progress" => ["En cours",     "br-status-in_progress"],
    "completed"   => ["Terminé",      "br-status-completed"],
    "cancelled"   => ["Annulé",       "br-status-cancelled"]
  }
  sl, sc = status_labels[@bidding_round.status] || ["Inconnu", "br-status-draft"]
%>

<%= turbo_stream_from "bidding_round_#{@bidding_round.id}_requests" %>
<div id="bidding_toast_container"></div>

<div class="container py-4 br-scope" style="max-width: 1000px;">
  <%= link_to "← Retour au projet", project_path(@project), class: "back-link" %>

  <div class="d-flex justify-content-between align-items-start mt-3 mb-4 flex-wrap gap-2">
    <div>
      <h2 class="page-heading">Suivi des devis artisans</h2>
      <div style="color: #9B9588; font-size: 0.85rem; margin-top: 4px;">
        Niveau : <strong style="color: #2C2A25;"><%= @bidding_round.standing_label %></strong>
        · Date limite : <strong style="color: #2C2A25;"><%= l(@bidding_round.deadline, format: :short) %></strong>
      </div>
    </div>
    <div class="d-flex align-items-center gap-2">
      <span class="br-status-badge <%= sc %>"><%= sl %></span>
      <% if @bidding_round.ready_for_review? %>
        <%= link_to "Voir les recommandations →",
              review_responses_project_bidding_round_path(@project),
              class: "btn btn-dark-od btn-sm" %>
      <% end %>
    </div>
  </div>

  <%# Progress card %>
  <div class="progress-card">
    <%= render "bidding_rounds/progress_bar", bidding_round: @bidding_round %>
  </div>

  <%# Requests by category %>
  <% if @requests_by_category.any? %>
    <div class="eyebrow">Par catégorie</div>
    <% @requests_by_category.each do |category, requests| %>
      <div class="cat-group">
        <div class="cat-group-header">
          <%= category&.name || "Autre" %>
          <span style="color: #9B9588; font-weight: 500; font-size: 0.8rem; margin-left: 8px;">
            <%= requests.count %> artisan<%= requests.count > 1 ? "s" : "" %>
          </span>
        </div>
        <% requests.each do |req| %>
          <%= render "bidding_rounds/bidding_request_row", bidding_request: req, project: @project %>
        <% end %>
      </div>
    <% end %>
  <% else %>
    <div class="empty-state">
      <div style="color: #9B9588; font-size: 0.88rem;">Aucune demande envoyée pour l'instant.</div>
    </div>
  <% end %>
</div>
