<% content_for :head do %>
<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap');

  .sa-scope {
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .sa-scope .page-heading {
    font-family: 'DM Serif Display', serif;
    font-style: italic;
    font-size: 1.9rem;
    color: #1C1A16;
    margin: 0 0 6px;
    line-height: 1.2;
  }
  .sa-scope .eyebrow {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: #9B9588;
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
  }
  .sa-scope .eyebrow::after {
    content: '';
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, #E8E4DC, transparent);
  }
  .sa-scope .artisan-card {
    border: 1.5px solid #E8E4DC;
    border-radius: 12px;
    padding: 13px 16px;
    cursor: pointer;
    transition: all 0.15s ease;
    background: #fff;
    position: relative;
    user-select: none;
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 8px;
  }
  .sa-scope .artisan-card:hover { border-color: #DDD9D1; }
  .sa-scope .artisan-card.selected { border-color: #2563eb; background: #EFF4FF; }
  .sa-scope .artisan-card.disabled { opacity: 0.4; cursor: not-allowed; }
  .sa-scope .artisan-avatar {
    width: 38px; height: 38px; border-radius: 50%;
    background: #2C2A25; color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 0.88rem; flex-shrink: 0;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .sa-scope .artisan-name {
    font-weight: 600;
    font-size: 0.88rem;
    color: #1C1A16;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .sa-scope .artisan-meta {
    font-size: 0.78rem;
    color: #9B9588;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .sa-scope .artisan-rating {
    font-size: 0.83rem;
    color: #2C2A25;
    font-weight: 600;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .sa-scope .artisan-checkbox {
    position: absolute;
    top: 14px;
    right: 14px;
    accent-color: #2563eb;
    width: 16px;
    height: 16px;
  }
  .sa-scope .cat-section {
    border: 1.5px solid #E8E4DC;
    border-radius: 14px;
    background: #fff;
    margin-bottom: 18px;
    overflow: hidden;
  }
  .sa-scope .cat-section-header {
    padding: 13px 20px;
    background: #FAFAF7;
    border-bottom: 1.5px solid #E8E4DC;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .sa-scope .cat-section-body { padding: 16px 20px; }
  .sa-scope .select-all-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.82rem;
    font-weight: 500;
    color: #4A4640;
    cursor: pointer;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .sa-scope .select-all-toggle input[type="checkbox"] {
    width: 16px;
    height: 16px;
    accent-color: #2563eb;
    cursor: pointer;
  }
  .sa-scope .selection-counter {
    font-size: 0.78rem;
    color: #9B9588;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .sa-scope .selection-counter.has-selection { color: #2D6A4F; font-weight: 600; }
  .sa-scope .back-link {
    font-size: 0.82rem;
    color: #9B9588;
    text-decoration: none;
  }
  .sa-scope .back-link:hover { color: #4A4640; }
  .sa-scope .submit-btn {
    background: #2563eb;
    color: #fff;
    border: none;
    padding: 10px 26px;
    border-radius: 20px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    transition: background 0.15s;
  }
  .sa-scope .submit-btn:hover { background: #1d4ed8; }
  .sa-scope .empty-state {
    border: 1.5px solid #E8E4DC;
    border-radius: 14px;
    background: #fff;
    padding: 3rem;
    text-align: center;
  }
</style>
<% end %>

<div class="container py-4 sa-scope" style="max-width: 860px;">
  <%= link_to "← Retour", new_project_bidding_round_path(@project), class: "back-link" %>

  <h2 class="page-heading mt-3">Choisir les artisans</h2>
  <p class="mb-4" style="color: #9B9588; font-size: 0.88rem;">Sélectionnez jusqu'à 3 artisans par catégorie. Ils recevront une demande de devis.</p>

  <%= form_with url: update_artisans_project_bidding_round_path(@project), method: :patch,
        data: { controller: "artisan-select" } do |f| %>

    <% if @categories.any? %>
      <% @categories.each do |category| %>
        <% artisans = @artisans_by_category[category.id] || [] %>
        <div class="cat-section" data-artisan-select-target="section" data-max="3">
          <div class="cat-section-header">
            <div>
              <span style="font-weight: 700; color: #1C1A16; font-size: 0.88rem;"><%= category.name %></span>
              <span style="color: #9B9588; font-size: 0.8rem; margin-left: 8px;">
                (<%= artisans.count %> artisans disponibles)
              </span>
            </div>
            <div class="d-flex align-items-center gap-3">
              <label class="select-all-toggle">
                <input type="checkbox" data-artisan-select-target="sectionToggle"
                       data-action="change->artisan-select#selectAll">
                Tout sélectionner
              </label>
              <span class="selection-counter" data-artisan-select-target="counter">
                0 / 3 sélectionnés
              </span>
            </div>
          </div>
          <div class="cat-section-body">
            <% if artisans.any? %>
              <% artisans.each do |artisan| %>
                <label class="artisan-card" data-artisan-select-target="card">
                  <input type="checkbox"
                         name="artisan_selections[<%= category.id %>][]"
                         value="<%= artisan.id %>"
                         class="artisan-checkbox"
                         data-artisan-select-target="checkbox"
                         data-action="change->artisan-select#toggle">
                  <div class="artisan-avatar">
                    <%= artisan.name.first.upcase %>
                  </div>
                  <div style="flex: 1; min-width: 0;">
                    <div class="artisan-name"><%= artisan.name %></div>
                    <div class="artisan-meta">
                      <%= artisan.company_name.presence || artisan.postcode %>
                      <% if artisan.company_name.present? %>
                        · <%= artisan.postcode %>
                      <% end %>
                    </div>
                  </div>
                  <div class="text-end" style="padding-right: 28px;">
                    <% if artisan.rating.present? %>
                      <div class="artisan-rating">★ <%= artisan.star_rating %></div>
                    <% end %>
                    <% if artisan.certifications.present? %>
                      <div class="artisan-meta">Certifié</div>
                    <% end %>
                  </div>
                </label>
              <% end %>
            <% else %>
              <div style="color: #9B9588; font-size: 0.88rem; text-align: center; padding: 20px 0;">
                Aucun artisan disponible dans ce secteur pour cette catégorie.
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="empty-state">
        <div style="color: #9B9588; font-size: 0.88rem;">Aucune catégorie sélectionnée.</div>
        <%= link_to "← Retour", new_project_bidding_round_path(@project), class: "btn btn-ghost-od btn-sm mt-3" %>
      </div>
    <% end %>

    <div class="d-flex justify-content-between align-items-center mt-4">
      <%= link_to "← Retour", new_project_bidding_round_path(@project), class: "back-link" %>
      <button type="submit" class="submit-btn">
        Envoyer les demandes →
      </button>
    </div>
  <% end %>
</div>
