<% content_for :head do %>
<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap');

  .rr-scope {
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .rr-scope .page-heading {
    font-family: 'DM Serif Display', serif;
    font-style: italic;
    font-size: 1.9rem;
    color: #1C1A16;
    margin: 0 0 6px;
    line-height: 1.2;
  }
  .rr-scope .eyebrow {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: #9B9588;
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
  }
  .rr-scope .eyebrow::after {
    content: '';
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, #E8E4DC, transparent);
  }
  .rr-scope .rec-card {
    border: 1.5px solid #E8E4DC;
    border-radius: 14px;
    padding: 16px;
    background: #fff;
    cursor: pointer;
    transition: all 0.15s ease;
    position: relative;
    user-select: none;
  }
  .rr-scope .rec-card:hover { border-color: #DDD9D1; }
  .rr-scope .rec-card.selected { border-color: #2563eb; background: #EFF4FF; }
  .rr-scope .rec-card.recommended { border-color: #2D6A4F; }
  .rr-scope .rec-card.recommended.selected { background: #EAF5EE; border-color: #2563eb; }
  .rr-scope .rec-badge {
    display: inline-block;
    background: #D4EDDA;
    color: #2D6A4F;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 2px 9px;
    border-radius: 20px;
    margin-bottom: 8px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    letter-spacing: 0.04em;
  }
  .rr-scope .rec-radio {
    position: absolute;
    top: 14px;
    right: 14px;
    accent-color: #2563eb;
  }
  .rr-scope .score-bar-wrap {
    height: 3px;
    background: #E8E4DC;
    border-radius: 2px;
    margin-top: 8px;
  }
  .rr-scope .score-bar {
    height: 3px;
    background: #2563eb;
    border-radius: 2px;
  }
  .rr-scope .cat-section {
    border: 1.5px solid #E8E4DC;
    border-radius: 14px;
    background: #fff;
    margin-bottom: 18px;
    overflow: hidden;
  }
  .rr-scope .cat-header {
    padding: 13px 20px;
    background: #FAFAF7;
    border-bottom: 1.5px solid #E8E4DC;
    font-weight: 700;
    font-size: 0.88rem;
    color: #1C1A16;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .rr-scope .cat-body { padding: 16px 20px; }
  .rr-scope .artisan-comment-block {
    font-size: 0.78rem;
    color: #4A4640;
    margin-top: 8px;
    padding: 8px 12px;
    background: #F8F6F2;
    border-radius: 8px;
    white-space: pre-wrap;
    border: 1px solid #E8E4DC;
  }
  .rr-scope .back-link {
    font-size: 0.82rem;
    color: #9B9588;
    text-decoration: none;
  }
  .rr-scope .back-link:hover { color: #4A4640; }
  .rr-scope .submit-btn {
    background: #2563eb;
    color: #fff;
    border: none;
    padding: 10px 26px;
    border-radius: 20px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    transition: background 0.15s;
  }
  .rr-scope .submit-btn:hover { background: #1d4ed8; }
  .rr-scope .empty-state {
    border: 1.5px solid #E8E4DC;
    border-radius: 14px;
    background: #fff;
    padding: 3rem;
    text-align: center;
  }
</style>
<% end %>

<div class="container py-4 rr-scope" style="max-width: 920px;">
  <%= link_to "← Retour au suivi", project_bidding_round_path(@project), class: "back-link" %>

  <h2 class="page-heading mt-3">Recommandations</h2>
  <p class="mb-4" style="color: #9B9588; font-size: 0.88rem;">
    Sélectionnez l'artisan retenu pour chaque catégorie. La recommandation est basée sur le prix (60%) et la note (40%).
  </p>

  <%= form_with url: confirm_selections_project_bidding_round_path(@project), method: :post do |f| %>
    <% if @recommendations.any? %>
      <div class="eyebrow">Par catégorie</div>
      <% @recommendations.each do |category_id, scored| %>
        <% category = scored.first[:request].work_category %>
        <div class="cat-section">
          <div class="cat-header"><%= category.name %></div>
          <div class="cat-body">
            <div class="row g-3">
              <% scored.each_with_index do |item, idx| %>
                <% req = item[:request] %>
                <% is_top = idx == 0 %>
                <div class="col-md-4">
                  <label class="rec-card w-100 <%= "recommended" if is_top %>">
                    <input type="radio"
                           name="selections[<%= category_id %>]"
                           value="<%= req.id %>"
                           class="rec-radio"
                           <%= "checked" if is_top %>
                           required>
                    <% if is_top %>
                      <input type="hidden" name="ai_recommended_ids[]" value="<%= req.id %>">
                    <% end %>
                    <div style="height: 22px; margin-bottom: 8px;">
                      <% if is_top %>
                        <span class="rec-badge">✨ Recommandé</span>
                      <% end %>
                    </div>
                    <div style="font-family: 'DM Serif Display', serif; font-size: 1.1rem; color: #1C1A16; margin-bottom: 2px; font-weight: 400;">
                      <%= number_to_currency(req.price_total, unit: "€", format: "%n %u", precision: 0) %> HT
                    </div>
                    <div style="font-weight: 600; color: #2C2A25; font-size: 0.88rem; font-family: 'Plus Jakarta Sans', sans-serif;"><%= req.artisan.name %></div>
                    <div style="font-size: 0.78rem; color: #9B9588; font-family: 'Plus Jakarta Sans', sans-serif;">
                      <%= req.artisan.company_name.presence || req.artisan.postcode %>
                      <% if req.artisan.rating.present? %>
                        · ★ <%= req.artisan.star_rating %>
                      <% end %>
                    </div>
                    <% if req.artisan_comment.present? %>
                      <div class="artisan-comment-block">
                        <%= req.artisan_comment %>
                      </div>
                    <% end %>
                    <div style="font-size: 0.72rem; color: #9B9588; margin-top: 6px; font-family: 'Plus Jakarta Sans', sans-serif;">
                      Score : <%= (item[:score] * 100).round %>%
                    </div>
                    <div class="score-bar-wrap">
                      <div class="score-bar" style="width: <%= (item[:score] * 100).round %>%;"></div>
                    </div>
                  </label>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>

      <div class="d-flex justify-content-between align-items-center mt-4">
        <%= link_to "← Retour", project_bidding_round_path(@project), class: "back-link" %>
        <button type="submit" class="submit-btn">
          Confirmer les sélections →
        </button>
      </div>
    <% else %>
      <div class="empty-state">
        <div style="color: #9B9588; font-size: 0.88rem;">Aucune réponse reçue pour l'instant.</div>
        <%= link_to "← Retour", project_bidding_round_path(@project), class: "btn btn-ghost-od btn-sm mt-3" %>
      </div>
    <% end %>
  <% end %>
</div>
