<% content_for :title, "Modifier mon profil — OpenDevis" %>
<% content_for :head do %>
<style>
  body { background-color: #FAFAF7; }
  .profile-scope * { font-family: 'Plus Jakarta Sans', sans-serif; }
  .profile-edit-page { max-width: 620px; margin: 0 auto; padding: 2.5rem 1.25rem; }
  .profile-edit-heading {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: 1.85rem;
    font-weight: 400;
    color: #1C1A16;
    line-height: 1.15;
  }
  .profile-edit-sub { font-size: 0.88rem; color: #9B9588; margin-top: 0.2rem; margin-bottom: 2rem; }
  .profile-edit-avatar {
    width: 72px; height: 72px;
    border-radius: 50%;
    background: linear-gradient(135deg, #2C2A25 0%, #4A4640 100%);
    color: #fff;
    font-size: 1.6rem;
    font-weight: 700;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    font-family: 'DM Serif Display', Georgia, serif;
    box-shadow: 0 4px 16px rgba(44,42,37,0.15);
  }
  .profile-edit-card {
    background: #fff;
    border: 1.5px solid #E8E4DC;
    border-radius: 16px;
    padding: 2rem 2.25rem;
    box-shadow: 0 2px 12px rgba(44,42,37,0.06);
  }
  .profile-scope .form-label,
  .profile-scope label {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: #9B9588;
    margin-bottom: 0.35rem;
    display: block;
  }
  .profile-scope .form-control,
  .profile-scope input[type="text"],
  .profile-scope input[type="email"] {
    border-radius: 10px;
    border: 1.5px solid #DDD9D1;
    font-family: 'Plus Jakarta Sans', sans-serif;
    padding: 0.6rem 0.875rem;
    font-size: 0.92rem;
    color: #1C1A16;
    width: 100%;
    background: #fff;
    transition: border-color 0.15s, box-shadow 0.15s;
    box-sizing: border-box;
  }
  .profile-scope .form-control:focus,
  .profile-scope input:focus {
    border-color: #2563eb;
    box-shadow: 0 0 0 3px rgba(37,99,235,0.1);
    outline: none;
  }
  .profile-error {
    background: #FEF2F2;
    color: #842029;
    border: 1.5px solid #FECDD3;
    border-radius: 10px;
    padding: 0.75rem 1rem;
    margin-bottom: 1.25rem;
    font-size: 0.88rem;
  }
  .btn-profile-save {
    background: #2563eb;
    color: #fff;
    border: none;
    border-radius: 50px;
    padding: 0.65rem 1.75rem;
    font-size: 0.92rem;
    font-weight: 700;
    cursor: pointer;
    font-family: 'Plus Jakarta Sans', sans-serif;
    transition: background 0.15s, box-shadow 0.15s;
  }
  .btn-profile-save:hover {
    background: #1d4ed8;
    box-shadow: 0 2px 8px rgba(37,99,235,0.25);
  }
  .btn-profile-cancel {
    font-size: 0.88rem;
    color: #9B9588;
    text-decoration: none;
    transition: color 0.12s;
  }
  .btn-profile-cancel:hover { color: #1C1A16; }
</style>
<% end %>

<div class="profile-scope">
  <div class="profile-edit-page">
    <div class="d-flex align-items-center gap-3 mb-2">
      <div class="profile-edit-avatar">
        <%= (@user.full_name&.first || @user.email.first).upcase %>
      </div>
      <div>
        <h1 class="profile-edit-heading">Modifier mon profil</h1>
        <div class="profile-edit-sub"><%= @user.email %></div>
      </div>
    </div>

    <%= form_with model: @user, url: profile_path, method: :patch, class: "profile-edit-card" do |f| %>
      <% if @user.errors.any? %>
        <div class="profile-error">
          <% @user.errors.full_messages.each do |msg| %>
            <div><%= msg %></div>
          <% end %>
        </div>
      <% end %>

      <div class="mb-3">
        <%= f.label :full_name, "Nom complet" %>
        <%= f.text_field :full_name, class: "form-control", placeholder: "Jean Dupont" %>
      </div>

      <div class="mb-3">
        <%= f.label :phone, "Téléphone" %>
        <%= f.text_field :phone, class: "form-control", placeholder: "+33 6 12 34 56 78" %>
      </div>

      <div class="mb-4">
        <%= f.label :location, "Localisation" %>
        <%= f.text_field :location, class: "form-control", placeholder: "Paris, France" %>
      </div>

      <div class="d-flex align-items-center justify-content-between">
        <%= link_to "Annuler", profile_path, class: "btn-profile-cancel" %>
        <%= f.submit "Enregistrer", class: "btn-profile-save" %>
      </div>
    <% end %>
  </div>
</div>
