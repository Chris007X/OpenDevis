<% content_for :title, "#{@room.name} — #{@room.project.name} — OpenDevis" %>
<% content_for :description, "Détail de la pièce #{@room.name} : dimensions, matériaux et coûts estimés." %>

<% content_for :head do %>
<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap');

  .rooms-scope {
    font-family: 'Plus Jakarta Sans', sans-serif;
  }

  .rooms-scope .room-tab {
    display: inline-block;
    padding: 0.38rem 1rem;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 500;
    text-decoration: none;
    border: 1.5px solid #E8E4DC;
    color: #4A4640;
    background: #fff;
    transition: border-color 0.12s, background 0.12s, color 0.12s;
    white-space: nowrap;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .rooms-scope .room-tab:hover { border-color: #DDD9D1; color: #2C2A25; }
  .rooms-scope .room-tab.active { border-color: #2563eb; background: #2563eb; color: #fff; }

  .rooms-scope .room-heading {
    font-family: 'DM Serif Display', serif;
    font-style: italic;
    font-size: 1.7rem;
    color: #1C1A16;
    margin: 0;
    line-height: 1.2;
  }

  .rooms-scope .eyebrow {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: #9B9588;
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
  }
  .rooms-scope .eyebrow::after {
    content: '';
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, #E8E4DC, transparent);
  }

  .rooms-scope .items-table-wrap {
    border: 1.5px solid #E8E4DC;
    border-radius: 14px;
    overflow: hidden;
  }
  .rooms-scope .items-table {
    width: 100%;
    border-collapse: collapse;
  }
  .rooms-scope .items-table th {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #9B9588;
    border-bottom: 1.5px solid #E8E4DC;
    padding: 0.65rem 0.85rem;
    background: #FAFAF7;
  }
  .rooms-scope .items-table td {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.88rem;
    color: #2C2A25;
    padding: 0.75rem 0.85rem;
    border-bottom: 1px solid #F0EDE8;
    vertical-align: middle;
  }
  .rooms-scope .items-table tr:last-child td { border-bottom: none; }
  .rooms-scope .items-table tbody tr:hover td { background: #FAFAF7; }
  .rooms-scope .total-row td {
    font-weight: 700;
    font-family: 'Plus Jakarta Sans', sans-serif;
    color: #1C1A16;
    background: #F5F3EE;
    border-top: 1.5px solid #E8E4DC;
  }
  .rooms-scope .category-separator td {
    background: #F8F6F2;
    border-bottom: 1px solid #E8E4DC;
    border-top: 1px solid #E8E4DC;
    padding: 0.45rem 0.85rem;
    font-size: 0.75rem;
    font-weight: 700;
    font-family: 'Plus Jakarta Sans', sans-serif;
    color: #4A4640;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .rooms-scope .category-separator .cat-color-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    margin-right: 0.5rem;
    vertical-align: middle;
  }
  .rooms-scope .back-link {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.82rem;
    color: #9B9588;
    text-decoration: none;
    letter-spacing: 0.02em;
  }
  .rooms-scope .back-link:hover { color: #4A4640; }

  .rooms-scope .delete-btn {
    background: none;
    border: none;
    color: #9B9588;
    cursor: pointer;
    font-size: 0.82rem;
    padding: 0;
    font-family: 'Plus Jakarta Sans', sans-serif;
    transition: color 0.12s;
  }
  .rooms-scope .delete-btn:hover { color: #842029; }

  .rooms-scope .empty-state {
    border: 1.5px solid #E8E4DC;
    border-radius: 14px;
    background: #fff;
    padding: 3rem 2rem;
    text-align: center;
  }
</style>
<% end %>

<div class="container py-4 rooms-scope" style="max-width: 1000px;">

  <%# ── Back link ───────────────────────────────────────────────────────── %>
  <%= link_to "← #{@room.project.location_zip.presence || "Projet"}",
        @room.project,
        class: "back-link" %>

  <%# ── Room tabs ───────────────────────────────────────────────────────── %>
  <% if @all_rooms.size > 1 %>
    <div class="d-flex flex-wrap gap-2 mt-3 mb-4">
      <% @all_rooms.each do |r| %>
        <%= link_to r.name, r,
              class: "room-tab #{"active" if r == @room}",
              data: { turbo_frame: "room_content" } %>
      <% end %>
    </div>
  <% else %>
    <div class="mt-3"></div>
  <% end %>

  <%# ── Room content (Turbo Frame) ─────────────────────────────────────── %>
  <%= turbo_frame_tag "room_content" do %>
    <div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-2">
      <div>
        <h2 class="room-heading"><%= @room.name %></h2>
        <div style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 0.83rem; color: #9B9588; margin-top: 5px;">
          <% dim = [@room.surface_sqm&.then { |v| "#{v.to_i} m²" },
                    @room.perimeter_lm&.then { |v| "périmètre #{v} ml" },
                    @room.wall_height_m&.then { |v| "h. #{v} m" }].compact %>
          <%= dim.any? ? dim.join(" · ") : "Aucune dimension renseignée" %>
        </div>
      </div>
      <div class="d-flex gap-2">
        <%= link_to "Modifier la pièce", edit_room_path(@room), class: "btn btn-ghost-od btn-sm" %>
        <%= link_to "+ Ajouter un poste", new_room_work_item_path(@room), class: "btn btn-dark-od btn-sm" %>
      </div>
    </div>

    <% if @work_items.any? %>
      <%
        room_total_ht  = @work_items.sum { |i| (i.quantity || 0) * (i.unit_price_exVAT || 0) }
        room_total_ttc = @work_items.sum { |i|
          exvat = (i.quantity || 0) * (i.unit_price_exVAT || 0)
          exvat * (1 + (i.vat_rate || 0) / 100.0)
        }
      %>

      <div class="eyebrow">Postes de travaux</div>

      <div class="table-responsive items-table-wrap">
        <table class="items-table">
          <thead>
            <tr>
              <th colspan="2">Désignation</th>
              <th class="text-end">Qté</th>
              <th>Unité</th>
              <th class="text-end">P.U. HT</th>
              <th class="text-end">TVA</th>
              <th class="text-end">Total HT</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <%
              category_colors = %w[#2663EB #E07A3A #2E7D32 #8E44AD #C0392B #16A085 #D4A017 #6C5B7B]
              grouped = @work_items.group_by(&:work_category)
              color_idx = 0
            %>
            <% grouped.each do |cat, items| %>
              <% color = category_colors[color_idx % category_colors.length]; color_idx += 1 %>
              <tr class="category-separator">
                <td colspan="8">
                  <span class="cat-color-dot" style="background: <%= color %>;"></span>
                  <%= cat&.name || "Autre" %>
                  <span style="font-weight: 400; color: #9B9588; margin-left: 0.5rem;">
                    (<%= pluralize(items.size, "poste") %>)
                  </span>
                </td>
              </tr>
              <% items.each do |item| %>
                <tr>
                  <td style="padding-left: 1.5rem;"><%= item.label %></td>
                  <td></td>
                  <td class="text-end"><%= item.quantity %></td>
                  <td><%= item.unit %></td>
                  <td class="text-end">
                    <% if item.unit_price_exVAT %>
                      <%= number_to_currency(item.unit_price_exVAT, unit: "€", format: "%n %u",
                            separator: ",", delimiter: "\u202F") %>
                    <% end %>
                  </td>
                  <td class="text-end"><%= item.vat_rate ? "#{item.vat_rate}%" : "—" %></td>
                  <td class="text-end">
                    <% line_total = (item.quantity || 0) * (item.unit_price_exVAT || 0) %>
                    <%= number_to_currency(line_total, unit: "€", format: "%n %u",
                          separator: ",", delimiter: "\u202F") %>
                  </td>
                  <td class="text-end" style="white-space: nowrap;">
                    <%= button_to "✕", item, method: :delete,
                          data: { turbo_confirm: "Supprimer ce poste ?" },
                          class: "delete-btn" %>
                  </td>
                </tr>
              <% end %>
            <% end %>
          </tbody>
          <tfoot>
            <tr class="total-row">
              <td colspan="6">Total <%= @room.name %></td>
              <td class="text-end">
                <%= number_to_currency(room_total_ht, unit: "€", format: "%n %u",
                      separator: ",", delimiter: "\u202F") %>
                <div style="font-size: 0.75rem; font-weight: 400; color: #9B9588;">
                  TTC :
                  <%= number_to_currency(room_total_ttc, unit: "€", format: "%n %u",
                        separator: ",", delimiter: "\u202F") %>
                </div>
              </td>
              <td></td>
            </tr>
          </tfoot>
        </table>
      </div>
    <% else %>
      <div class="empty-state">
        <div style="color: #9B9588; font-size: 0.88rem; margin-bottom: 1rem;">
          Aucun poste de travaux pour cette pièce.
        </div>
        <%= link_to "+ Ajouter le premier poste", new_room_work_item_path(@room),
              class: "btn btn-dark-od btn-sm" %>
      </div>
    <% end %>

    <%# Delete room link (less prominent) %>
    <div class="mt-3 text-end">
      <%= button_to "Supprimer la pièce", @room, method: :delete,
            data: { turbo_confirm: "Supprimer cette pièce et tous ses postes ?" },
            class: "btn btn-ghost-od btn-sm",
            style: "color: #842029; border-color: #F8D7DA;" %>
    </div>
  <% end %>

</div>
