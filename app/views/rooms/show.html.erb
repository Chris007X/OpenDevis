<% content_for :head do %>
<style>


  .room-tab {
    display: inline-block;
    padding: 0.4rem 1rem;
    border-radius: 20px;
    font-size: 0.88rem;
    font-weight: 500;
    text-decoration: none;
    border: 1.5px solid #C8C4BC;
    color: #4A4640;
    background: #fff;
    transition: border-color 0.12s, background 0.12s, color 0.12s;
    white-space: nowrap;
  }
  .room-tab:hover { border-color: #2C2A25; color: #2C2A25; }
  .room-tab.active { border-color: #2C2A25; background: #2C2A25; color: #fff; }

  .items-table th {
    font-size: 0.78rem;
    font-weight: 700;
    color: #4A4640;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border-bottom: 1px solid #C8C4BC;
    padding: 0.6rem 0.75rem;
    background: #FFFFFF;
  }
  .items-table td {
    font-size: 0.9rem;
    color: #2C2A25;
    padding: 0.75rem;
    border-bottom: 1px solid #EDEAE4;
    vertical-align: middle;
  }
  .items-table tr:last-child td { border-bottom: none; }
  .items-table tbody tr:hover td { background: #FFFFFF; }
  .total-row td {
    font-weight: 700;
    color: #2C2A25;
    background: #EDEAE4;
    border-top: 2px solid #C8C4BC;
  }
  .category-separator td {
    background: #F5F3EE;
    border-bottom: 2px solid #D8D4CA;
    border-top: 1px solid #D8D4CA;
    padding: 0.5rem 0.75rem;
    font-size: 0.82rem;
    font-weight: 700;
    color: #2C2A25;
    letter-spacing: 0.02em;
  }
  .category-separator .cat-color-dot {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    margin-right: 0.5rem;
    vertical-align: middle;
  }
</style>
<% end %>

<div class="container py-4" style="max-width: 1000px;">

  <%# ── Back link ───────────────────────────────────────────────────────── %>
  <%= link_to "← #{@room.project.location_zip.presence || "Projet"}",
        @room.project,
        style: "color: #4A4640; font-size: 0.85rem; text-decoration: none;" %>

  <%# ── Room tabs ───────────────────────────────────────────────────────── %>
  <% if @all_rooms.size > 1 %>
    <div class="d-flex flex-wrap gap-2 mt-3 mb-4">
      <% @all_rooms.each do |r| %>
        <%= link_to r.name, r,
              class: "room-tab #{"active" if r == @room}",
              data: { turbo_frame: "room_content" } %>
      <% end %>
    </div>
  <% else %>
    <div class="mt-3"></div>
  <% end %>

  <%# ── Room content (Turbo Frame) ─────────────────────────────────────── %>
  <%= turbo_frame_tag "room_content" do %>
    <div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-2">
      <div>
        <h2 style="font-size: 1.3rem; font-weight: 700; color: #2C2A25; margin: 0;">
          <%= @room.name %>
        </h2>
        <div style="font-size: 0.85rem; color: #4A4640; margin-top: 3px;">
          <% dim = [@room.surface_sqm&.then { |v| "#{v.to_i} m²" },
                    @room.perimeter_lm&.then { |v| "périmètre #{v} ml" },
                    @room.wall_height_m&.then { |v| "h. #{v} m" }].compact %>
          <%= dim.any? ? dim.join(" · ") : "Aucune dimension renseignée" %>
        </div>
      </div>
      <div class="d-flex gap-2">
        <%= link_to "Modifier la pièce", edit_room_path(@room), class: "btn btn-ghost-od btn-sm" %>
        <%= link_to "+ Ajouter un poste", new_room_work_item_path(@room), class: "btn btn-dark-od btn-sm" %>
      </div>
    </div>

    <% if @work_items.any? %>
      <%
        room_total_ht  = @work_items.sum { |i| (i.quantity || 0) * (i.unit_price_exVAT || 0) }
        room_total_ttc = @work_items.sum { |i|
          exvat = (i.quantity || 0) * (i.unit_price_exVAT || 0)
          exvat * (1 + (i.vat_rate || 0) / 100.0)
        }
      %>
      <div class="table-responsive">
        <table class="w-100 items-table" style="border-collapse: collapse; border: 1px solid #C8C4BC; border-radius: 10px; overflow: hidden;">
          <thead>
            <tr>
              <th colspan="2">Désignation</th>
              <th class="text-end">Qté</th>
              <th>Unité</th>
              <th class="text-end">P.U. HT</th>
              <th class="text-end">TVA</th>
              <th class="text-end">Total HT</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <%
              category_colors = %w[#2663EB #E07A3A #2E7D32 #8E44AD #C0392B #16A085 #D4A017 #6C5B7B]
              grouped = @work_items.group_by(&:work_category)
              color_idx = 0
            %>
            <% grouped.each do |cat, items| %>
              <% color = category_colors[color_idx % category_colors.length]; color_idx += 1 %>
              <tr class="category-separator">
                <td colspan="8">
                  <span class="cat-color-dot" style="background: <%= color %>;"></span>
                  <%= cat&.name || "Autre" %>
                  <span style="font-weight: 400; color: #4A4640; margin-left: 0.5rem;">
                    (<%= pluralize(items.size, "poste") %>)
                  </span>
                </td>
              </tr>
              <% items.each do |item| %>
                <tr>
                  <td style="padding-left: 1.5rem;"><%= item.label %></td>
                  <td></td>
                  <td class="text-end"><%= item.quantity %></td>
                  <td><%= item.unit %></td>
                  <td class="text-end">
                    <% if item.unit_price_exVAT %>
                      <%= number_to_currency(item.unit_price_exVAT, unit: "€", format: "%n %u",
                            separator: ",", delimiter: "\u202F") %>
                    <% end %>
                  </td>
                  <td class="text-end"><%= item.vat_rate ? "#{item.vat_rate}%" : "—" %></td>
                  <td class="text-end">
                    <% line_total = (item.quantity || 0) * (item.unit_price_exVAT || 0) %>
                    <%= number_to_currency(line_total, unit: "€", format: "%n %u",
                          separator: ",", delimiter: "\u202F") %>
                  </td>
                  <td class="text-end" style="white-space: nowrap;">
                    <%= button_to "✕", item, method: :delete,
                          data: { turbo_confirm: "Supprimer ce poste ?" },
                          style: "background: none; border: none; color: #4A4640; cursor: pointer; font-size: 0.9rem; padding: 0;" %>
                  </td>
                </tr>
              <% end %>
            <% end %>
          </tbody>
          <tfoot>
            <tr class="total-row">
              <td colspan="6">Total <%= @room.name %></td>
              <td class="text-end">
                <%= number_to_currency(room_total_ht, unit: "€", format: "%n %u",
                      separator: ",", delimiter: "\u202F") %>
                <div style="font-size: 0.75rem; font-weight: 400; color: #4A4640;">
                  TTC:
                  <%= number_to_currency(room_total_ttc, unit: "€", format: "%n %u",
                        separator: ",", delimiter: "\u202F") %>
                </div>
              </td>
              <td></td>
            </tr>
          </tfoot>
        </table>
      </div>
    <% else %>
      <div class="text-center py-5"
           style="border: 1px solid #C8C4BC; border-radius: 10px; background: #fff;">
        <div style="color: #4A4640; font-size: 0.9rem; margin-bottom: 1rem;">
          Aucun poste de travaux pour cette pièce.
        </div>
        <%= link_to "+ Ajouter le premier poste", new_room_work_item_path(@room),
              class: "btn btn-dark-od btn-sm" %>
      </div>
    <% end %>

    <%# Delete room link (less prominent) %>
    <div class="mt-3 text-end">
      <%= button_to "Supprimer la pièce", @room, method: :delete,
            data: { turbo_confirm: "Supprimer cette pièce et tous ses postes ?" },
            class: "btn btn-ghost-od btn-sm",
            style: "color: #842029; border-color: #F8D7DA;" %>
    </div>
  <% end %>

</div>
