<style>
  .od-navbar {
    background: #fff;
    border-bottom: 1px solid #E8E4DC;
    padding: 0 1rem;
    height: 58px;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .od-brand {
    font-size: 1.25rem;
    font-weight: 800;
    color: #2C2A25 !important;
    text-decoration: none;
    letter-spacing: -0.01em;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .od-brand:hover { color: #2C2A25 !important; }
  .od-nav-link {
    font-size: 0.9rem;
    font-weight: 500;
    color: #4A4640 !important;
    text-decoration: none;
    padding: 0.4rem 0.75rem;
    border-radius: 8px;
    transition: background 0.12s, color 0.12s;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .od-nav-link:hover { background: #EDEAE4; color: #2C2A25 !important; }
  .od-nav-link.active { color: #2C2A25 !important; font-weight: 600; }
  .od-avatar {
    width: 34px; height: 34px;
    border-radius: 50%;
    background: #2563eb;
    color: #fff;
    font-size: 0.82rem;
    font-weight: 700;
    display: flex; align-items: center; justify-content: center;
    text-decoration: none;
    cursor: pointer;
    border: none;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .od-avatar:hover { background: #1B4FC2; }
</style>

<nav class="navbar od-navbar d-flex align-items-center sticky-top">
  <div class="container-fluid d-flex align-items-center justify-content-between">

    <%# Brand %>
    <% if user_signed_in? %>
      <span class="od-brand me-4">Open<span style="color: #2563eb;">Devis</span></span>
    <% else %>
      <%= link_to root_path, class: "od-brand me-4" do %>
        Open<span style="color: #2563eb;">Devis</span>
      <% end %>
    <% end %>

    <%# Nav links (desktop) %>
    <% if user_signed_in? %>
      <div class="d-none d-sm-flex align-items-center gap-1 me-auto">
        <%= link_to "Projets", projects_path,
              class: "od-nav-link #{"active" if request.path.start_with?("/projects")}" %>
      </div>

      <%# Right side: notifications + new project + avatar %>
      <div class="d-flex align-items-center gap-3">
        <% unread_count = current_user.notifications.unread.count %>
        <div data-controller="notification-badge">
          <%= link_to notifications_path,
                style: "position: relative; color: #4A4640; text-decoration: none; line-height: 1;",
                title: "Notifications" do %>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
              <path d="M8 16a2 2 0 0 0 2-2H6a2 2 0 0 0 2 2zm.995-14.901a1 1 0 1 0-1.99 0A5.002 5.002 0 0 0 3 6c0 1.098-.5 6-2 7h14c-1.5-1-2-5.902-2-7 0-2.42-1.72-4.44-4.005-4.901z"/>
            </svg>
            <span data-notification-badge-target="count"
                  style="position: absolute; top: -5px; right: -6px;
                         background: #842029; color: #fff; font-size: 0.65rem; font-weight: 700;
                         width: 16px; height: 16px; border-radius: 50%;
                         display: <%= unread_count > 0 ? "inline-flex" : "none" %>; align-items: center; justify-content: center;">
              <%= unread_count > 9 ? "9+" : unread_count %>
            </span>
          <% end %>
        </div>

        <div class="dropdown">
          <button class="od-avatar" data-bs-toggle="dropdown" aria-expanded="false">
            <%= (current_user.full_name&.first || current_user.email.first).upcase %>
          </button>
          <ul class="dropdown-menu dropdown-menu-end" style="border: 1px solid #E8E4DC; border-radius: 10px; padding: 0.5rem; font-family: 'Plus Jakarta Sans', sans-serif;">
            <li>
              <span class="dropdown-item-text" style="font-size: 0.82rem; color: #4A4640; padding: 0.4rem 0.75rem;">
                <%= current_user.email %>
              </span>
            </li>
            <li><hr class="dropdown-divider" style="border-color: #C8C4BC; margin: 0.25rem 0;"></li>
            <li><%= link_to "Profil", profile_path, class: "dropdown-item", style: "font-size: 0.875rem; border-radius: 6px; font-family: 'Plus Jakarta Sans', sans-serif;" %></li>
            <li><%= link_to "Paramètres", edit_user_registration_path, class: "dropdown-item", style: "font-size: 0.875rem; border-radius: 6px; font-family: 'Plus Jakarta Sans', sans-serif;" %></li>
            <% if current_user.admin? %>
              <li><hr class="dropdown-divider" style="border-color: #C8C4BC; margin: 0.25rem 0;"></li>
              <li>
                <%= link_to analytics_dashboard_path, class: "dropdown-item d-flex align-items-center gap-2", style: "font-size: 0.875rem; border-radius: 6px; color: #2563EB; font-family: 'Plus Jakarta Sans', sans-serif;" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M4 11H2v3h2v-3zm5-4H7v7h2V7zm5-5v12h-2V2h2zm-2-1a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h2a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1h-2zM6 7a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v7a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1V7zm-5 4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1v-3z"/>
                  </svg>
                  Analytics
                <% end %>
              </li>
              <li>
                <%= link_to test_runs_path, class: "dropdown-item d-flex align-items-center gap-2", style: "font-size: 0.875rem; border-radius: 6px; color: #2563EB; font-family: 'Plus Jakarta Sans', sans-serif;" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M4 1.5H3a2 2 0 0 0-2 2V14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V3.5a2 2 0 0 0-2-2h-1v1h1a1 1 0 0 1 1 1V14a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V3.5a1 1 0 0 1 1-1h1v-1z"/>
                    <path d="M9.5 1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-3a.5.5 0 0 1-.5-.5v-1a.5.5 0 0 1 .5-.5h3zm-3-1A1.5 1.5 0 0 0 5 1.5v1A1.5 1.5 0 0 0 6.5 4h3A1.5 1.5 0 0 0 11 2.5v-1A1.5 1.5 0 0 0 9.5 0h-3z"/>
                  </svg>
                  Test Runs
                <% end %>
              </li>
            <% end %>
            <li><hr class="dropdown-divider" style="border-color: #C8C4BC; margin: 0.25rem 0;"></li>
            <li><%= link_to "Se déconnecter", destroy_user_session_path,
                      data: { turbo_method: :delete },
                      class: "dropdown-item",
                      style: "font-size: 0.875rem; border-radius: 6px; color: #842029; font-family: 'Plus Jakarta Sans', sans-serif;" %></li>
          </ul>
        </div>
      </div>

    <% else %>
      <div class="ms-auto d-flex gap-2">
        <% unless request.path == new_artisan_session_path || request.path == new_user_session_path %>
          <%= link_to "Se connecter", new_user_session_path, class: "od-nav-link" %>
        <% end %>
        <%= link_to "Créer un compte", new_user_registration_path,
              style: "background: #2C2A25; color: #fff; border-radius: 8px; padding: 0.4rem 0.9rem;
                      font-size: 0.85rem; font-weight: 500; text-decoration: none;" %>
      </div>
    <% end %>

  </div>
</nav>
