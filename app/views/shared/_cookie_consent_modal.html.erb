<div class="modal fade" id="cookiePreferencesModal" tabindex="-1" aria-labelledby="cookiePreferencesModalLabel" aria-hidden="true"
     data-cookie-consent-target="modal">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content" style="border-radius: 12px; border: 1.5px solid #C8C4BC; font-family: 'Plus Jakarta Sans', sans-serif;">
      <div class="modal-header" style="border-bottom: 1px solid #E8E4DC; padding: 1.25rem 1.5rem;">
        <h5 class="modal-title" id="cookiePreferencesModalLabel" style="font-weight: 700; font-size: 1.1rem; color: #2C2A25;">
          <%= t("cookie_consent.modal.title") %>
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
      </div>
      <div class="modal-body" style="padding: 1.5rem;">
        <p style="font-size: 0.85rem; color: #4A4640; margin-bottom: 1.25rem;">
          <%= t("cookie_consent.modal.description") %>
        </p>

        <%# ── Essential cookies (always on) ── %>
        <div class="d-flex align-items-start justify-content-between mb-3 pb-3" style="border-bottom: 1px solid #E8E4DC;">
          <div class="me-3">
            <p style="font-weight: 600; font-size: 0.9rem; color: #2C2A25; margin-bottom: 0.15rem;">
              <%= t("cookie_consent.modal.essential.title") %>
            </p>
            <p style="font-size: 0.8rem; color: #9B9588; margin-bottom: 0;">
              <%= t("cookie_consent.modal.essential.description") %>
            </p>
          </div>
          <div class="d-flex align-items-center gap-2 flex-shrink-0">
            <span style="font-size: 0.75rem; color: #2563eb; font-weight: 600; white-space: nowrap;">
              <%= t("cookie_consent.modal.essential.badge") %>
            </span>
            <div class="form-check form-switch mb-0">
              <input class="form-check-input" type="checkbox" checked disabled
                     style="cursor: not-allowed; opacity: 0.7;">
            </div>
          </div>
        </div>

        <%# ── Analytics cookies ── %>
        <div class="d-flex align-items-start justify-content-between mb-3 pb-3" style="border-bottom: 1px solid #E8E4DC;">
          <div class="me-3">
            <p style="font-weight: 600; font-size: 0.9rem; color: #2C2A25; margin-bottom: 0.15rem;">
              <%= t("cookie_consent.modal.analytics.title") %>
            </p>
            <p style="font-size: 0.8rem; color: #9B9588; margin-bottom: 0;">
              <%= t("cookie_consent.modal.analytics.description") %>
            </p>
          </div>
          <div class="form-check form-switch mb-0 flex-shrink-0">
            <input class="form-check-input" type="checkbox"
                   data-cookie-consent-target="analyticsToggle">
          </div>
        </div>

        <%# ── Marketing cookies ── %>
        <div class="d-flex align-items-start justify-content-between">
          <div class="me-3">
            <p style="font-weight: 600; font-size: 0.9rem; color: #2C2A25; margin-bottom: 0.15rem;">
              <%= t("cookie_consent.modal.marketing.title") %>
            </p>
            <p style="font-size: 0.8rem; color: #9B9588; margin-bottom: 0;">
              <%= t("cookie_consent.modal.marketing.description") %>
            </p>
          </div>
          <div class="form-check form-switch mb-0 flex-shrink-0">
            <input class="form-check-input" type="checkbox"
                   data-cookie-consent-target="marketingToggle">
          </div>
        </div>
      </div>
      <div class="modal-footer" style="border-top: 1px solid #E8E4DC; padding: 1rem 1.5rem;">
        <button type="button" class="btn btn-ghost-od btn-sm"
                data-action="cookie-consent#rejectAll">
          <%= t("cookie_consent.modal.reject_all") %>
        </button>
        <button type="button" class="btn btn-dark-od btn-sm"
                data-action="cookie-consent#savePreferences">
          <%= t("cookie_consent.modal.save") %>
        </button>
      </div>
    </div>
  </div>
</div>
