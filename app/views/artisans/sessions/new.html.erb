<div class="auth-scope" style="min-height: calc(100vh - 56px); display: flex; align-items: center; justify-content: center; padding: 40px 20px; background: #FAFAF7;">
  <style>
    .auth-scope * { font-family: 'Plus Jakarta Sans', sans-serif; }
    .auth-card {
      background: #fff;
      border: 1.5px solid #E8E4DC;
      border-radius: 16px;
      padding: 2.5rem 2.25rem;
      box-shadow: 0 2px 12px rgba(44,42,37,0.06);
      width: 100%;
      max-width: 440px;
    }
    .auth-wordmark {
      font-size: 1.05rem;
      font-weight: 800;
      color: #2C2A25;
      text-decoration: none;
      letter-spacing: -0.3px;
    }
    .auth-heading {
      font-family: 'DM Serif Display', Georgia, serif;
      font-style: italic;
      font-size: 1.9rem;
      font-weight: 400;
      color: #1C1A16;
      margin: 0 0 0.25rem;
      line-height: 1.15;
    }
    .auth-subheading {
      color: #9B9588;
      font-size: 0.88rem;
      margin-bottom: 1.75rem;
    }
    .auth-form-label {
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.13em;
      text-transform: uppercase;
      color: #9B9588;
      display: block;
      margin-bottom: 0.35rem;
    }
    .auth-input {
      width: 100%;
      border: 1.5px solid #DDD9D1;
      border-radius: 10px;
      padding: 0.6rem 0.875rem;
      font-size: 0.92rem;
      font-family: 'Plus Jakarta Sans', sans-serif;
      color: #1C1A16;
      background: #fff;
      outline: none;
      box-sizing: border-box;
      transition: border-color 0.15s, box-shadow 0.15s;
    }
    .auth-input:focus {
      border-color: #2563eb;
      box-shadow: 0 0 0 3px rgba(37,99,235,0.1);
    }
    .auth-submit-btn {
      width: 100%;
      background: #2563eb;
      color: #fff;
      border: none;
      border-radius: 50px;
      padding: 0.7rem 1.5rem;
      font-size: 0.95rem;
      font-weight: 700;
      cursor: pointer;
      font-family: 'Plus Jakarta Sans', sans-serif;
      transition: background 0.15s, box-shadow 0.15s;
      margin-top: 0.25rem;
    }
    .auth-submit-btn:hover {
      background: #1d4ed8;
      box-shadow: 0 2px 8px rgba(37,99,235,0.25);
    }
    .auth-divider { height: 1px; background: #E8E4DC; margin: 1.25rem 0; }
    .auth-link {
      color: #4A4640;
      font-size: 0.83rem;
      text-decoration: none;
      transition: color 0.12s;
    }
    .auth-link:hover { color: #1C1A16; text-decoration: underline; }
    .auth-client-btn {
      display: block;
      width: 100%;
      text-align: center;
      border: 1.5px solid #E8E4DC;
      border-radius: 50px;
      padding: 0.6rem 1rem;
      font-size: 0.88rem;
      font-weight: 600;
      color: #4A4640;
      text-decoration: none;
      transition: border-color 0.15s, color 0.15s;
      font-family: 'Plus Jakarta Sans', sans-serif;
      box-sizing: border-box;
    }
    .auth-client-btn:hover { border-color: #2563eb; color: #2563eb; }
    .artisan-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: #F5F0E8;
      border: 1px solid #E8E4DC;
      border-radius: 50px;
      padding: 4px 12px;
      font-size: 0.73rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #4A4640;
      margin-bottom: 1.25rem;
    }
  </style>

  <div style="width: 100%; max-width: 440px;">
    <div class="text-center mb-4">
      <%= link_to "OpenDevis", root_path, class: "auth-wordmark" %>
    </div>

    <div class="auth-card">
      <div class="text-center mb-3">
        <span class="artisan-badge">
          <i class="fas fa-hard-hat" style="font-size: 0.7rem;"></i>
          Espace artisan
        </span>
      </div>

      <h1 class="auth-heading">Connexion artisan</h1>
      <p class="auth-subheading">Accédez à votre tableau de bord pour gérer vos demandes de devis.</p>

      <%= form_with url: artisan_session_path, method: :post, data: { turbo: false } do |f| %>
        <div style="margin-bottom: 1.1rem;">
          <label class="auth-form-label">Adresse e-mail</label>
          <input type="email" name="artisan[email]" autofocus autocomplete="email"
                 placeholder="votre@email.com"
                 class="auth-input">
        </div>
        <div style="margin-bottom: 1.5rem;">
          <label class="auth-form-label">Mot de passe</label>
          <input type="password" name="artisan[password]" autocomplete="current-password"
                 placeholder="••••••••"
                 class="auth-input">
        </div>
        <button type="submit" class="auth-submit-btn">Se connecter</button>
      <% end %>

      <div class="text-center mt-3">
        <a href="<%= new_artisan_password_path %>" class="auth-link">Mot de passe oublié ?</a>
      </div>

      <div class="auth-divider mt-3"></div>

      <a href="<%= new_user_session_path %>" class="auth-client-btn">
        Accéder à l'espace client →
      </a>
    </div>
  </div>
</div>
