<div class="container py-4">
  <div class="mb-4">
    <%= link_to "← Toutes les catégories", work_categories_path, class: "btn btn-outline-secondary btn-sm" %>
  </div>

  <h1 class="mb-4"><%= @work_category.name %></h1>

  <% if @materials.any? %>
    <table class="table table-hover align-middle">
      <thead class="table-light">
        <tr>
          <th>Marque</th>
          <th>Référence</th>
          <th>Unité</th>
          <th>Prix HT</th>
          <th>TVA %</th>
        </tr>
      </thead>
      <tbody>
        <% @materials.each do |material| %>
          <tr>
            <td><%= material.brand %></td>
            <td><%= material.reference %></td>
            <td><%= material.unit %></td>
            <td><%= number_to_currency(material.public_price_exVAT, unit: "€", separator: ",", delimiter: " ") %></td>
            <td><%= material.vat_rate&.then { |v| "#{v} %" } %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-muted">Aucun matériau dans cette catégorie.</p>
  <% end %>
</div>
