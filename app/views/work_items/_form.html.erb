<%= simple_form_for [@room || @work_item.room, @work_item] do |f| %>
  <%= f.error_notification %>

  <div class="row g-3">
    <div class="col-12">
      <%= f.input :label, label: "Désignation" %>
    </div>
    <div class="col-md-6">
      <%= f.association :work_category, collection: @work_categories, label_method: :name, value_method: :id, include_blank: "— Sélectionner une catégorie —", label: "Catégorie" %>
    </div>
    <div class="col-md-6">
      <%= f.association :material, collection: @materials, label_method: ->(m) { "#{m.brand} #{m.reference} (#{m.work_category.name})" }, value_method: :id, include_blank: "— Sélectionner un matériau —", label: "Matériau" %>
    </div>
    <div class="col-md-4">
      <%= f.input :quantity, label: "Quantité" %>
    </div>
    <div class="col-md-4">
      <%= f.input :unit, label: "Unité" %>
    </div>
    <div class="col-md-4">
      <%= f.input :unit_price_exVAT, label: "Prix unitaire HT" %>
    </div>
    <div class="col-md-6">
      <%= f.input :vat_rate, label: "Taux TVA (%)" %>
    </div>
    <div class="col-md-6">
      <%= f.input :standing_level, label: "Niveau de gamme" %>
    </div>
  </div>

  <div class="mt-3">
    <%= f.button :submit, class: "btn btn-primary" %>
    <%= link_to "Annuler", (@room || @work_item.room), class: "btn btn-outline-secondary ms-2" %>
  </div>
<% end %>
