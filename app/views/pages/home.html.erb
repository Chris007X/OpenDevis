<% content_for :title, "OpenDevis — Devis de rénovation gratuit et instantané" %>
<% content_for :description, "Estimez le coût de vos travaux de rénovation en quelques minutes. OpenDevis génère des devis détaillés par pièce, gratuit et sans inscription." %>
<% content_for :keywords, "devis rénovation, estimation travaux, coût rénovation appartement, prix travaux maison, devis gratuit, rénovation cuisine, rénovation salle de bain" %>

<% content_for :head do %>
  <style>
    .home-scope * { font-family: 'Plus Jakarta Sans', sans-serif; }
    .home-scope h1, .home-scope h2 {
      font-family: 'DM Serif Display', Georgia, serif;
    }

    /* ── HERO ── */
    .home-hero {
      background: linear-gradient(135deg, #FAFAF7 0%, #F5F0E8 100%);
      padding: 5rem 0 4rem;
      position: relative;
      overflow: hidden;
    }
    .home-hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 70% 60% at 60% 40%, rgba(37,99,235,0.04) 0%, transparent 70%);
      pointer-events: none;
    }
    .hero-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: #fff;
      border: 1.5px solid #E8E4DC;
      border-radius: 50px;
      padding: 6px 14px;
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: #4A4640;
      margin-bottom: 1.5rem;
      box-shadow: 0 1px 4px rgba(44,42,37,0.06);
    }
    .hero-eyebrow-dot {
      width: 7px; height: 7px;
      border-radius: 50%;
      background: #22C55E;
      box-shadow: 0 0 0 3px rgba(34,197,94,0.2);
      animation: pulse-dot 2s infinite;
    }
    @keyframes pulse-dot {
      0%, 100% { box-shadow: 0 0 0 3px rgba(34,197,94,0.2); }
      50% { box-shadow: 0 0 0 5px rgba(34,197,94,0.1); }
    }
    .hero-title {
      font-family: 'DM Serif Display', Georgia, serif;
      font-size: clamp(2.4rem, 5vw, 3.5rem);
      font-weight: 400;
      color: #1C1A16;
      line-height: 1.1;
      margin-bottom: 1.25rem;
    }
    .hero-title em {
      font-style: italic;
      color: #2563eb;
    }
    .hero-lead {
      font-size: 1.05rem;
      color: #4A4640;
      line-height: 1.7;
      margin-bottom: 2rem;
      max-width: 520px;
    }
    .hero-social-proof {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 2.25rem;
    }
    .hero-avatars {
      display: flex;
    }
    .hero-avatar {
      width: 34px; height: 34px;
      border-radius: 50%;
      border: 2.5px solid #FAFAF7;
      display: flex; align-items: center; justify-content: center;
      font-size: 0.78rem;
      font-weight: 700;
      color: #fff;
      margin-left: -8px;
    }
    .hero-avatars .hero-avatar:first-child { margin-left: 0; }
    .hero-stars { color: #F59E0B; font-size: 0.8rem; letter-spacing: 1px; margin-bottom: 2px; }
    .hero-social-label { font-size: 0.82rem; color: #4A4640; margin: 0; }
    .hero-cta {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: #2563eb;
      color: #fff;
      border: none;
      border-radius: 50px;
      padding: 0.875rem 2rem;
      font-size: 1rem;
      font-weight: 700;
      text-decoration: none;
      font-family: 'Plus Jakarta Sans', sans-serif;
      transition: background 0.15s, box-shadow 0.15s, transform 0.15s;
      box-shadow: 0 4px 16px rgba(37,99,235,0.3);
    }
    .hero-cta:hover {
      background: #1d4ed8;
      box-shadow: 0 6px 20px rgba(37,99,235,0.4);
      transform: translateY(-1px);
      color: #fff;
    }

    /* ── Hero words loader (keep existing animation) ── */
    .hero-words-loader {
      display: inline-block;
      position: relative;
      overflow: hidden;
      vertical-align: bottom;
      height: 1.15em;
      min-width: 140px;
    }
    .hero-words {
      display: flex;
      flex-direction: column;
      animation: slideWords 6s infinite;
    }
    .hero-word {
      display: block;
      color: #2563eb;
      font-style: italic;
      line-height: 1.1;
    }
    @keyframes slideWords {
      0%   { transform: translateY(0); }
      20%  { transform: translateY(0); }
      25%  { transform: translateY(-1.1em); }
      45%  { transform: translateY(-1.1em); }
      50%  { transform: translateY(-2.2em); }
      70%  { transform: translateY(-2.2em); }
      75%  { transform: translateY(-3.3em); }
      95%  { transform: translateY(-3.3em); }
      100% { transform: translateY(0); }
    }

    /* ── Hero mock card ── */
    .hero-card-wrap {
      position: relative;
      display: inline-block;
    }
    .hero-card-float {
      animation: floatCard 4s ease-in-out infinite;
    }
    @keyframes floatCard {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-10px); }
    }
    .hero-card {
      background: #fff;
      border: 1.5px solid #E8E4DC;
      border-radius: 20px;
      padding: 1.75rem;
      box-shadow: 0 16px 48px rgba(44,42,37,0.14), 0 2px 8px rgba(44,42,37,0.06);
      width: 340px;
      max-width: 100%;
    }
    .hero-card-label { font-size: 0.68rem; font-weight: 700; letter-spacing: 0.13em; text-transform: uppercase; color: #9B9588; margin: 0 0 4px; }
    .hero-card-title { font-weight: 800; color: #1C1A16; font-size: 1.05rem; margin: 0; }
    .hero-card-icon {
      width: 40px; height: 40px;
      background: #EFF6FF;
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
    }
    .hero-item {
      display: flex; align-items: center; justify-content: space-between;
      padding: 0.7rem 0;
      border-bottom: 1px solid #F0EDE8;
    }
    .hero-item:last-child { border-bottom: none; }
    .hero-item-icon {
      width: 34px; height: 34px;
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      font-size: 0.85rem;
      flex-shrink: 0;
    }
    .hero-item-icon--orange { background: #FEF3C7; color: #D97706; }
    .hero-item-icon--cyan { background: #DBEAFE; color: #2563eb; }
    .hero-item-name { font-weight: 600; color: #1C1A16; font-size: 0.88rem; margin: 0 0 1px; }
    .hero-item-sub { font-size: 0.75rem; color: #9B9588; margin: 0; }
    .hero-item-price { font-weight: 700; color: #1C1A16; font-size: 0.92rem; white-space: nowrap; }
    .hero-card-footer {
      background: #F5F0E8;
      border-radius: 12px;
      padding: 1rem 1.1rem;
      margin-top: 1rem;
      display: flex; align-items: center; justify-content: space-between;
    }
    .hero-footer-label { font-size: 0.72rem; color: #9B9588; margin: 0 0 2px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; }
    .hero-footer-total { font-size: 1.35rem; font-weight: 800; color: #1C1A16; margin: 0; }
    .hero-footer-ttc { font-size: 0.72rem; color: #9B9588; font-weight: 600; }
    .hero-check-btn {
      width: 36px; height: 36px;
      background: #22C55E;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      color: #fff;
      font-size: 0.9rem;
    }

    /* ── FEATURES SECTION ── */
    .features-section {
      padding: 5rem 0;
      background: #fff;
    }
    .section-eyebrow {
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.13em;
      text-transform: uppercase;
      color: #2563eb;
      margin-bottom: 0.75rem;
    }
    .section-heading {
      font-family: 'DM Serif Display', Georgia, serif;
      font-size: clamp(1.75rem, 3.5vw, 2.5rem);
      font-weight: 400;
      color: #1C1A16;
      line-height: 1.15;
      margin-bottom: 0.75rem;
    }
    .section-lead { color: #4A4640; font-size: 1rem; max-width: 500px; margin: 0 auto; }
    .feature-card-od {
      background: #FAFAF7;
      border: 1.5px solid #E8E4DC;
      border-radius: 16px;
      padding: 1.75rem;
      height: 100%;
      transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
    }
    .feature-card-od:hover {
      border-color: #DDD9D1;
      box-shadow: 0 4px 16px rgba(44,42,37,0.08);
      transform: translateY(-2px);
    }
    .feature-icon-wrap {
      width: 48px; height: 48px;
      border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 1rem;
      font-size: 1.2rem;
    }
    .feature-icon-wrap--blue { background: #EFF6FF; color: #2563eb; }
    .feature-icon-wrap--amber { background: #FEF3C7; color: #D97706; }
    .feature-icon-wrap--green { background: #DCFCE7; color: #15803D; }
    .feature-title { font-weight: 800; color: #1C1A16; font-size: 1rem; margin-bottom: 0.5rem; }
    .feature-desc { color: #4A4640; font-size: 0.88rem; line-height: 1.65; margin: 0; }

    /* ── HOW IT WORKS ── */
    .how-section {
      padding: 5rem 0;
      background: #FAFAF7;
    }
    .step-circle {
      width: 48px; height: 48px;
      border-radius: 50%;
      background: #2563eb;
      color: #fff;
      font-weight: 800;
      font-size: 1.1rem;
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 1rem;
      box-shadow: 0 4px 12px rgba(37,99,235,0.25);
    }
    .step-title { font-weight: 700; color: #1C1A16; font-size: 0.95rem; margin-bottom: 0.4rem; }
    .step-desc { color: #4A4640; font-size: 0.85rem; line-height: 1.6; }
    .step-arrow { color: #DDD9D1; font-size: 1.5rem; }

    /* ── CTA SECTION ── */
    .cta-section {
      padding: 5rem 0;
      background: linear-gradient(135deg, #1C1A16 0%, #2C2A25 100%);
      position: relative;
      overflow: hidden;
    }
    .cta-section::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 60% 80% at 50% 50%, rgba(37,99,235,0.15) 0%, transparent 70%);
      pointer-events: none;
    }
    .cta-heading {
      font-family: 'DM Serif Display', Georgia, serif;
      font-size: clamp(1.75rem, 3.5vw, 2.5rem);
      font-weight: 400;
      color: #fff;
      line-height: 1.15;
      margin-bottom: 0.75rem;
    }
    .cta-heading em { font-style: italic; color: #93C5FD; }
    .cta-lead { color: rgba(255,255,255,0.6); font-size: 1rem; margin-bottom: 2rem; }
    .btn-cta-primary {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: #2563eb;
      color: #fff;
      border: none;
      border-radius: 50px;
      padding: 0.875rem 2rem;
      font-size: 1rem;
      font-weight: 700;
      text-decoration: none;
      font-family: 'Plus Jakarta Sans', sans-serif;
      transition: background 0.15s, box-shadow 0.15s;
      box-shadow: 0 4px 16px rgba(37,99,235,0.4);
    }
    .btn-cta-primary:hover {
      background: #1d4ed8;
      box-shadow: 0 6px 20px rgba(37,99,235,0.5);
      color: #fff;
    }
    .cta-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.15);
      border-radius: 50px;
      padding: 5px 14px;
      font-size: 0.78rem;
      color: rgba(255,255,255,0.7);
      font-weight: 600;
      margin-top: 1.25rem;
    }
  </style>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "OpenDevis",
    "url": "https://opendevis.com",
    "description": "Estimez le coût de vos travaux de rénovation en quelques minutes. OpenDevis génère des devis détaillés par pièce, gratuit et sans inscription.",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "inLanguage": "fr-FR",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "EUR",
      "description": "Gratuit pour toujours. Sans carte bancaire."
    }
  }
  </script>
<% end %>

<div class="home-scope">

  <%# ── HERO ── %>
  <section class="home-hero">
    <div class="container">
      <div class="row align-items-center g-5">

        <%# Colonne gauche : texte %>
        <div class="col-lg-6">
          <div class="hero-eyebrow">
            <span class="hero-eyebrow-dot"></span>
            Reprenez le contrôle de votre rénovation
          </div>

          <h1 class="hero-title">
            Obtenez le devis de vos
            <span class="hero-words-loader">
              <span class="hero-words">
                <span class="hero-word">travaux</span>
                <span class="hero-word">rénovations</span>
                <span class="hero-word">isolations</span>
                <span class="hero-word">travaux</span>
              </span>
            </span><br>
            facilement et <em>instantanément.</em>
          </h1>

          <p class="hero-lead">
            Visitez, chiffrez, décidez l'esprit léger. OpenDevis vous guide pas à pas pour estimer chaque poste de dépense, à votre rythme et en totale autonomie, sans dépendre de l'agenda de quiconque.
          </p>

          <%# Avis clients %>
          <div class="hero-social-proof">
            <div class="hero-avatars">
              <div class="hero-avatar" style="background: #F59E0B;">S</div>
              <div class="hero-avatar" style="background: #22C55E;">M</div>
              <div class="hero-avatar" style="background: #3B82F6;">A</div>
              <div class="hero-avatar" style="background: #EF4444;">L</div>
            </div>
            <div>
              <div class="hero-stars">★★★★★</div>
              <p class="hero-social-label">
                <strong>4,9/5</strong> · Plébiscité par +200 propriétaires
              </p>
            </div>
          </div>

          <% if user_signed_in? %>
            <%= link_to projects_path, class: "hero-cta" do %>
              Mes projets <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 448 512" fill="currentColor" style="vertical-align:-0.1em"><path d="M438.6 278.6c12.5-12.5 12.5-32.8 0-45.3l-160-160c-12.5-12.5-32.8-12.5-45.3 0s-12.5 32.8 0 45.3L338.8 224 32 224c-17.7 0-32 14.3-32 32s14.3 32 32 32l306.7 0L233.4 393.4c-12.5 12.5-12.5 32.8 0 45.3s32.8 12.5 45.3 0l160-160z"/></svg>
            <% end %>
          <% else %>
            <%= link_to new_user_registration_path, class: "hero-cta" do %>
              Obtenir mon estimation <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 448 512" fill="currentColor" style="vertical-align:-0.1em"><path d="M438.6 278.6c12.5-12.5 12.5-32.8 0-45.3l-160-160c-12.5-12.5-32.8-12.5-45.3 0s-12.5 32.8 0 45.3L338.8 224 32 224c-17.7 0-32 14.3-32 32s14.3 32 32 32l306.7 0L233.4 393.4c-12.5 12.5-12.5 32.8 0 45.3s32.8 12.5 45.3 0l160-160z"/></svg>
            <% end %>
          <% end %>
        </div>

        <%# Colonne droite : carte mock UI %>
        <div class="col-lg-6 d-flex justify-content-center justify-content-lg-end">
          <div class="hero-card-wrap">
            <div class="hero-card-float">
              <div class="hero-card">
                <div class="d-flex justify-content-between align-items-center mb-4">
                  <div>
                    <p class="hero-card-label">Projet en cours</p>
                    <p class="hero-card-title">Appartement Paris 11e</p>
                  </div>
                  <div class="hero-card-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 576 512" fill="currentColor"><path d="M575.8 255.5c0 18-15 32.1-32 32.1h-32l.7 160.2c0 2.7-.2 5.4-.5 8.1V472c0 22.1-17.9 40-40 40H456c-1.1 0-2.2 0-3.3-.1c-1.4 .1-2.8 .1-4.2 .1H416 392c-22.1 0-40-17.9-40-40V448 384c0-17.7-14.3-32-32-32H256c-17.7 0-32 14.3-32 32v64 24c0 22.1-17.9 40-40 40H160 128.1c-1.4 0-2.8 0-4.2-.1c-1.1 .1-2.2 .1-3.3 .1H80c-22.1 0-40-17.9-40-40V360c0-.9 0-1.9 .1-2.8V287.6H32c-18 0-32-14-32-32.1c0-9 3-17 10-24L266.4 8c7-7 15-8 22-8s15 2 21 7L564.8 231.5c8 7 12 15 11 24z"/></svg>
                  </div>
                </div>

                <div>
                  <div class="hero-item">
                    <div class="d-flex align-items-center gap-3">
                      <div class="hero-item-icon hero-item-icon--orange">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 448 512" fill="currentColor"><path d="M416 0C400 0 288 32 288 176V288c0 35.3 28.7 64 64 64h32V480c0 17.7 14.3 32 32 32s32-14.3 32-32V352 240 32c0-17.7-14.3-32-32-32zM64 16C64 7.8 57.9 1 49.7 .1S34.2 4.6 32.4 12.5L2.1 148.8C.7 155.1 0 161.5 0 167.9c0 45.9 35.1 83.6 80 87.7V480c0 17.7 14.3 32 32 32s32-14.3 32-32V255.6c44.9-4.1 80-41.8 80-87.7c0-6.4-.7-12.8-2.1-19.1L191.6 12.5c-1.8-8-9.3-13.3-17.4-12.4S160 7.8 160 16V150.2c0 5.4-4.4 9.8-9.8 9.8c-5.1 0-9.3-3.9-9.8-9L128 16c-.1-8.8-7.3-16-16.1-16s-16 7.2-16.1 16l-11.4 135c-.5 5.1-4.7 9-9.8 9c-5.4 0-9.8-4.4-9.8-9.8L64 16z"/></svg>
                      </div>
                      <div>
                        <p class="hero-item-name">Cuisine complète</p>
                        <p class="hero-item-sub">12m² • Dépose + Pose</p>
                      </div>
                    </div>
                    <p class="hero-item-price">6 450 €</p>
                  </div>

                  <div class="hero-item">
                    <div class="d-flex align-items-center gap-3">
                      <div class="hero-item-icon hero-item-icon--cyan">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 512 512" fill="currentColor"><path d="M96 77.3c0-7.3 5.9-13.3 13.3-13.3c3.5 0 6.9 1.4 9.4 3.9l14.9 14.9C130 91.8 128 101.7 128 112c0 19.9 7.2 38 19.2 52c-5.3 9.2-4 21.1 3.8 29c9.4 9.4 24.6 9.4 33.9 0L289 89c9.4-9.4 9.4-24.6 0-33.9c-7.9-7.9-19.8-9.1-29-3.8C246 39.2 227.9 32 208 32c-10.3 0-20.2 2-29.2 5.5L163.9 22.6C149.4 8.1 129.7 0 109.3 0C66.6 0 32 34.6 32 77.3V256c-17.7 0-32 14.3-32 32s14.3 32 32 32H480c17.7 0 32-14.3 32-32s-14.3-32-32-32H96V77.3zM32 352v16c0 28.4 10.8 54.3 28.3 73.8C37.3 453.1 32 464 32 476c0 19.9 16.1 36 36 36s36-16.1 36-36H408c0 19.9 16.1 36 36 36s36-16.1 36-36c0-12-5.3-22.9-13.7-30.2C484 426.3 480 414.8 480 402.7V352H32z"/></svg>
                      </div>
                      <div>
                        <p class="hero-item-name">Salle de bain</p>
                        <p class="hero-item-sub">5m² • Rafraîchissement</p>
                      </div>
                    </div>
                    <p class="hero-item-price">3 200 €</p>
                  </div>
                </div>

                <div class="hero-card-footer">
                  <div>
                    <p class="hero-footer-label">Enveloppe globale estimée</p>
                    <p class="hero-footer-total">9 650 € <span class="hero-footer-ttc">TTC</span></p>
                  </div>
                  <div class="hero-check-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 448 512" fill="currentColor"><path d="M438.6 105.4c12.5 12.5 12.5 32.8 0 45.3l-256 256c-12.5 12.5-32.8 12.5-45.3 0l-128-128c-12.5-12.5-12.5-32.8 0-45.3s32.8-12.5 45.3 0L160 338.7 393.4 105.4c12.5-12.5 32.8-12.5 45.3 0z"/></svg>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <%# ── FONCTIONNALITÉS ── %>
  <section class="features-section">
    <div class="container">
      <div class="text-center mb-5">
        <div class="section-eyebrow">Fonctionnalités</div>
        <h2 class="section-heading">Tout ce qu'il faut pour<br>chiffrer un chantier</h2>
        <p class="section-lead">De la première pièce au devis final, OpenDevis gère la structure.</p>
      </div>

      <div class="row g-4">
        <div class="col-md-4">
          <div class="feature-card-od">
            <div class="feature-icon-wrap feature-icon-wrap--blue">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 576 512" fill="currentColor"><path d="M384 480h48c11.4 0 21.9-6 27.6-15.9l112-192c5.8-9.9 5.8-22.1 .1-32.1S555.5 224 544 224H144c-11.4 0-21.9 6-27.6 15.9L48 357.1V96c0-8.8 7.2-16 16-16H181.5c4.2 0 8.3 1.7 11.3 4.7l26.5 26.5c21 21 49.5 32.8 79.2 32.8H416c8.8 0 16 7.2 16 16v32h48V160c0-35.3-28.7-64-64-64H298.5c-17 0-33.3-6.7-45.3-18.7L226.7 50.7c-12-12-28.3-18.7-45.3-18.7H64C28.7 32 0 60.7 0 96V416c0 35.3 28.7 64 64 64H87.7 384z"/></svg>
            </div>
            <div class="feature-title">Projets</div>
            <p class="feature-desc">
              Organisez chaque chantier comme un projet. Suivez le statut (brouillon, envoyé, accepté), la surface, la classe énergétique et le lien du bien — tout au même endroit.
            </p>
          </div>
        </div>

        <div class="col-md-4">
          <div class="feature-card-od">
            <div class="feature-icon-wrap feature-icon-wrap--amber">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 512 512" fill="currentColor"><path d="M368 32H144C135.2 32 128 39.2 128 48v16H64c-17.7 0-32 14.3-32 32V416c0 17.7 14.3 32 32 32h64v16c0 8.8 7.2 16 16 16H368c8.8 0 16-7.2 16-16V416h64c17.7 0 32-14.3 32-32V96c0-17.7-14.3-32-32-32H384V48c0-8.8-7.2-16-16-16zM160 96h192v32H160V96zm192 320H160V384h192v32zM96 384H64V352h32v32zm0-256H64V96h32v32zM416 384V352h32v32H416zm0-256V96h32v32H416z"/></svg>
            </div>
            <div class="feature-title">Pièces</div>
            <p class="feature-desc">
              Décomposez chaque projet pièce par pièce avec surface, périmètre et hauteur sous plafond. Vos devis reflètent la géométrie réelle des espaces.
            </p>
          </div>
        </div>

        <div class="col-md-4">
          <div class="feature-card-od">
            <div class="feature-icon-wrap feature-icon-wrap--green">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 512 512" fill="currentColor"><path d="M152.1 38.2c9.9 8.9 10.7 24 1.8 33.9l-72 80c-4.4 4.9-10.6 7.8-17.2 7.9s-12.9-2.4-17.6-7L7 113C-2.3 103.6-2.3 88.4 7 79s24.6-9.4 33.9 0l22.1 22.1 55.1-61.2c8.9-9.9 24-10.7 33.9-1.8zm0 160c9.9 8.9 10.7 24 1.8 33.9l-72 80c-4.4 4.9-10.6 7.8-17.2 7.9s-12.9-2.4-17.6-7L7 273c-9.4-9.4-9.4-24.6 0-33.9s24.6-9.4 33.9 0l22.1 22.1 55.1-61.2c8.9-9.9 24-10.7 33.9-1.8zM224 96c0-17.7 14.3-32 32-32H480c17.7 0 32 14.3 32 32s-14.3 32-32 32H256c-17.7 0-32-14.3-32-32zm0 160c0-17.7 14.3-32 32-32H480c17.7 0 32 14.3 32 32s-14.3 32-32 32H256c-17.7 0-32-14.3-32-32zM160 416c0-17.7 14.3-32 32-32H480c17.7 0 32 14.3 32 32s-14.3 32-32 32H192c-17.7 0-32-14.3-32-32zM48 368a48 48 0 1 1 0 96 48 48 0 1 1 0-96z"/></svg>
            </div>
            <div class="feature-title">Postes &amp; matériaux</div>
            <p class="feature-desc">
              Sélectionnez les matériaux depuis un catalogue partagé, saisissez les quantités et laissez OpenDevis calculer automatiquement vos totaux HT et TTC.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <%# ── COMMENT ÇA MARCHE ── %>
  <section class="how-section">
    <div class="container">
      <div class="text-center mb-5">
        <div class="section-eyebrow">En 3 étapes</div>
        <h2 class="section-heading">Comment ça marche</h2>
      </div>

      <div class="row g-4 justify-content-center align-items-center">
        <div class="col-md-3 text-center">
          <div class="step-circle">1</div>
          <div class="step-title">Créez un projet</div>
          <p class="step-desc">Ajoutez la localisation, la surface et la classe énergétique. Faites évoluer le statut au fil du temps.</p>
        </div>
        <div class="col-md-1 d-none d-md-flex align-items-center justify-content-center">
          <span class="step-arrow">→</span>
        </div>
        <div class="col-md-3 text-center">
          <div class="step-circle">2</div>
          <div class="step-title">Ajoutez les pièces</div>
          <p class="step-desc">Définissez les dimensions de chaque pièce. OpenDevis garde la structure claire et navigable.</p>
        </div>
        <div class="col-md-1 d-none d-md-flex align-items-center justify-content-center">
          <span class="step-arrow">→</span>
        </div>
        <div class="col-md-3 text-center">
          <div class="step-circle">3</div>
          <div class="step-title">Construisez votre devis</div>
          <p class="step-desc">Choisissez les matériaux, entrez les quantités — les totaux se mettent à jour sur l'ensemble du projet.</p>
        </div>
      </div>
    </div>
  </section>

  <%# ── APPEL À L'ACTION ── %>
  <% unless user_signed_in? %>
    <section class="cta-section">
      <div class="container text-center" style="position: relative; z-index: 1;">
        <h2 class="cta-heading">
          Prêt à créer votre<br><em>premier devis ?</em>
        </h2>
        <p class="cta-lead">Gratuit pour toujours. Sans carte bancaire.</p>
        <%= link_to new_user_registration_path, class: "btn-cta-primary" do %>
          Créer mon compte <i class="fa fa-arrow-right"></i>
        <% end %>
        <div>
          <span class="cta-badge">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 512 512" fill="currentColor" style="vertical-align:-0.05em"><path d="M256 0c4.6 0 9.2 1 13.4 2.9L457.7 82.8c22 9.3 38.4 31 38.3 57.2c-.5 99.2-41.3 280.7-213.7 363.2c-16.7 8-36.1 8-52.8 0C57.3 420.7 16.5 239.2 16 140c-.1-26.2 16.3-47.9 38.3-57.2L242.7 2.9C246.8 1 251.4 0 256 0z"/></svg>
            Aucun engagement · Résiliable à tout moment
          </span>
        </div>
      </div>
    </section>
  <% end %>

</div>
