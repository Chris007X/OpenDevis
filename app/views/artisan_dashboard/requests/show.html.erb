<style>
  .ad-req-scope * { font-family: 'Plus Jakarta Sans', sans-serif; }
  .ad-req-page { max-width: 700px; margin: 0 auto; padding: 2.5rem 1.25rem; }
  .ad-back-link { color: #9B9588; text-decoration: none; font-size: 0.85rem; font-weight: 600; transition: color 0.12s; }
  .ad-back-link:hover { color: #1C1A16; }
  .ad-req-heading {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: 1.85rem;
    font-weight: 400;
    color: #1C1A16;
    line-height: 1.15;
    margin: 1rem 0 0.25rem;
  }
  .ad-req-meta { color: #9B9588; font-size: 0.88rem; margin-bottom: 1.75rem; }
  .ad-info-card {
    background: #fff;
    border: 1.5px solid #E8E4DC;
    border-radius: 16px;
    padding: 1.5rem 1.75rem;
    box-shadow: 0 2px 12px rgba(44,42,37,0.05);
    margin-bottom: 1.5rem;
  }
  .ad-info-eyebrow {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: #9B9588;
    margin-bottom: 1rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid #E8E4DC;
  }
  .ad-info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.1rem; }
  .ad-info-label { font-size: 0.68rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #9B9588; margin-bottom: 3px; }
  .ad-info-value { font-weight: 600; color: #1C1A16; font-size: 0.92rem; }

  /* Status banners */
  .ad-status-banner {
    border-radius: 12px;
    padding: 1rem 1.25rem;
    margin-bottom: 1.25rem;
    font-size: 0.9rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .ad-status-banner--green { background: #DCFCE7; color: #15803D; border: 1.5px solid #BBF7D0; }
  .ad-status-banner--red   { background: #FEE2E2; color: #991B1B; border: 1.5px solid #FECACA; }
  .ad-status-banner--amber { background: #FEF3C7; color: #92400E; border: 1.5px solid #FDE68A; }

  .ad-comment-block {
    background: #FAFAF7;
    border: 1.5px solid #E8E4DC;
    border-radius: 10px;
    padding: 1rem 1.1rem;
    margin-bottom: 1.25rem;
  }
  .ad-comment-label { font-size: 0.68rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #9B9588; margin-bottom: 6px; }
  .ad-comment-text { font-size: 0.9rem; color: #1C1A16; white-space: pre-wrap; line-height: 1.6; }
  .ad-update-note { color: #9B9588; font-size: 0.85rem; margin-bottom: 1rem; }

  /* Form */
  .ad-form-card {
    background: #fff;
    border: 1.5px solid #E8E4DC;
    border-radius: 16px;
    padding: 1.75rem;
    box-shadow: 0 2px 12px rgba(44,42,37,0.05);
    margin-bottom: 1rem;
  }
  .ad-form-eyebrow {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: #9B9588;
    margin-bottom: 1.25rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid #E8E4DC;
  }
  .ad-form-label { font-size: 0.68rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #9B9588; display: block; margin-bottom: 0.4rem; }
  .ad-price-wrap {
    display: flex;
    align-items: center;
    border: 1.5px solid #DDD9D1;
    border-radius: 10px;
    overflow: hidden;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .ad-price-wrap:focus-within {
    border-color: #2563eb;
    box-shadow: 0 0 0 3px rgba(37,99,235,0.1);
  }
  .ad-price-input {
    border: none;
    padding: 0.7rem 1rem;
    font-size: 1.1rem;
    font-weight: 700;
    color: #1C1A16;
    flex: 1;
    outline: none;
    background: transparent;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .ad-price-unit { padding: 0 1rem; color: #9B9588; font-size: 0.9rem; font-weight: 600; }
  .ad-price-hint { font-size: 0.75rem; color: #9B9588; margin-top: 0.35rem; }
  .ad-textarea {
    width: 100%;
    border: 1.5px solid #DDD9D1;
    border-radius: 10px;
    padding: 0.7rem 0.9rem;
    font-size: 0.9rem;
    font-family: 'Plus Jakarta Sans', sans-serif;
    color: #1C1A16;
    resize: vertical;
    outline: none;
    background: #fff;
    transition: border-color 0.15s, box-shadow 0.15s;
    box-sizing: border-box;
  }
  .ad-textarea:focus {
    border-color: #2563eb;
    box-shadow: 0 0 0 3px rgba(37,99,235,0.1);
  }
  .btn-ad-submit {
    background: #2563eb;
    color: #fff;
    border: none;
    border-radius: 50px;
    padding: 0.75rem 2rem;
    font-size: 0.95rem;
    font-weight: 700;
    cursor: pointer;
    font-family: 'Plus Jakarta Sans', sans-serif;
    transition: background 0.15s, box-shadow 0.15s;
    width: 100%;
  }
  .btn-ad-submit:hover {
    background: #1d4ed8;
    box-shadow: 0 4px 12px rgba(37,99,235,0.3);
  }
  .btn-ad-decline {
    background: transparent;
    color: #9B9588;
    border: 1.5px solid #E8E4DC;
    border-radius: 50px;
    padding: 0.65rem 1.5rem;
    font-size: 0.88rem;
    font-weight: 600;
    cursor: pointer;
    font-family: 'Plus Jakarta Sans', sans-serif;
    transition: border-color 0.12s, color 0.12s;
    width: 100%;
  }
  .btn-ad-decline:hover { border-color: #FECACA; color: #991B1B; }
  .ad-error-banner {
    background: #FEF3C7;
    color: #92400E;
    border: 1.5px solid #FDE68A;
    border-radius: 10px;
    padding: 0.75rem 1rem;
    margin-bottom: 1rem;
    font-size: 0.88rem;
  }
</style>

<div class="ad-req-scope">
  <div class="ad-req-page">
    <%= link_to "← Retour aux demandes", artisan_dashboard_root_path, class: "ad-back-link" %>

    <h1 class="ad-req-heading"><%= @bidding_request.work_category.name %></h1>
    <p class="ad-req-meta">
      Demande de devis reçue · Limite : <%= @bidding_request.bidding_round.deadline.strftime("%d/%m/%Y à %H:%M") %>
    </p>

    <%# Info block %>
    <div class="ad-info-card">
      <div class="ad-info-eyebrow">Détails du projet</div>
      <div class="ad-info-grid">
        <div>
          <div class="ad-info-label">Catégorie</div>
          <div class="ad-info-value"><%= @bidding_request.work_category.name %></div>
        </div>
        <div>
          <div class="ad-info-label">Localisation</div>
          <div class="ad-info-value"><%= @bidding_request.bidding_round.project.location_zip %></div>
        </div>
        <div>
          <div class="ad-info-label">Standing</div>
          <div class="ad-info-value"><%= @bidding_request.bidding_round.standing_label %></div>
        </div>
        <div>
          <div class="ad-info-label">Date limite</div>
          <div class="ad-info-value"><%= @bidding_request.bidding_round.deadline.strftime("%d/%m/%Y") %></div>
        </div>
        <% if @bidding_request.bidding_round.project.total_surface_sqm.present? %>
          <div>
            <div class="ad-info-label">Surface</div>
            <div class="ad-info-value"><%= @bidding_request.bidding_round.project.total_surface_sqm.to_i %> m²</div>
          </div>
        <% end %>
        <% if @bidding_request.bidding_round.project.room_count.present? %>
          <div>
            <div class="ad-info-label">Pièces</div>
            <div class="ad-info-value"><%= @bidding_request.bidding_round.project.room_count %></div>
          </div>
        <% end %>
      </div>
    </div>

    <% if @bidding_request.status == "responded" %>
      <div class="ad-status-banner ad-status-banner--green">
        <i class="fas fa-circle-check"></i>
        Devis envoyé ·
        <%= number_to_currency(@bidding_request.price_total, unit: "€", format: "%n %u") %> HT
        · le <%= @bidding_request.responded_at&.strftime("%d/%m/%Y à %H:%M") %>
      </div>

      <% if @bidding_request.artisan_comment.present? %>
        <div class="ad-comment-block">
          <div class="ad-comment-label">Commentaire inclus</div>
          <div class="ad-comment-text"><%= @bidding_request.artisan_comment %></div>
        </div>
      <% end %>

      <% unless @bidding_request.bidding_round.deadline_passed? %>
        <p class="ad-update-note">Vous pouvez modifier votre prix jusqu'à la date limite.</p>
        <div class="ad-form-card">
          <div class="ad-form-eyebrow">Mettre à jour mon devis</div>
          <%= form_with url: submit_price_artisan_dashboard_request_path(@bidding_request), method: :post do |f| %>
            <div style="margin-bottom: 1.25rem;">
              <label class="ad-form-label">Nouveau prix total HT (€)</label>
              <div class="ad-price-wrap">
                <input type="number" name="price_total" step="0.01" min="0.01"
                       value="<%= @bidding_request.price_total %>"
                       class="ad-price-input">
                <span class="ad-price-unit">€ HT</span>
              </div>
            </div>
            <div style="margin-bottom: 1.25rem;">
              <label class="ad-form-label">Commentaire (optionnel)</label>
              <textarea name="artisan_comment" rows="4"
                        placeholder="Décrivez ce qui est inclus dans votre devis (prestations, matériaux, délais…)"
                        class="ad-textarea"><%= @bidding_request.artisan_comment %></textarea>
            </div>
            <button type="submit" class="btn-ad-submit">Mettre à jour</button>
          <% end %>
        </div>
      <% end %>

    <% elsif @bidding_request.status == "declined" %>
      <div class="ad-status-banner ad-status-banner--red">
        <i class="fas fa-circle-xmark"></i>
        Demande déclinée · Vous avez décliné cette demande.
      </div>

    <% elsif @bidding_request.status == "expired" %>
      <div class="ad-status-banner ad-status-banner--amber">
        <i class="fas fa-clock"></i>
        Délai dépassé · La date limite de réponse est passée.
      </div>

    <% elsif @bidding_request.status == "replaced" %>
      <div class="ad-status-banner ad-status-banner--amber">
        <i class="fas fa-ban"></i>
        Demande annulée · Cette demande a été annulée par le donneur d'ordre.
      </div>

    <% else %>
      <% if @error %>
        <div class="ad-error-banner"><%= @error %></div>
      <% end %>

      <% if @bidding_request.bidding_round.deadline_passed? %>
        <div class="ad-status-banner ad-status-banner--amber">
          <i class="fas fa-clock"></i>
          Délai dépassé · La date limite de réponse est passée.
        </div>
      <% else %>
        <div class="ad-form-card">
          <div class="ad-form-eyebrow">Soumettre mon devis</div>
          <%= form_with url: submit_price_artisan_dashboard_request_path(@bidding_request), method: :post do |f| %>
            <div style="margin-bottom: 1.25rem;">
              <label class="ad-form-label">Votre prix total HT (€)</label>
              <div class="ad-price-wrap">
                <input type="number" name="price_total" step="0.01" min="0.01"
                       placeholder="Ex : 3500.00"
                       class="ad-price-input">
                <span class="ad-price-unit">€ HT</span>
              </div>
              <p class="ad-price-hint">Indiquez votre prix de main-d'œuvre et fournitures, hors taxes.</p>
            </div>
            <div style="margin-bottom: 1.5rem;">
              <label class="ad-form-label">Commentaire (optionnel)</label>
              <textarea name="artisan_comment" rows="4"
                        placeholder="Décrivez ce qui est inclus dans votre devis (prestations, matériaux, délais…)"
                        class="ad-textarea"></textarea>
            </div>
            <button type="submit" class="btn-ad-submit">Envoyer mon devis</button>
          <% end %>
        </div>

        <div>
          <%= form_with url: decline_artisan_dashboard_request_path(@bidding_request), method: :post do |f| %>
            <button type="submit"
                    onclick="return confirm('Êtes-vous sûr de vouloir décliner cette demande ?')"
                    class="btn-ad-decline">
              Décliner la demande
            </button>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
